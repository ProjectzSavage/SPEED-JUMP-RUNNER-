local Players = game:GetService("Players")
local UserInputService = game:GetService("UserInputService")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local TweenService = game:GetService("TweenService")

local player = Players.LocalPlayer
local playerGui = player:WaitForChild("PlayerGui")

local TITLES = {
	{ name = "Newbie", speedReq = 0, jumpReq = 0, rebirthReq = 0, color = Color3.fromRGB(255, 255, 255) },
	{ name = "Walker", speedReq = 1000, jumpReq = 50, rebirthReq = 0, color = Color3.fromRGB(0, 255, 0) },
	{ name = "Runner", speedReq = 5000, jumpReq = 100, rebirthReq = 1, color = Color3.fromRGB(0, 150, 255) },
	{ name = "Speedster", speedReq = 10000, jumpReq = 300, rebirthReq = 1, color = Color3.fromRGB(255, 165, 0) },
	{ name = "Lightning", speedReq = 35000, jumpReq = 750, rebirthReq = 2, color = Color3.fromRGB(255, 215, 0) },
	{ name = "Sonic", speedReq = 75000, jumpReq = 3000, rebirthReq = 3, color = Color3.fromRGB(255, 0, 255) },
	{ name = "Flash", speedReq = 100000, jumpReq = 10000, rebirthReq = 4, color = Color3.fromRGB(255, 0, 0) },
}

local equipTitleRemote = ReplicatedStorage:WaitForChild("EquipTitle")
local titleGUI = playerGui:WaitForChild("TitleGUI")
local MainMenuButtonsGUI = playerGui:WaitForChild("MainMenuButtons")
local toggleButton = MainMenuButtonsGUI:WaitForChild("Frame"):WaitForChild("TitleToggleButton")
local mainFrame = titleGUI:WaitForChild("MainFrame")
local titleList = mainFrame:WaitForChild("TitleList")
local closeButton = mainFrame:WaitForChild("CloseButton")

local equippedTitleName = "Newbie"

local animating = false
local openPos = mainFrame.Position
local closedPos = UDim2.new(openPos.X.Scale, openPos.X.Offset, openPos.Y.Scale - 0.12, openPos.Y.Offset)

local uiScale = mainFrame:FindFirstChildOfClass("UIScale")
if not uiScale then
	uiScale = Instance.new("UIScale")
	uiScale.Scale = 1
	uiScale.Parent = mainFrame
end

mainFrame.Visible = false
mainFrame.Position = openPos
uiScale.Scale = 1

local function openFrame()
	if animating then return end
	animating = true
	mainFrame.Visible = true
	mainFrame.Position = closedPos
	uiScale.Scale = 0.94

	local t1 = TweenService:Create(mainFrame, TweenInfo.new(0.22, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {Position = openPos})
	local t2 = TweenService:Create(uiScale, TweenInfo.new(0.22, Enum.EasingStyle.Back, Enum.EasingDirection.Out), {Scale = 1})
	t1:Play()
	t2:Play()
	t1.Completed:Wait()
	animating = false
end

local function closeFrame()
	if animating or not mainFrame.Visible then return end
	animating = true
	local t1 = TweenService:Create(mainFrame, TweenInfo.new(0.18, Enum.EasingStyle.Quad, Enum.EasingDirection.In), {Position = closedPos})
	local t2 = TweenService:Create(uiScale, TweenInfo.new(0.18, Enum.EasingStyle.Quad, Enum.EasingDirection.In), {Scale = 0.94})
	t1:Play()
	t2:Play()
	t1.Completed:Wait()
	mainFrame.Visible = false
	mainFrame.Position = openPos
	uiScale.Scale = 1
	animating = false
end

local function isUnlocked(title)
	local leaderstats = player:FindFirstChild("leaderstats")
	local statsFolder = player:FindFirstChild("Stats")
	if not leaderstats or not statsFolder then return false end
	local speed = leaderstats:FindFirstChild("Speed")
	local rebirths = leaderstats:FindFirstChild("Rebirths")
	local jumps = statsFolder:FindFirstChild("Jumps")
	if not speed or not rebirths or not jumps then return false end
	return speed.Value >= title.speedReq and jumps.Value >= title.jumpReq and rebirths.Value >= title.rebirthReq
end

local function updateEquippedFromLeaderstats()
	local leaderstats = player:FindFirstChild("leaderstats")
	if not leaderstats then return end
	local titleStat = leaderstats:FindFirstChild("Title")
	if titleStat and titleStat.Value ~= "" then
		equippedTitleName = titleStat.Value
	end
end

local function clearListFrames()
	for _, child in ipairs(titleList:GetChildren()) do
		if child:IsA("Frame") then child:Destroy() end
	end
end

local TITLE_MULTIPLIERS = {
	Newbie = 1.00,
	Walker = 1.05,
	Runner = 1.10,
	Speedster = 1.15,
	Lightning = 1.25,
	Sonic = 1.35,
	Flash = 1.50,
}

local template = titleList:WaitForChild("TitleRowTemplate")
template.Visible = false

local function updateTitleDisplay()
	updateEquippedFromLeaderstats()

	for _, child in ipairs(titleList:GetChildren()) do
		if child:IsA("Frame") and child ~= template then
			child:Destroy()
		end
	end

	for i, title in ipairs(TITLES) do
		local row = template:Clone()
		row.Name = "TitleRow_" .. i
		row.Visible = true
		row.LayoutOrder = i
		row.Parent = titleList

		local nameLabel = row:WaitForChild("NameLabel")
		local reqLabel = row:WaitForChild("RequirementsLabel")
		local multLabel = row:WaitForChild("TitleMultLabel")
		local statusButton = row:WaitForChild("StatusButton")

		nameLabel.Text = title.name
		nameLabel.TextColor3 = title.color

		reqLabel.Text = title.speedReq .. " Speed, " .. title.jumpReq .. " Jumps, " .. title.rebirthReq .. " Rebirths"
		multLabel.Text = "Boost x" .. string.format("%.2f", TITLE_MULTIPLIERS[title.name] or 1)

		local unlocked = isUnlocked(title)
		local equipped = (title.name == equippedTitleName)

		if not unlocked then
			statusButton.BackgroundColor3 = Color3.fromRGB(255, 0, 0)
			statusButton.Text = "LOCKED"
		elseif equipped then
			statusButton.BackgroundColor3 = Color3.fromRGB(0, 170, 255)
			statusButton.Text = "EQUIPPED"
		else
			statusButton.BackgroundColor3 = Color3.fromRGB(0, 255, 0)
			statusButton.Text = "EQUIP"
		end

		statusButton.MouseButton1Click:Connect(function()
			if not unlocked or equipped then return end
			equippedTitleName = title.name
			equipTitleRemote:FireServer(title)
			updateTitleDisplay()
		end)
	end

	local listLayout = titleList:FindFirstChildOfClass("UIListLayout")
	if titleList:IsA("ScrollingFrame") and listLayout then
		task.defer(function()
			titleList.CanvasSize = UDim2.new(0, 0, 0, listLayout.AbsoluteContentSize.Y + 8)
		end)
	end
end

toggleButton.MouseButton1Click:Connect(function()
	if mainFrame.Visible then
		closeFrame()
	else
		updateTitleDisplay()
		openFrame()
	end
end)

closeButton.MouseButton1Click:Connect(closeFrame)

UserInputService.InputBegan:Connect(function(input, gameProcessed)
	if gameProcessed then return end
	if input.KeyCode == Enum.KeyCode.R then
		if mainFrame.Visible then
			closeFrame()
		else
			updateTitleDisplay()
			openFrame()
		end
	end
end)

task.spawn(function()
	local leaderstats = player:WaitForChild("leaderstats")
	local titleStat = leaderstats:FindFirstChild("Title")
	if titleStat then
		titleStat.Changed:Connect(function()
			updateEquippedFromLeaderstats()
			if mainFrame.Visible then updateTitleDisplay() end
		end)
	end
end)
