local Players = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local UserInputService = game:GetService("UserInputService")

local player = Players.LocalPlayer
local playerGui = player:WaitForChild("PlayerGui")

local REBIRTH_DATA = {
	[1] = {speed = 100, multiplier = 2},
	[2] = {speed = 1000, multiplier = 3},
	[3] = {speed = 5000, multiplier = 4},
	[4] = {speed = 25000, multiplier = 5}
}

wait(2)

local rebirthGUI = playerGui:WaitForChild("RebirthGUI")
local toggleButton = rebirthGUI:WaitForChild("ToggleButton")
local mainFrame = rebirthGUI:WaitForChild("MainFrame")
local currentRebirthFrame = mainFrame:WaitForChild("CurrentRebirthFrame")
local nextRebirthLabel = currentRebirthFrame:WaitForChild("NextRebirthLabel")
local requirementLabel = currentRebirthFrame:WaitForChild("RequirementLabel")
local progressBarFrame = currentRebirthFrame:WaitForChild("ProgressBarFrame")
local progressBar = progressBarFrame:WaitForChild("ProgressBar")
local rebirthButton = mainFrame:WaitForChild("RebirthButton")
local rewardsFrame = mainFrame:WaitForChild("RewardsFrame")
local closeButton = mainFrame:WaitForChild("CloseButton")

local rebirthRemote = ReplicatedStorage:WaitForChild("RebirthRequest")

local function formatNumber(num)
	if num >= 1000000000 then
		return string.format("%.1fB", num / 1000000000)
	elseif num >= 1000000 then
		return string.format("%.1fM", num / 1000000)
	elseif num >= 1000 then
		return string.format("%.1fK", num / 1000)
	else
		return tostring(num)
	end
end

local function getNextRebirth()
	local leaderstats = player:FindFirstChild("leaderstats")
	if not leaderstats then return 1 end

	local currentRebirths = leaderstats:FindFirstChild("Rebirths")
	if not currentRebirths then return 1 end

	local nextRebirth = currentRebirths.Value + 1
	return nextRebirth <= 4 and nextRebirth or nil
end

local function canRebirth()
	local nextRebirth = getNextRebirth()
	if not nextRebirth then return false end

	local leaderstats = player:FindFirstChild("leaderstats")
	if not leaderstats then return false end

	local speed = leaderstats:FindFirstChild("Speed")
	if not speed then return false end

	local requirement = REBIRTH_DATA[nextRebirth]
	return speed.Value >= requirement.speed
end

local function updateRebirthDisplay()
	local nextRebirth = getNextRebirth()
	local leaderstats = player:FindFirstChild("leaderstats")

	if not nextRebirth or not leaderstats then
		nextRebirthLabel.Text = "MAX REBIRTH REACHED!"
		requirementLabel.Text = "You've reached the maximum rebirth level"
		rebirthButton.Text = "MAXED OUT"
		rebirthButton.BackgroundColor3 = Color3.fromRGB(100, 100, 100)
		progressBar.Size = UDim2.new(1, 0, 1, 0)
		return
	end

	local speed = leaderstats:FindFirstChild("Speed")
	if not speed then return end

	local data = REBIRTH_DATA[nextRebirth]
	local progress = math.min(speed.Value / data.speed, 1)

	nextRebirthLabel.Text = "Next Rebirth: " .. nextRebirth
	requirementLabel.Text = "Need: " .. formatNumber(data.speed) .. " Speed (" .. formatNumber(speed.Value) .. "/" .. formatNumber(data.speed) .. ")"

	progressBar.Size = UDim2.new(progress, 0, 1, 0)

	if canRebirth() then
		rebirthButton.BackgroundColor3 = Color3.fromRGB(0, 255, 0)
		rebirthButton.Text = "REBIRTH " .. nextRebirth
	else
		rebirthButton.BackgroundColor3 = Color3.fromRGB(255, 100, 100)
		rebirthButton.Text = "LOCKED"
	end
end

local function updateRewardsDisplay()
	for _, child in pairs(rewardsFrame:GetChildren()) do
		if child:IsA("Frame") then
			child:Destroy()
		end
	end

	local leaderstats = player:FindFirstChild("leaderstats")
	if not leaderstats then return end

	local currentRebirths = leaderstats:FindFirstChild("Rebirths")
	if not currentRebirths then return end

	for i = 1, currentRebirths.Value do
		local rebirthInfo = Instance.new("Frame")
		rebirthInfo.Name = "RebirthInfoFrame"
		rebirthInfo.Size = UDim2.new(1, 0, 0, 50)
		rebirthInfo.BackgroundColor3 = Color3.fromRGB(70, 70, 70)
		rebirthInfo.Parent = rewardsFrame

		local rebirthTitle = Instance.new("TextLabel")
		rebirthTitle.Name = "RebirthTitle"
		rebirthTitle.Size = UDim2.new(0.6, 0, 1, 0)
		rebirthTitle.BackgroundTransparency = 1
		rebirthTitle.Text = "Rebirth " .. i
		rebirthTitle.TextScaled = true
		rebirthTitle.TextColor3 = Color3.fromRGB(255, 255, 255)
		rebirthTitle.Parent = rebirthInfo

		local multiplierLabel = Instance.new("TextLabel")
		multiplierLabel.Name = "MultiplierLabel"
		multiplierLabel.Size = UDim2.new(0.4, 0, 1, 0)
		multiplierLabel.Position = UDim2.new(0.6, 0, 0, 0)
		multiplierLabel.BackgroundTransparency = 1
		multiplierLabel.Text = REBIRTH_DATA[i].multiplier .. "x"
		multiplierLabel.TextScaled = true
		multiplierLabel.TextColor3 = Color3.fromRGB(0, 255, 127)
		multiplierLabel.Parent = rebirthInfo
	end
end

rebirthButton.MouseButton1Click:Connect(function()
	local nextRebirth = getNextRebirth()
	if nextRebirth and canRebirth() then
		rebirthRemote:FireServer(nextRebirth)
		mainFrame.Visible = false
	end
end)

toggleButton.MouseButton1Click:Connect(function()
	print("Rebirth toggle clicked!")
	print("MainFrame found:", mainFrame)
	print("MainFrame current visibility:", mainFrame.Visible)
	mainFrame.Visible = not mainFrame.Visible
	print("MainFrame new visibility:", mainFrame.Visible)
	if mainFrame.Visible then
		print("Updating rebirth display...")
		updateRebirthDisplay()
		updateRewardsDisplay()
	end
end)

closeButton.MouseButton1Click:Connect(function()
	mainFrame.Visible = false
end)

UserInputService.InputBegan:Connect(function(input, gameProcessed)
	if gameProcessed then return end
	if input.KeyCode == Enum.KeyCode.B then
		mainFrame.Visible = not mainFrame.Visible
		if mainFrame.Visible then
			updateRebirthDisplay()
			updateRewardsDisplay()
		end
	end
end)

spawn(function()
	while wait(1) do
		if mainFrame.Visible then
			updateRebirthDisplay()
		end
	end
end)

if player.leaderstats then
	if player.leaderstats:FindFirstChild("Speed") then
		player.leaderstats.Speed.Changed:Connect(function()
			if mainFrame.Visible then
				updateRebirthDisplay()
			end
		end)
	end
	if player.leaderstats:FindFirstChild("Rebirths") then
		player.leaderstats.Rebirths.Changed:Connect(function()
			if mainFrame.Visible then
				updateRebirthDisplay()
				updateRewardsDisplay()
			end
		end)
	end
end
