local Players = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local ServerStorage = game:GetService("ServerStorage")

local SKINS = {
	Flash = {
		name = "Flash",
		speedReq = 1000,
		rebirthReq = 1,
		speedBoost = 0.05,
		description = "+5% Speed Boost",
		clothing = { Shirt = 14506431850, Pants = 14506438924 },
		accessoryNames = {"FlashMask"},
	},
	Speedster = {
		name = "Speedster",
		speedReq = 5000,
		rebirthReq = 2,
		speedBoost = 0.10,
		description = "+10% Speed Boost",
		clothing = { Shirt = 0, Pants = 0 },
		accessoryNames = {},
	},
	Velocity = {
		name = "Velocity",
		speedReq = 10000,
		rebirthReq = 3,
		speedBoost = 0.15,
		description = "+15% Speed Boost",
		clothing = { Shirt = 0, Pants = 0 },
		accessoryNames = {},
	},
	Hypersonic = {
		name = "Hypersonic",
		speedReq = 25000,
		rebirthReq = 4,
		speedBoost = 0.20,
		description = "+20% Speed Boost",
		clothing = { Shirt = 0, Pants = 0 },
		accessoryNames = {},
	},

}

local equipSkinRemote = ReplicatedStorage:FindFirstChild("EquipSkin")
if not equipSkinRemote then
	equipSkinRemote = Instance.new("RemoteEvent")
	equipSkinRemote.Name = "EquipSkin"
	equipSkinRemote.Parent = ReplicatedStorage
end

local equippedSkins = {}
local originalAvatars = {}

local function ensureSkinStats(player)
	local leaderstats = player:FindFirstChild("leaderstats")
	if not leaderstats then return nil end

	local currentSkin = leaderstats:FindFirstChild("CurrentSkin")
	if not currentSkin then
		currentSkin = Instance.new("StringValue")
		currentSkin.Name = "CurrentSkin"
		currentSkin.Value = "None"
		currentSkin.Parent = leaderstats
	end

	local speedBoost = leaderstats:FindFirstChild("SpeedBoost")
	if not speedBoost then
		speedBoost = Instance.new("NumberValue")
		speedBoost.Name = "SpeedBoost"
		speedBoost.Value = 0
		speedBoost.Parent = leaderstats
	end

	return currentSkin, speedBoost
end

local function saveOriginalAvatar(player)
	if not player.Character then return end
	local humanoid = player.Character:FindFirstChildOfClass("Humanoid")
	if not humanoid then return end

	local ok, desc = pcall(function()
		return humanoid:GetAppliedDescription()
	end)
	if ok and desc then
		originalAvatars[player] = desc
	end
end
local function getSpeedBoostValue(player)
	local stats = player:FindFirstChild("Stats")
	if not stats then
		stats = Instance.new("Folder")
		stats.Name = "Stats"
		stats.Parent = player
	end

	local speedBoost = stats:FindFirstChild("SpeedBoost")
	if not speedBoost then
		speedBoost = Instance.new("NumberValue")
		speedBoost.Name = "SpeedBoost"
		speedBoost.Value = 0
		speedBoost.Parent = stats
	end

	return speedBoost
end
local function applySkin(player, skinName)
	local skin = SKINS[skinName]
	local speedBoost = getSpeedBoostValue(player)
	speedBoost.Value = skin.speedBoost
	if not skin then return end
	if not player.Character then return end

	local humanoid = player.Character:FindFirstChildOfClass("Humanoid")
	if not humanoid then return end

	local success, description = pcall(function()
		return humanoid:GetAppliedDescription()
	end)
	if not success or not description then return end

	if skin.clothing.Shirt > 0 then
		description.Shirt = skin.clothing.Shirt
	end
	if skin.clothing.Pants > 0 then
		description.Pants = skin.clothing.Pants
	end

	pcall(function()
		humanoid:ApplyDescription(description)
	end)

	task.wait(0.2)

	for _, accessoryName in ipairs(skin.accessoryNames) do
		local accessory = ServerStorage:FindFirstChild(accessoryName) or ReplicatedStorage:FindFirstChild(accessoryName)
		if accessory and accessory:IsA("Accessory") then
			local clone = accessory:Clone()
			clone.Parent = player.Character
		end
	end

	local currentSkin, speedBoost = ensureSkinStats(player)
	if currentSkin then currentSkin.Value = skin.name end
	if speedBoost then speedBoost.Value = skin.speedBoost end
end

local function removeSkin(player)
	if not player.Character then return end

	local humanoid = player.Character:FindFirstChildOfClass("Humanoid")
	if not humanoid then return end

	if originalAvatars[player] then
		pcall(function()
			humanoid:ApplyDescription(originalAvatars[player])
		end)
	else
		local ok, desc = pcall(function()
			return Players:GetHumanoidDescriptionFromUserIdAsync(player.UserId)
		end)
		if ok and desc then
			pcall(function()
				humanoid:ApplyDescription(desc)
			end)
		end
	end

	local currentSkin, speedBoost = getSpeedBoostValue(player)
	if currentSkin then currentSkin.Value = "None" end
	if speedBoost then speedBoost.Value = 0 end
end

equipSkinRemote.OnServerEvent:Connect(function(player, skinName)
	if skinName and skinName ~= "" then
		equippedSkins[player] = skinName
		applySkin(player, skinName)
	else
		equippedSkins[player] = nil
		removeSkin(player)
	end
end)

Players.PlayerAdded:Connect(function(player)
	player.CharacterAdded:Connect(function()
		task.wait(0.6)
		ensureSkinStats(player)
		saveOriginalAvatar(player)

		task.wait(0.3)
		if equippedSkins[player] then
			applySkin(player, equippedSkins[player])
		end
	end)
end)

Players.PlayerRemoving:Connect(function(player)
	equippedSkins[player] = nil
	originalAvatars[player] = nil
end)
