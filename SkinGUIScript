local Players = game:GetService("Players")
local UserInputService = game:GetService("UserInputService")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local TweenService = game:GetService("TweenService")

local player = Players.LocalPlayer
local playerGui = player:WaitForChild("PlayerGui")
local equipSkinRemote = ReplicatedStorage:WaitForChild("EquipSkin")

local SKINS = {
	{name = "Flash", speedReq = 1000, rebirthReq = 1, speedBoost = 0.05, description = "+1.05% Speed Boost", color = Color3.fromRGB(255, 0, 0)},
	{name = "Speedster", speedReq = 5000, rebirthReq = 2, speedBoost = 0.10, description = "+1.10% Speed Boost", color = Color3.fromRGB(0, 150, 255)},
	{name = "Velocity", speedReq = 10000, rebirthReq = 3, speedBoost = 0.15, description = "+1.15% Speed Boost", color = Color3.fromRGB(255, 215, 0)},
	{name = "Hypersonic", speedReq = 25000, rebirthReq = 4, speedBoost = 0.20, description = "+1.20% Speed Boost", color = Color3.fromRGB(138, 43, 226)},
}

local skinGUI = playerGui:WaitForChild("SkinGUI")
local toggleButton = skinGUI:WaitForChild("ToggleButton")
local mainFrame = skinGUI:WaitForChild("MainFrame")
local skinList = mainFrame:WaitForChild("SkinList")
local closeButton = mainFrame:WaitForChild("CloseButton")
local template = skinList:WaitForChild("SkinRowTemplate")
template.Visible = false

local removeSkinButton = mainFrame:WaitForChild("RemoveSkinButton")

local equippedSkinName = "None"

local animating = false
local openPos = mainFrame.Position
local closedPos = UDim2.new(openPos.X.Scale, openPos.X.Offset, openPos.Y.Scale - 0.12, openPos.Y.Offset)

local uiScale = mainFrame:FindFirstChildOfClass("UIScale")
if not uiScale then
	uiScale = Instance.new("UIScale")
	uiScale.Scale = 1
	uiScale.Parent = mainFrame
end

mainFrame.Visible = false

local function openFrame()
	if animating then return end
	animating = true
	mainFrame.Visible = true
	mainFrame.Position = closedPos
	uiScale.Scale = 0.94

	local t1 = TweenService:Create(mainFrame, TweenInfo.new(0.22, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {Position = openPos})
	local t2 = TweenService:Create(uiScale, TweenInfo.new(0.22, Enum.EasingStyle.Back, Enum.EasingDirection.Out), {Scale = 1})
	t1:Play()
	t2:Play()
	t1.Completed:Wait()
	animating = false
end

local function closeFrame()
	if animating or not mainFrame.Visible then return end
	animating = true

	local t1 = TweenService:Create(mainFrame, TweenInfo.new(0.18, Enum.EasingStyle.Quad, Enum.EasingDirection.In), {Position = closedPos})
	local t2 = TweenService:Create(uiScale, TweenInfo.new(0.18, Enum.EasingStyle.Quad, Enum.EasingDirection.In), {Scale = 0.94})
	t1:Play()
	t2:Play()
	t1.Completed:Wait()

	mainFrame.Visible = false
	mainFrame.Position = openPos
	uiScale.Scale = 1
	animating = false
end

local function formatNumber(num)
	if num >= 1e9 then
		return string.format("%.1fB", num / 1e9)
	elseif num >= 1e6 then
		return string.format("%.1fM", num / 1e6)
	elseif num >= 1e3 then
		return string.format("%.1fK", num / 1e3)
	end
	return tostring(math.floor(num))
end

local function getCurrentSkinName()
	local leaderstats = player:FindFirstChild("leaderstats")
	if not leaderstats then return "None" end
	local currentSkin = leaderstats:FindFirstChild("CurrentSkin")
	if currentSkin and currentSkin.Value ~= "" then
		return currentSkin.Value
	end
	return "None"
end

local function isUnlocked(skin)
	local leaderstats = player:FindFirstChild("leaderstats")
	if not leaderstats then return false end

	local speed = leaderstats:FindFirstChild("Speed")
	local rebirths = leaderstats:FindFirstChild("Rebirths")
	if not speed or not rebirths then return false end

	return speed.Value >= skin.speedReq and rebirths.Value >= skin.rebirthReq
end

local function clearRows()
	for _, child in ipairs(skinList:GetChildren()) do
		if child:IsA("Frame") and child ~= template then
			child:Destroy()
		end
	end
end

local function updateSkinDisplay()
	equippedSkinName = getCurrentSkinName()
	clearRows()

	for i, skin in ipairs(SKINS) do
		local row = template:Clone()
		row.Name = "SkinRow_" .. i
		row.Visible = true
		row.LayoutOrder = i
		row.Parent = skinList

		local nameLabel = row:WaitForChild("NameLabel")
		local descriptionLabel = row:WaitForChild("DescriptionLabel")
		local reqLabel = row:WaitForChild("RequirementsLabel")
		local boostLabel = row:WaitForChild("SkinBoostLabel")
		local statusButton = row:WaitForChild("StatusButton")

		nameLabel.Text = skin.name
		nameLabel.TextColor3 = skin.color
		descriptionLabel.Text = skin.description
		reqLabel.Text = formatNumber(skin.speedReq) .. " Speed, " .. skin.rebirthReq .. " Rebirths"
		boostLabel.Text = "+" .. tostring(math.floor(skin.speedBoost * 100 + 0.5)) .. "% Speed"

		local unlocked = isUnlocked(skin)
		local equipped = (equippedSkinName == skin.name)

		if not unlocked then
			statusButton.BackgroundColor3 = Color3.fromRGB(255, 0, 0)
			statusButton.Text = "LOCKED"
		elseif equipped then
			statusButton.BackgroundColor3 = Color3.fromRGB(0, 170, 255)
			statusButton.Text = "EQUIPPED"
		else
			statusButton.BackgroundColor3 = Color3.fromRGB(0, 255, 0)
			statusButton.Text = "EQUIP"
		end

		statusButton.MouseButton1Click:Connect(function()
			if not unlocked or equipped then return end
			equippedSkinName = skin.name
			equipSkinRemote:FireServer(skin.name)
			updateSkinDisplay()
		end)
	end
end

toggleButton.MouseButton1Click:Connect(function()
	if mainFrame.Visible then
		closeFrame()
	else
		updateSkinDisplay()
		openFrame()
	end
end)

closeButton.MouseButton1Click:Connect(closeFrame)

UserInputService.InputBegan:Connect(function(input, processed)
	if processed then return end
	if input.KeyCode == Enum.KeyCode.K then
		if mainFrame.Visible then
			closeFrame()
		else
			updateSkinDisplay()
			openFrame()
		end
	end
end)
removeSkinButton.MouseButton1Click:Connect(function()
	equippedSkinName = "None"
	equipSkinRemote:FireServer("")
	updateSkinDisplay()
end)
task.spawn(function()
	local leaderstats = player:WaitForChild("leaderstats")
	leaderstats:WaitForChild("Speed").Changed:Connect(function()
		if mainFrame.Visible then updateSkinDisplay() end
	end)
	leaderstats:WaitForChild("Rebirths").Changed:Connect(function()
		if mainFrame.Visible then updateSkinDisplay() end
	end)

	local currentSkin = leaderstats:FindFirstChild("CurrentSkin")
	if currentSkin then
		currentSkin.Changed:Connect(function()
			if mainFrame.Visible then updateSkinDisplay() end
		end)
	end
end)
