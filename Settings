local ReplicatedStorage = game:GetService("ReplicatedStorage")
local TweenService = game:GetService("TweenService")
local Lighting = game:GetService("Lighting")
local Workspace = game:GetService("Workspace")
local Players = game:GetService("Players")

local player = Players.LocalPlayer
local playerGui = player:WaitForChild("PlayerGui")

local Icon = require(ReplicatedStorage:WaitForChild("Icon"))

local gui = playerGui:WaitForChild("SettingsGUI")
local mainFrame = gui:WaitForChild("MainFrame")
local titleLabel = mainFrame:WaitForChild("TitleLabel")
local closeButton = mainFrame:WaitForChild("CloseButton")
local shadowsToggleButton = mainFrame:WaitForChild("ShadowsToggleButton")
local shadowsStatusLabel = mainFrame:WaitForChild("ShadowsStatusLabel")
local musicToggleButton = mainFrame:WaitForChild("MusicToggleButton")
local musicStatusLabel = mainFrame:WaitForChild("MusicStatusLabel")
local sfxToggleButton = mainFrame:WaitForChild("SFXToggleButton")
local sfxStatusLabel = mainFrame:WaitForChild("SFXStatusLabel")
local screenShakeToggleButton = mainFrame:WaitForChild("ScreenShakeToggleButton")
local screenShakeStatusLabel = mainFrame:WaitForChild("ScreenShakeStatusLabel")

local analyticsRemote = ReplicatedStorage:FindFirstChild("AnalyticsFunnelStep")

local function logFunnel(data)
	if analyticsRemote then
		analyticsRemote:FireServer(data)
	end
end

local function setCastShadowsForWorkspace(enabled)
	for _, obj in ipairs(Workspace:GetDescendants()) do
		if obj:IsA("BasePart") then
			obj.CastShadow = enabled
		end
	end
end

local function setBoolAttribute(name, value)
	player:SetAttribute(name, value)
end

local function getBoolAttribute(name, default)
	local v = player:GetAttribute(name)
	if v == nil then
		player:SetAttribute(name, default)
		return default
	end
	return v
end

local function applyQuality(enabled)
	Lighting.GlobalShadows = enabled
	setCastShadowsForWorkspace(enabled)
	if enabled then
		player:SetAttribute("StageCullLookBehind", 1)
		player:SetAttribute("StageCullLookAhead", 2)
	else
		player:SetAttribute("StageCullLookBehind", 1)
		player:SetAttribute("StageCullLookAhead", 1)
	end
end

applyQuality(true)
setBoolAttribute("MusicEnabled", true)
setBoolAttribute("SFXEnabled", true)
setBoolAttribute("ScreenShakeEnabled", true)

local openPos = mainFrame.Position
local closedPos = UDim2.new(openPos.X.Scale, openPos.X.Offset, openPos.Y.Scale + 0.06, openPos.Y.Offset)
local uiScale = mainFrame:FindFirstChildOfClass("UIScale")
if not uiScale then
	uiScale = Instance.new("UIScale")
	uiScale.Scale = 1
	uiScale.Parent = mainFrame
end

mainFrame.Visible = false

local settingsIcon = Icon.new()
	--:setLabel("Settings")
	:setImage("rbxassetid://6031280882")
	:setOrder(999)
	:bindToggleItem(mainFrame)

local function updateUI()
	if Lighting.GlobalShadows then
		shadowsToggleButton.Text = "Disable High Quality"
		shadowsToggleButton.BackgroundColor3 = Color3.fromRGB(70, 190, 80)
		shadowsStatusLabel.Text = "High Quality: Enabled"
	else
		shadowsToggleButton.Text = "Enable High Quality"
		shadowsToggleButton.BackgroundColor3 = Color3.fromRGB(190, 80, 80)
		shadowsStatusLabel.Text = "Low Quality: Enabled"
	end

	local musicEnabled = getBoolAttribute("MusicEnabled", true)
	musicToggleButton.Text = musicEnabled and "Pause Music" or "Resume Music"
	musicToggleButton.BackgroundColor3 = musicEnabled and Color3.fromRGB(70, 190, 80) or Color3.fromRGB(190, 80, 80)
	musicStatusLabel.Text = musicEnabled and "Music: On" or "Music: Paused"

	local sfxEnabled = getBoolAttribute("SFXEnabled", true)
	sfxToggleButton.Text = sfxEnabled and "Disable SFX" or "Enable SFX"
	sfxToggleButton.BackgroundColor3 = sfxEnabled and Color3.fromRGB(70, 190, 80) or Color3.fromRGB(190, 80, 80)
	sfxStatusLabel.Text = sfxEnabled and "SFX: Enabled" or "SFX: Disabled"

	local shakeEnabled = getBoolAttribute("ScreenShakeEnabled", true)
	screenShakeToggleButton.Text = shakeEnabled and "Disable Screen Shake" or "Enable Screen Shake"
	screenShakeToggleButton.BackgroundColor3 = shakeEnabled and Color3.fromRGB(70, 190, 80) or Color3.fromRGB(190, 80, 80)
	screenShakeStatusLabel.Text = shakeEnabled and "Screen Shake: Enabled" or "Screen Shake: Disabled"
end

settingsIcon:bindEvent("selected", function()
	logFunnel({
		funnelName = "SettingsFlow",
		step = 1,
		stepName = "Clicked Settings",
		resetSession = true,
	})
	mainFrame.Visible = true
	mainFrame.Position = closedPos
	uiScale.Scale = 0.94
	TweenService:Create(mainFrame, TweenInfo.new(0.22, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), { Position = openPos }):Play()
	TweenService:Create(uiScale, TweenInfo.new(0.22, Enum.EasingStyle.Back, Enum.EasingDirection.Out), { Scale = 1 }):Play()
end)

settingsIcon:bindEvent("deselected", function()
	local tween1 = TweenService:Create(mainFrame, TweenInfo.new(0.18, Enum.EasingStyle.Quad, Enum.EasingDirection.In), { Position = closedPos })
	local tween2 = TweenService:Create(uiScale, TweenInfo.new(0.18, Enum.EasingStyle.Quad, Enum.EasingDirection.In), { Scale = 0.94 })
	tween1:Play()
	tween2:Play()
	tween1.Completed:Connect(function()
		mainFrame.Visible = false
		mainFrame.Position = openPos
		uiScale.Scale = 1
	end)
end)

closeButton.MouseButton1Click:Connect(function()
	settingsIcon:deselect()
end)

shadowsToggleButton.MouseButton1Click:Connect(function()
	applyQuality(not Lighting.GlobalShadows)
	updateUI()
end)

musicToggleButton.MouseButton1Click:Connect(function()
	setBoolAttribute("MusicEnabled", not getBoolAttribute("MusicEnabled", true))
	updateUI()
end)

sfxToggleButton.MouseButton1Click:Connect(function()
	setBoolAttribute("SFXEnabled", not getBoolAttribute("SFXEnabled", true))
	updateUI()
end)

screenShakeToggleButton.MouseButton1Click:Connect(function()
	setBoolAttribute("ScreenShakeEnabled", not getBoolAttribute("ScreenShakeEnabled", true))
	updateUI()
end)

updateUI()
