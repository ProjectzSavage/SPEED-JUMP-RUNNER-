local Players = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")

local REBIRTH_REQUIREMENTS = {
	[1] = {speed = 100, multiplier = 2},
	[2] = {speed = 1000, multiplier = 3},
	[3] = {speed = 5000, multiplier = 4},
	[4] = {speed = 25000, multiplier = 5}
}

local rebirthRemote = ReplicatedStorage:WaitForChild("RebirthRequest")

local function updateLeaderstats(player)
	local leaderstats = player:FindFirstChild("leaderstats")
	if not leaderstats then return end

	local rebirths = leaderstats:FindFirstChild("Rebirths")
	if not rebirths then
		rebirths = Instance.new("IntValue")
		rebirths.Name = "Rebirths"
		rebirths.Value = 0
		rebirths.Parent = leaderstats
	end

	local multiplier = leaderstats:FindFirstChild("Multiplier")
	if not multiplier then
		multiplier = Instance.new("IntValue")
		multiplier.Name = "Multiplier"
		multiplier.Value = 1
		multiplier.Parent = leaderstats
	end
end

local function canRebirth(player, rebirthLevel)
	local leaderstats = player:FindFirstChild("leaderstats")
	if not leaderstats then return false end

	local speed = leaderstats:FindFirstChild("Speed")
	local rebirths = leaderstats:FindFirstChild("Rebirths")

	if not speed or not rebirths then return false end

	local requirement = REBIRTH_REQUIREMENTS[rebirthLevel]
	if not requirement then return false end

	return speed.Value >= requirement.speed and rebirths.Value == (rebirthLevel - 1)
end

local function doRebirth(player, rebirthLevel)
	print("Attempting rebirth for", player.Name, "level", rebirthLevel)

	if not canRebirth(player, rebirthLevel) then 
		print("Cannot rebirth - requirements not met")
		return false 
	end

	local leaderstats = player:FindFirstChild("leaderstats")
	local speed = leaderstats:FindFirstChild("Speed")
	local jumps = leaderstats:FindFirstChild("Jumps")
	local rebirths = leaderstats:FindFirstChild("Rebirths")
	local multiplier = leaderstats:FindFirstChild("Multiplier")

	if player.Character and player.Character:FindFirstChild("Humanoid") then
		player.Character.Humanoid.WalkSpeed = 4
	end

	speed.Value = 4
	jumps.Value = 0
	rebirths.Value = rebirthLevel
	multiplier.Value = REBIRTH_REQUIREMENTS[rebirthLevel].multiplier

	print("Rebirth successful for", player.Name, "- New multiplier:", multiplier.Value)
	return true
end

rebirthRemote.OnServerEvent:Connect(function(player, rebirthLevel)
	print("Rebirth remote fired by", player.Name, "for level", rebirthLevel)
	doRebirth(player, rebirthLevel)
end)

Players.PlayerAdded:Connect(function(player)
	player.CharacterAdded:Connect(function()
		wait(1)
		updateLeaderstats(player)
	end)
end)
