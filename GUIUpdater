local Players = game:GetService("Players")
local TweenService = game:GetService("TweenService")
local RunService = game:GetService("RunService")

local player = Players.LocalPlayer
local playerGui = player:WaitForChild("PlayerGui")

local currentSpeedValue = 16
local currentJumpValue = 0

local function formatNumber(num)
	if num >= 1000000000 then
		return string.format("%.1fB", num / 1000000000)
	elseif num >= 1000000 then
		return string.format("%.1fM", num / 1000000)
	elseif num >= 1000 then
		return string.format("%.1fK", num / 1000)
	else
		return tostring(num)
	end
end

local function animateNumber(label, startValue, endValue, prefix)
	if not label then return end

	local info = TweenInfo.new(
		0.5,
		Enum.EasingStyle.Quad,
		Enum.EasingDirection.Out
	)

	local numberValue = Instance.new("NumberValue")
	numberValue.Value = startValue

	local tween = TweenService:Create(numberValue, info, {Value = endValue})

	local connection
	connection = RunService.Heartbeat:Connect(function()
		if label and label.Parent then
			label.Text = prefix .. formatNumber(math.floor(numberValue.Value))
		else
			connection:Disconnect()
		end
	end)

	tween.Completed:Connect(function()
		connection:Disconnect()
		if label and label.Parent then
			label.Text = prefix .. formatNumber(endValue)
		end
	end)

	tween:Play()
end

local function connectToGUI()
	local speedJumpGUI = playerGui:FindFirstChild("SpeedJumpGUI")
	if not speedJumpGUI then return end

	local mainFrame = speedJumpGUI:FindFirstChild("MainFrame")
	if not mainFrame then return end

	local speedLabel = mainFrame:FindFirstChild("SpeedLabel")
	local jumpLabel = mainFrame:FindFirstChild("JumpLabel")

	if not speedLabel or not jumpLabel then return end

	local function updateGUI()
		local leaderstats = player:FindFirstChild("leaderstats")
		if leaderstats then
			local speed = leaderstats:FindFirstChild("Speed")
			local jumps = leaderstats:FindFirstChild("Jumps")

			if speed and speed.Value ~= currentSpeedValue then
				animateNumber(speedLabel, currentSpeedValue, speed.Value, "Speed: ")
				currentSpeedValue = speed.Value
			end

			if jumps and jumps.Value ~= currentJumpValue then
				animateNumber(jumpLabel, currentJumpValue, jumps.Value, "Jumps: ")
				currentJumpValue = jumps.Value
			end
		end
	end

	local leaderstats = player:WaitForChild("leaderstats")
	local speed = leaderstats:WaitForChild("Speed")
	local jumps = leaderstats:WaitForChild("Jumps")

	speed.Changed:Connect(updateGUI)
	jumps.Changed:Connect(updateGUI)
	updateGUI()
end

player.CharacterAdded:Connect(function()
	wait(2)
	connectToGUI()
end)

if player.Character then
	connectToGUI()
end
