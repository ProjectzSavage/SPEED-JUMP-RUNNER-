local Players = game:GetService("Players")
local CollectionService = game:GetService("CollectionService")
local TweenService = game:GetService("TweenService")
local Debris = game:GetService("Debris")
local ReplicatedStorage = game:GetService("ReplicatedStorage")

local player = Players.LocalPlayer
local remote = ReplicatedStorage:WaitForChild("SurfaceInteractRequest")

local SPARK_TEXTURE = "rbxassetid://17086390547"
local DEFAULT_BUBBLE_SOUND_ID = "rbxassetid://140323850218372"

local playerStats = player:WaitForChild("Stats")
local bubbleSoundIdValue = playerStats:WaitForChild("BubbleSoundId")

local bubbleState = {}
local localCooldown = {}

local function getBubbleSoundId()
	return (bubbleSoundIdValue.Value ~= "" and bubbleSoundIdValue.Value) or DEFAULT_BUBBLE_SOUND_ID
end

local function isMyCharacterHit(hit)
	return player.Character and hit and hit:IsDescendantOf(player.Character)
end

local function canFire(part, cooldown)
	local now = tick()
	local last = localCooldown[part] or 0
	if now - last < cooldown then return false end
	localCooldown[part] = now
	return true
end

local function play3DSound(part, soundId, volume, minDist, maxDist)
	local sound = Instance.new("Sound")
	sound.SoundId = soundId
	sound.Volume = volume
	sound.RollOffMode = Enum.RollOffMode.InverseTapered
	sound.RollOffMinDistance = minDist
	sound.RollOffMaxDistance = maxDist
	sound.PlaybackSpeed = math.random(95, 108) / 100
	sound.Parent = part
	sound:Play()
	Debris:AddItem(sound, 1.5)
end

local function bubbleFx(part)
	local st = bubbleState[part]
	if st and st.popped then return end

	if not st then
		st = {
			popped = false,
			originalSize = part.Size,
			originalTransparency = part.Transparency,
		}
		bubbleState[part] = st
	end

	st.popped = true

	local att = Instance.new("Attachment")
	att.Position = Vector3.new(0, part.Size.Y * 0.45, 0)
	att.Parent = part

	local emitter = Instance.new("ParticleEmitter")
	emitter.Texture = SPARK_TEXTURE
	emitter.Rate = 0
	emitter.Lifetime = NumberRange.new(0.15, 0.28)
	emitter.Speed = NumberRange.new(10, 18)
	emitter.SpreadAngle = Vector2.new(360, 360)
	emitter.Rotation = NumberRange.new(0, 360)
	emitter.RotSpeed = NumberRange.new(-250, 250)
	emitter.Drag = 4
	emitter.LightEmission = 1
	emitter.ZOffset = 0.2
	emitter.Size = NumberSequence.new({
		NumberSequenceKeypoint.new(0, 0.9),
		NumberSequenceKeypoint.new(1, 0),
	})
	emitter.Transparency = NumberSequence.new({
		NumberSequenceKeypoint.new(0, 0.05),
		NumberSequenceKeypoint.new(1, 1),
	})
	emitter.Color = ColorSequence.new(Color3.new(1, 1, 1))
	emitter.Parent = att
	emitter:Emit(34)

	Debris:AddItem(att, 0.7)
	play3DSound(part, getBubbleSoundId(), 1, 6, 70)

	local flatY = math.max(0.05, st.originalSize.Y * 0.16)
	TweenService:Create(
		part,
		TweenInfo.new(0.1, Enum.EasingStyle.Quad, Enum.EasingDirection.Out),
		{
			Size = Vector3.new(st.originalSize.X, flatY, st.originalSize.Z),
			Transparency = math.clamp(st.originalTransparency + 0.6, 0, 1),
		}
	):Play()

	task.delay(2.0, function()
		if not part or not part.Parent then return end
		local restore = TweenService:Create(
			part,
			TweenInfo.new(0.18, Enum.EasingStyle.Back, Enum.EasingDirection.Out),
			{
				Size = st.originalSize,
				Transparency = st.originalTransparency,
			}
		)
		restore:Play()
		restore.Completed:Connect(function()
			st.popped = false
		end)
	end)
end

local function setupBubble(part)
	if not part:IsA("BasePart") then return end
	if part:GetAttribute("BubbleFxConnected") then return end
	part:SetAttribute("BubbleFxConnected", true)

	part.Touched:Connect(function(hit)
		if not isMyCharacterHit(hit) then return end
		if not canFire(part, 0.12) then return end
		bubbleFx(part)
		remote:FireServer(part, "Bubble")
	end)
end

for _, p in ipairs(CollectionService:GetTagged("BubblePop")) do
	setupBubble(p)
end
CollectionService:GetInstanceAddedSignal("BubblePop"):Connect(setupBubble)
