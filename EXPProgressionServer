MarketplaceService.ProcessReceipt = function(receiptInfo)
	local player = Players:GetPlayerByUserId(receiptInfo.PlayerId)
	if not player then
		return Enum.ProductPurchaseDecision.NotProcessedYet
	end

	local potionConfig = POTION_PRODUCT_BY_ID[receiptInfo.ProductId]
	if potionConfig then
		local grantedPotion = grantPurchasablePotion(player, potionConfig)
		if grantedPotion then
			return Enum.ProductPurchaseDecision.PurchaseGranted
		end
		return Enum.ProductPurchaseDecision.NotProcessedYet
	end

	local speedShopKey = SPEED_SHOP_BY_PRODUCT_ID[receiptInfo.ProductId]
	if speedShopKey then
		local granted = grantSyncedSpeedProduct(player, speedShopKey)
		if granted then
			local info = SPEED_SHOP_PRODUCTS[speedShopKey]
			local percentText = tostring(math.floor((info.percent or 0) * 100 + 0.5))
			notifyPlayer(player, "THANK YOU!", "Thanks for supporting the game. +" .. percentText .. "% synced speed purchased!", "Info", 4.5, nil, {
				rainbowTitle = true,
				confetti = true,
				confettiCount = 120,
				soundId = "rbxassetid://1843520822",
				iconKey = "Purchase",
				scaleMultiplier = 1.8,
			})
			return Enum.ProductPurchaseDecision.PurchaseGranted
		end
		return Enum.ProductPurchaseDecision.NotProcessedYet
	end

	return Enum.ProductPurchaseDecision.PurchaseGranted
end

