local Players = game:GetService("Players")
local player = Players.LocalPlayer
local playerGui = player:WaitForChild("PlayerGui")

wait(3)

local guiList = {
	{name = "RebirthGUI", frame = "MainFrame"},
	{name = "TitleGUI", frame = "MainFrame"},
	{name = "SkinGUI", frame = "MainFrame"},
	{name = "SpeedShopGUI", frame = "ShopFrame"},
}

local function closeAllGUIs(except)
	for _, guiData in pairs(guiList) do
		if guiData.name ~= except then
			local gui = playerGui:FindFirstChild(guiData.name)
			if gui then
				local frame = gui:FindFirstChild(guiData.frame)
				if frame then
					frame.Visible = false
				end
			end
		end
	end
end

for _, guiData in pairs(guiList) do
	local gui = playerGui:FindFirstChild(guiData.name)
	if gui then
		local frame = gui:FindFirstChild(guiData.frame)
		if frame then
			frame:GetPropertyChangedSignal("Visible"):Connect(function()
				if frame.Visible then
					closeAllGUIs(guiData.name)
				end
			end)
			
		end
	end
end
