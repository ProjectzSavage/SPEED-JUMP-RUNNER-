task.spawn(function()
	while true do
		for _, pad in ipairs(CollectionService:GetTagged("TrampolinePad")) do
			if pad:IsA("BasePart") and pad.Parent then
				local expMult = pad:GetAttribute("ExpMultiplier") or 1
				local tickRate = pad:GetAttribute("TickRate") or TRAMPOLINE_TICK_RATE_DEFAULT
				local bouncePower = pad:GetAttribute("BouncePower") or TRAMPOLINE_BOUNCE_DEFAULT

				local parts = workspace:GetPartsInPart(pad, overlapParams)
				local seen = {}

				for _, p in ipairs(parts) do
					local model = p:FindFirstAncestorOfClass("Model")
					if model then
						local plr = Players:GetPlayerFromCharacter(model)
						if plr then seen[plr] = true end
