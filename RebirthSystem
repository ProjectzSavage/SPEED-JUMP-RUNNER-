local Players = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")

local REBIRTH_REQUIREMENTS = {
	[1] = { speed = 100, multiplier = 2 },
	[2] = { speed = 1000, multiplier = 3 },
	[3] = { speed = 5000, multiplier = 4 },
	[4] = { speed = 25000, multiplier = 5 },
	[5] = { speed = 50000, multiplier = 6 },
}

local rebirthRemote = ReplicatedStorage:WaitForChild("RebirthRequest")
local showNotificationRemote = ReplicatedStorage:FindFirstChild("ShowNotification")
if not showNotificationRemote then
	showNotificationRemote = Instance.new("RemoteEvent")
	showNotificationRemote.Name = "ShowNotification"
	showNotificationRemote.Parent = ReplicatedStorage
end

local function notifyPlayer(player, title, message, kind, duration, icon, extra)
	local payload = {
		title = title,
		message = message,
		kind = kind or "Info",
		duration = duration or 3.5,
		icon = icon,
	}
	if type(extra) == "table" then
		for key, value in pairs(extra) do
			payload[key] = value
		end
	end
	showNotificationRemote:FireClient(player, payload)
end

local function expRequiredForLevel(level)
	return math.floor(100 + (level ^ 1.45) * 35)
end

local function ensureStats(player)
	local leaderstats = player:FindFirstChild("leaderstats")
	if not leaderstats then return nil, nil end

	local stats = player:FindFirstChild("Stats")
	if not stats then
		stats = Instance.new("Folder")
		stats.Name = "Stats"
		stats.Parent = player
	end

	local rebirths = leaderstats:FindFirstChild("Rebirths") or Instance.new("IntValue")
	rebirths.Name = "Rebirths"
	rebirths.Parent = leaderstats

	local level = leaderstats:FindFirstChild("Level") or Instance.new("IntValue")
	level.Name = "Level"
	level.Parent = leaderstats
	if level.Value == 0 then level.Value = 1 end

	local speed = leaderstats:FindFirstChild("Speed") or Instance.new("IntValue")
	speed.Name = "Speed"
	speed.Parent = leaderstats

	local jumps = stats:FindFirstChild("Jumps") or Instance.new("IntValue")
	jumps.Name = "Jumps"
	jumps.Parent = stats

	local multiplier = stats:FindFirstChild("Multiplier") or Instance.new("IntValue")
	multiplier.Name = "Multiplier"
	multiplier.Parent = stats
	if multiplier.Value <= 0 then multiplier.Value = 1 end

	local exp = stats:FindFirstChild("EXP") or Instance.new("NumberValue")
	exp.Name = "EXP"
	exp.Parent = stats

	local expRequired = stats:FindFirstChild("EXPRequired") or Instance.new("NumberValue")
	expRequired.Name = "EXPRequired"
	expRequired.Parent = stats
	if expRequired.Value <= 0 then expRequired.Value = expRequiredForLevel(level.Value) end

	return leaderstats, stats
end

local function canRebirth(player, rebirthLevel)
	local leaderstats = player:FindFirstChild("leaderstats")
	if not leaderstats then return false end

	local speed = leaderstats:FindFirstChild("Speed")
	local rebirths = leaderstats:FindFirstChild("Rebirths")
	if not speed or not rebirths then return false end

	local req = REBIRTH_REQUIREMENTS[rebirthLevel]
	if not req then return false end

	return speed.Value >= req.speed and rebirths.Value == (rebirthLevel - 1)
end

local function doRebirth(player, rebirthLevel)
	if not canRebirth(player, rebirthLevel) then
		return false
	end

	local leaderstats, stats = ensureStats(player)
	if not leaderstats or not stats then return false end

	local level = leaderstats:FindFirstChild("Level")
	local rebirths = leaderstats:FindFirstChild("Rebirths")
	local jumps = stats:FindFirstChild("Jumps")
	local multiplier = stats:FindFirstChild("Multiplier")
	local exp = stats:FindFirstChild("EXP")
	local expRequired = stats:FindFirstChild("EXPRequired")
	if not level or not rebirths or not jumps or not multiplier or not exp or not expRequired then
		return false
	end

	level.Value = 1
	exp.Value = 0
	expRequired.Value = expRequiredForLevel(1)
	jumps.Value = 0

	rebirths.Value = rebirthLevel
	multiplier.Value = REBIRTH_REQUIREMENTS[rebirthLevel].multiplier

	notifyPlayer(player, "Rebirth Complete", "You rebirthed to level " .. tostring(rebirthLevel) .. "!", "Success", 3.5, nil, {
		iconKey = "Rebirth",
	})
	return true
end

rebirthRemote.OnServerEvent:Connect(function(player, rebirthLevel)
	doRebirth(player, rebirthLevel)
end)

Players.PlayerAdded:Connect(function(player)
	ensureStats(player)
	player.CharacterAdded:Connect(function()
		task.wait(0.2)
		ensureStats(player)
	end)
end)
