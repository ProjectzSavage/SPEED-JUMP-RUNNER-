MarketplaceService.ProcessReceipt = function(receiptInfo)
	local player = Players:GetPlayerByUserId(receiptInfo.PlayerId)
	if not player then
		return Enum.ProductPurchaseDecision.NotProcessedYet
	end

	local speedShopKey = SPEED_SHOP_BY_PRODUCT_ID[receiptInfo.ProductId]
	if speedShopKey then
		local granted = grantSyncedSpeedProduct(player, speedShopKey)
		if granted then
			local info = SPEED_SHOP_PRODUCTS[speedShopKey]
			local percentText = tostring(math.floor((info.percent or 0) * 100 + 0.5))
			notifyPlayer(player, "THANK YOU!", "Thanks for supporting the game. +" .. percentText .. "% synced speed purchased!", "Info", 4.5, nil, {
				rainbowTitle = true,
				confetti = true,
				confettiCount = 120,
				soundId = "rbxassetid://1843520822",
				iconKey = "Purchase",
			})
			return Enum.ProductPurchaseDecision.PurchaseGranted
		end
		return Enum.ProductPurchaseDecision.NotProcessedYet
	end

	return Enum.ProductPurchaseDecision.PurchaseGranted
end

jumpRemote.OnServerEvent:Connect(function(player)
	local now = tick()
	local last = playerJumpDebounce[player] or 0
	if now - last < JUMP_DEBOUNCE then return end
	playerJumpDebounce[player] = now

	local stats = player:FindFirstChild("Stats")
	if not stats then return end
	local jumps = stats:FindFirstChild("Jumps")
	if not jumps then return end

	jumps.Value += 1

	local rebirthMult, gamepassExpMult, titleMult, stepMult = getPlayerMultipliers(player)
	local speedFactor = getSpeedExpFactor(player)
	local gain = BASE_EXP_PER_JUMP * rebirthMult * gamepassExpMult * titleMult * stepMult * speedFactor

	addExp(player, gain)
	expPopupRemote:FireClient(player, math.floor(gain))
end)

surfaceInteractRemote.OnServerEvent:Connect(function(player, part, sourceType)
	if typeof(part) ~= "Instance" or not part:IsA("BasePart") then return end
	if not part:IsDescendantOf(workspace) then return end

	local char = player.Character
	if not char then return end
	local hum = char:FindFirstChildOfClass("Humanoid")
	local root = char:FindFirstChild("HumanoidRootPart")
	if not hum or hum.Health <= 0 or not root then return end
	if (root.Position - part.Position).Magnitude > INTERACT_DISTANCE then return end

	surfaceCooldown[player] = surfaceCooldown[player] or {}
	local last = surfaceCooldown[player][part] or 0
	local now = tick()
	if now - last < 0.12 then return end
	surfaceCooldown[player][part] = now

	local baseExp = 0
	if sourceType == "Bubble" and CollectionService:HasTag(part, "BubblePop") then
		baseExp = BUBBLE_BASE_EXP
	elseif sourceType == "Key" and CollectionService:HasTag(part, "KeyboardKey") then
		baseExp = KEY_BASE_EXP
	else
		return
	end

	if math.random() > SURFACE_EXP_CHANCE then return end

	local partMult = part:GetAttribute("ExpMultiplier") or 1
	local rebirthMult, gamepassExpMult, titleMult, stepMult = getPlayerMultipliers(player)
	local speedFactor = getSpeedExpFactor(player)
	local gain = baseExp * partMult * rebirthMult * gamepassExpMult * titleMult * stepMult * speedFactor

	addExp(player, gain)
	expPopupRemote:FireClient(player, math.floor(gain))
end)

task.spawn(function()
	while true do
		for _, pad in ipairs(CollectionService:GetTagged("TrampolinePad")) do
			if pad:IsA("BasePart") and pad.Parent then
				local expMult = pad:GetAttribute("ExpMultiplier") or 1
				local tickRate = pad:GetAttribute("TickRate") or TRAMPOLINE_TICK_RATE_DEFAULT
				local bouncePower = pad:GetAttribute("BouncePower") or TRAMPOLINE_BOUNCE_DEFAULT

				local parts = workspace:GetPartsInPart(pad, overlapParams)
				local seen = {}

				for _, p in ipairs(parts) do
					local model = p:FindFirstAncestorOfClass("Model")
					if model then
						local plr = Players:GetPlayerFromCharacter(model)
						if plr then seen[plr] = true end
					end
				end

				for plr in pairs(seen) do
					trampolineCooldown[plr] = trampolineCooldown[plr] or {}
					local last = trampolineCooldown[plr][pad] or 0
					local now = tick()
					if now - last >= tickRate then
						trampolineCooldown[plr][pad] = now

						local char = plr.Character
						local stats = plr:FindFirstChild("Stats")
						if char and stats then
							local hum = char:FindFirstChildOfClass("Humanoid")
							local root = char:FindFirstChild("HumanoidRootPart")
							local jumps = stats:FindFirstChild("Jumps")
							if hum and root and jumps and hum.Health > 0 then
								jumps.Value += 1
								hum:ChangeState(Enum.HumanoidStateType.Jumping)
								local v = root.AssemblyLinearVelocity
								root.AssemblyLinearVelocity = Vector3.new(v.X, math.max(v.Y, bouncePower), v.Z)

								local rebirthMult, gamepassExpMult, titleMult, stepMult = getPlayerMultipliers(plr)
								local speedFactor = getSpeedExpFactor(plr)
								local gain = BASE_EXP_PER_JUMP * rebirthMult * gamepassExpMult * titleMult * stepMult * speedFactor * expMult

								addExp(plr, gain)
								expPopupRemote:FireClient(plr, math.floor(gain))
							end
						end
					end
				end
			end
		end
		task.wait(0.1)
	end
end)

setSpeedRemote.OnServerEvent:Connect(function(player, requestedSpeed)
	if typeof(requestedSpeed) ~= "number" then return end
	local stats = player:FindFirstChild("Stats")
	if not stats then return end

	local selected = stats:FindFirstChild("SelectedRealSpeed")
	local useCustom = stats:FindFirstChild("UseCustomSpeed")
	if not selected or not useCustom then return end

	local maxReal = getMaxRealSpeed(player)
	selected.Value = math.clamp(requestedSpeed, BASE_REAL_SPEED, maxReal)
	useCustom.Value = true
	applyWalkSpeed(player)
	notifyPlayer(player, "Custom Speed Set", "Custom speed set to " .. formatNumber(selected.Value) .. ".", "Info", 3.2, nil, {
		iconKey = "CustomSpeed",
	})
end)

local function getSpawnPart()
	local directSpawnLocation = workspace:FindFirstChild("SpawnLocation")
	if directSpawnLocation and directSpawnLocation:IsA("BasePart") then
		return directSpawnLocation
	end

	local directSpawnPart = workspace:FindFirstChild("SpawnPoint")
	if directSpawnPart and directSpawnPart:IsA("BasePart") then
		return directSpawnPart
	end

	local alternateSpawnPart = workspace:FindFirstChild("Spawn") or workspace:FindFirstChild("SpawnPart") or workspace:FindFirstChild("LobbySpawn")
	if alternateSpawnPart and alternateSpawnPart:IsA("BasePart") then
		return alternateSpawnPart
	end

	local spawnModel = workspace:FindFirstChild("SpawnPoint") or workspace:FindFirstChild("Spawn") or workspace:FindFirstChild("LobbySpawn")
	if spawnModel and spawnModel:IsA("Model") then
		local p = spawnModel:FindFirstChild("SpawnLocation") or spawnModel:FindFirstChildWhichIsA("BasePart")
		if p and p:IsA("BasePart") then
			return p
		end
	end

	for _, obj in ipairs(workspace:GetDescendants()) do
		if obj:IsA("SpawnLocation") then
			return obj
		end
	end

	return nil
end

local function teleportPlayerToSpawn(player)
	local char = player.Character
	if not char then return end
	local root = char:FindFirstChild("HumanoidRootPart")
	local spawnPart = getSpawnPart()
	if not root or not spawnPart then return end
	char:PivotTo(spawnPart.CFrame + Vector3.new(0, 4, 0))
	root.AssemblyLinearVelocity = Vector3.zero
	root.AssemblyAngularVelocity = Vector3.zero
end

local function setupStepMultiplierPad(part)
	if not part:IsA("BasePart") then return end
	if part:GetAttribute("StepPadConnected") then return end
	part:SetAttribute("StepPadConnected", true)

	part.Touched:Connect(function(hit)
		local character = hit:FindFirstAncestorOfClass("Model")
		if not character then return end
		local player = Players:GetPlayerFromCharacter(character)
		if not player then return end

		local leaderstats = player:FindFirstChild("leaderstats")
		local wins = leaderstats and leaderstats:FindFirstChild("Wins")
		if not wins then return end

		local requiredWins = tonumber(part:GetAttribute("WinsRequired")) or 0
		local stepMultiplier = tonumber(part:GetAttribute("StepMultiplier")) or 1
		local order = tonumber(part:GetAttribute("StepOrder")) or 1

		if wins.Value >= requiredWins then
			setEquippedStepMultiplier(player, stepMultiplier, order)
		end
	end)
end

local function setupWinPart(part)
	if not part:IsA("BasePart") then return end
	if part:GetAttribute("WinConnected") then return end
	part:SetAttribute("WinConnected", true)

	winTouchCounts[part] = {}

	part.Touched:Connect(function(hit)
		local char = hit:FindFirstAncestorOfClass("Model")
		if not char then return end
		local player = Players:GetPlayerFromCharacter(char)
		if not player then return end

		local hum = char:FindFirstChildOfClass("Humanoid")
		if not hum or hum.Health <= 0 then return end

		local counts = winTouchCounts[part]
		local current = counts[player] or 0
		counts[player] = current + 1
		if current > 0 then return end

		local winsAmount = math.max(1, math.floor(part:GetAttribute("WinsAmount") or 1))
		local cooldownSec = part:GetAttribute("WinsCooldown") or 0.5

		winCooldown[player] = winCooldown[player] or {}
		local last = winCooldown[player][part] or 0
		local now = tick()
		if now - last < cooldownSec then return end
		winCooldown[player][part] = now

		local leaderstats = player:FindFirstChild("leaderstats")
		local wins = leaderstats and leaderstats:FindFirstChild("Wins")
		if wins then
			wins.Value += winsAmount
			autoEquipHighestStepMultiplier(player)
			notifyPlayer(player, "+" .. tostring(winsAmount) .. " Wins", "You earned " .. tostring(winsAmount) .. " win" .. (winsAmount == 1 and "" or "s") .. "!", "Warning", 3.2, nil, {
				scaleMultiplier = 1.8,
				confetti = true,
				confettiCount = math.clamp(20 + winsAmount * 10, 30, 90),
				soundId = "rbxassetid://1843520822",
				iconKey = "Wins",
			})
		end

		local shouldTeleport = part:GetAttribute("TeleportToSpawn")
		if shouldTeleport == nil or shouldTeleport == true then
			task.defer(teleportPlayerToSpawn, player)
		end
	end)

	part.TouchEnded:Connect(function(hit)
		local char = hit:FindFirstAncestorOfClass("Model")
		if not char then return end
		local player = Players:GetPlayerFromCharacter(char)
		if not player then return end

		local counts = winTouchCounts[part]
		if not counts then return end

		local current = counts[player] or 0
		current -= 1
		if current <= 0 then
			counts[player] = nil
		else
			counts[player] = current
		end
	end)
end

for _, part in ipairs(CollectionService:GetTagged("WinPart")) do
	setupWinPart(part)
end
CollectionService:GetInstanceAddedSignal("WinPart"):Connect(setupWinPart)

for _, part in ipairs(CollectionService:GetTagged("StepMultiplierPad")) do
	setupStepMultiplierPad(part)
end
CollectionService:GetInstanceAddedSignal("StepMultiplierPad"):Connect(setupStepMultiplierPad)

local function onPlayerAdded(player)
	createPlayerStats(player)
	refreshOwnedExpBoost(player)
	migrateLegacyShopBonus(player)

	local leaderstats = player:WaitForChild("leaderstats")
	local stats = player:WaitForChild("Stats")

	autoEquipHighestStepMultiplier(player, true)

	leaderstats:WaitForChild("Level").Changed:Connect(function() applyWalkSpeed(player) end)
	leaderstats:WaitForChild("Wins").Changed:Connect(function()
		autoEquipHighestStepMultiplier(player)
	end)
	stats:WaitForChild("EXP").Changed:Connect(function() applyWalkSpeed(player) end)
	stats:WaitForChild("EXPRequired").Changed:Connect(function() applyWalkSpeed(player) end)
	stats:WaitForChild("SpeedBoost").Changed:Connect(function() applyWalkSpeed(player) end)
	stats:WaitForChild("SelectedRealSpeed").Changed:Connect(function() applyWalkSpeed(player) end)
	stats:WaitForChild("TitleMultiplier").Changed:Connect(function() applyWalkSpeed(player) end)
	stats:WaitForChild("StepMultiplier").Changed:Connect(function() applyWalkSpeed(player) end)

	player.CharacterAdded:Connect(function()
		task.wait(0.2)
		applyWalkSpeed(player)
	end)

	applyWalkSpeed(player)
end

Players.PlayerAdded:Connect(onPlayerAdded)
Players.PlayerRemoving:Connect(function(player)
	playerJumpDebounce[player] = nil
	surfaceCooldown[player] = nil
	trampolineCooldown[player] = nil
	winCooldown[player] = nil
end)

for _, player in ipairs(Players:GetPlayers()) do
