local equipSkinRemote = ReplicatedStorage:FindFirstChild("EquipSkin")
if not equipSkinRemote then
	equipSkinRemote = Instance.new("RemoteEvent")
	equipSkinRemote.Name = "EquipSkin"
	equipSkinRemote.Parent = ReplicatedStorage
	print("Created EquipSkin remote")
else
	print("Found existing EquipSkin remote")
end

print("EquipSkin remote setup complete")

local equippedSkins = {}

local function applySkin(player, skinName)
	print("=== APPLYING SKIN START ===")
	print("Skin name:", skinName)
	print("Player:", player.Name)

	local skin = SKINS[skinName]
	if not skin then
		print("ERROR: Skin not found in SKINS table!")
		print("Available skins:", "Flash", "Sonic", "Lightning")
		return
	end

	print("Skin data found:", skin.name)
	print("Speed boost:", skin.speedBoost)

	if not player.Character then 
		print("ERROR: No character found!")
		return 
	end

	print("Character found")

	local humanoid = player.Character:FindFirstChildOfClass("Humanoid")
	if not humanoid then
		print("ERROR: No humanoid found!")
		return
	end

	print("Humanoid found")
	print("Getting HumanoidDescription...")

	local success, description = pcall(function()
		return humanoid:GetAppliedDescription()
	end)

	if not success then
		print("ERROR getting description:", description)
		return
	end

	print("Description obtained successfully")

	if skin.clothing.Shirt > 0 then
		description.Shirt = skin.clothing.Shirt
		print("Set shirt to:", skin.clothing.Shirt)
	end

	if skin.clothing.Pants > 0 then
		description.Pants = skin.clothing.Pants
		print("Set pants to:", skin.clothing.Pants)
	end

	print("Applying description to humanoid...")
	local applySuccess, applyError = pcall(function()
		humanoid:ApplyDescription(description)
	end)

	if not applySuccess then
		print("ERROR applying description:", applyError)
	else
		print("Description applied successfully!")
	end

	wait(0.5)

	print("Loading accessories...")
	if #skin.accessoryNames > 0 then
		for i, accessoryName in pairs(skin.accessoryNames) do
			print("Looking for accessory:", accessoryName)
			local accessory = game.ServerStorage:FindFirstChild(accessoryName)
			if not accessory then
				accessory = game.ReplicatedStorage:FindFirstChild(accessoryName)
			end

			if accessory and accessory:IsA("Accessory") then
				local clone = accessory:Clone()
				clone.Parent = player.Character
				print("Successfully added accessory:", accessoryName)
			else
				print("Accessory not found in ServerStorage or ReplicatedStorage:", accessoryName)
			end
		end
	else
		print("No accessories to load")
	end

	print("Updating leaderstats...")
	local leaderstats = player:FindFirstChild("leaderstats")
	if leaderstats then
		print("Leaderstats found")

		local skinStat = leaderstats:FindFirstChild("CurrentSkin")
		if not skinStat then
			skinStat = Instance.new("StringValue")
			skinStat.Name = "CurrentSkin"
			skinStat.Parent = leaderstats
			print("Created CurrentSkin stat")
		end
		skinStat.Value = skin.name
		print("CurrentSkin set to:", skin.name)

		local speedBoostStat = leaderstats:FindFirstChild("SpeedBoost")
		if not speedBoostStat then
			speedBoostStat = Instance.new("NumberValue")
			speedBoostStat.Name = "SpeedBoost"
			speedBoostStat.Parent = leaderstats
			print("Created SpeedBoost stat")
		end
		speedBoostStat.Value = skin.speedBoost
		print("SpeedBoost set to:", skin.speedBoost)
		print("Leaderstats SpeedBoost value:", speedBoostStat.Value)
	else
		print("ERROR: Leaderstats not found!")
	end

	print("=== SKIN APPLICATION COMPLETE ===")
end

local originalAvatars = {}

local function saveOriginalAvatar(player)
	if not player.Character then return end

	local humanoid = player.Character:FindFirstChildOfClass("Humanoid")
	if not humanoid then return end

	originalAvatars[player] = humanoid:GetAppliedDescription()
	print("Saved original avatar for", player.Name)
end

local function removeSkin(player)
	print("Removing skin for", player.Name)
	if not player.Character then 
		print("No character found")
		return 
	end

	local humanoid = player.Character:FindFirstChildOfClass("Humanoid")
	if not humanoid then
		print("No humanoid found")
		return
	end

	if originalAvatars[player] then
		print("Restoring original avatar...")
		humanoid:ApplyDescription(originalAvatars[player])
	else
		print("No saved avatar found, using default...")
		local userId = player.UserId
		local description = game:GetService("Players"):GetHumanoidDescriptionFromUserIdAsync(userId)
		humanoid:ApplyDescription(description)
	end

	local leaderstats = player:FindFirstChild("leaderstats")
	if leaderstats then
		local skinStat = leaderstats:FindFirstChild("CurrentSkin")
		if skinStat then skinStat.Value = "None" end

		local speedBoostStat = leaderstats:FindFirstChild("SpeedBoost")
		if speedBoostStat then speedBoostStat.Value = 0 end

		print("Skin removed successfully")
	end
end

equipSkinRemote.OnServerEvent:Connect(function(player, skinName)
	print("=== SERVER: EQUIP SKIN REMOTE RECEIVED ===")
	print("Player:", player.Name)
	print("Skin name received:", skinName)
	print("Type of skinName:", type(skinName))

	if skinName and skinName ~= "" then
		print("Valid skin name, equipping...")
		equippedSkins[player] = skinName
		applySkin(player, skinName)
	else
		print("Removing skin (skinName was nil or empty)...")
		equippedSkins[player] = nil
		removeSkin(player)
	end
end)

Players.PlayerAdded:Connect(function(player)
	player.CharacterAdded:Connect(function()
		wait(2)
		saveOriginalAvatar(player)

		wait(1)
		print("Character loaded, checking for equipped skin...")
		local leaderstats = player:FindFirstChild("leaderstats")
		if leaderstats then
			local skinStat = leaderstats:FindFirstChild("CurrentSkin")
			if not skinStat then
				skinStat = Instance.new("StringValue")
				skinStat.Name = "CurrentSkin"
				skinStat.Value = "None"
				skinStat.Parent = leaderstats
			end

			local speedBoostStat = leaderstats:FindFirstChild("SpeedBoost")
			if not speedBoostStat then
				speedBoostStat = Instance.new("NumberValue")
				speedBoostStat.Name = "SpeedBoost"
				speedBoostStat.Value = 0
				speedBoostStat.Parent = leaderstats
			end
		end

		if equippedSkins[player] then
			print("Re-applying saved skin:", equippedSkins[player])
			wait(1)
			applySkin(player, equippedSkins[player])
		else
			print("No skin equipped for", player.Name)
		end
	end)
end)

Players.PlayerRemoving:Connect(function(player)
	equippedSkins[player] = nil
	originalAvatars[player] = nil
end)
