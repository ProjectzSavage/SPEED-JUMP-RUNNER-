								local root = char:FindFirstChild("HumanoidRootPart")
								local jumps = stats:FindFirstChild("Jumps")
								if hum and root and jumps and hum.Health > 0 then
									jumps.Value += 1

									-- Lift the character off the pad first so the ground
									-- sensor doesn't immediately cancel the upward velocity.
									root.CFrame = root.CFrame + Vector3.new(0, 0.6, 0)

									hum:ChangeState(Enum.HumanoidStateType.Freefall)
									local v = root.AssemblyLinearVelocity
									root.AssemblyLinearVelocity = Vector3.new(v.X, bouncePower, v.Z)

									local comboCount, comboExpMult = updateComboForJump(plr)
									local rebirthMult, gamepassExpMult, titleMult, stepMult, auraExpMult = getPlayerMultipliers(plr)
									local expPotionMult = getExpPotionMultiplier(plr)

									local gain = BASE_EXP_PER_JUMP
										* rebirthMult
										* gamepassExpMult
										* titleMult
										* stepMult
										* auraExpMult
										* comboExpMult
										* expPotionMult
										* expMult

									addExp(plr, gain)
									expPopupRemote:FireClient(plr, math.floor(gain))
								end
							end
						end
					end
				end
			end
