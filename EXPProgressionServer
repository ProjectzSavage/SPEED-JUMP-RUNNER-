				for _, p in ipairs(parts) do
					local model = p:FindFirstAncestorOfClass("Model")
					if model then
						local plr = Players:GetPlayerFromCharacter(model)
						if plr then
							seen[plr] = true
						end
					end
				end

				for plr in pairs(seen) do
					trampolineCooldown[plr] = trampolineCooldown[plr] or {}
					local last = trampolineCooldown[plr][pad] or 0
					local now = tick()

					if now - last >= tickRate then
						trampolineCooldown[plr][pad] = now

						refreshTrampolinePassOwnership(plr)

						local allowed, expMult, bouncePower, reason, gamePassId, displayName = getTrampolineAccess(plr, pad)
						if not allowed then
							notifyLockedTrampoline(plr, pad, reason, gamePassId, displayName)
