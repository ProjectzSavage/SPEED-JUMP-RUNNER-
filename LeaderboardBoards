local Players = game:GetService("Players")
local DataStoreService = game:GetService("DataStoreService")
local ReplicatedStorage = game:GetService("ReplicatedStorage")

local orderedStores = {
	Wins = DataStoreService:GetOrderedDataStore("LB_Wins"),
	Level = DataStoreService:GetOrderedDataStore("LB_Level"),
	Speed = DataStoreService:GetOrderedDataStore("LB_Speed"),
}

local remote = ReplicatedStorage:FindFirstChild("GetLeaderboardData")
if not remote then
	remote = Instance.new("RemoteFunction")
	remote.Name = "GetLeaderboardData"
	remote.Parent = ReplicatedStorage
end

local function saveStat(player, statName, value)
	local store = orderedStores[statName]
	if not store then return end
	local key = tostring(player.UserId)
	pcall(function()
		store:SetAsync(key, tonumber(value) or 0)
	end)
end

local function hookPlayer(player)
	local leaderstats = player:WaitForChild("leaderstats", 10)
	if not leaderstats then return end

	for statName in pairs(orderedStores) do
		local stat = leaderstats:FindFirstChild(statName)
		if stat then
			saveStat(player, statName, stat.Value)
			stat.Changed:Connect(function()
				saveStat(player, statName, stat.Value)
			end)
		end
	end
end

Players.PlayerAdded:Connect(hookPlayer)
for _, player in ipairs(Players:GetPlayers()) do
	task.spawn(hookPlayer, player)
end

remote.OnServerInvoke = function(player, statName, limit)
	statName = tostring(statName)
	limit = math.clamp(tonumber(limit) or 25, 1, 100)

	local store = orderedStores[statName]
	if not store then
		return {}
	end

	local success, pages = pcall(function()
		return store:GetSortedAsync(false, limit)
	end)
	if not success or not pages then
		return {}
	end

	local page = pages:GetCurrentPage()
	local results = {}

	for rank, entry in ipairs(page) do
		local userId = tonumber(entry.key)
		local value = entry.value
		local username = "Unknown"

		if userId then
			local ok, name = pcall(function()
				return Players:GetNameFromUserIdAsync(userId)
			end)
			if ok and name then
				username = name
			end
		end

		table.insert(results, {
			Rank = rank,
			UserId = userId,
			Name = username,
			Value = value,
		})
	end

	return results
end
