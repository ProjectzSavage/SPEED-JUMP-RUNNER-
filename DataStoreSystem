local Players = game:GetService("Players")
local DataStoreService = game:GetService("DataStoreService")

local PROFILE_STORE = DataStoreService:GetDataStore("SJR_Profile_V2")
local AUTOSAVE_INTERVAL = 120

local function expRequiredForLevel(level)
	return math.floor(100 + (level ^ 1.45) * 35)
end

local function ensureValue(parent, className, name, defaultValue)
	local obj = parent:FindFirstChild(name)
	if not obj then
		obj = Instance.new(className)
		obj.Name = name
		obj.Value = defaultValue
		obj.Parent = parent
	end
	return obj
end

local function ensureFolders(player)
	local leaderstats = player:FindFirstChild("leaderstats")
	if not leaderstats then
		leaderstats = Instance.new("Folder")
		leaderstats.Name = "leaderstats"
		leaderstats.Parent = player
	end

	local stats = player:FindFirstChild("Stats")
	if not stats then
		stats = Instance.new("Folder")
		stats.Name = "Stats"
		stats.Parent = player
	end

	local ownedAuras = stats:FindFirstChild("OwnedAuras")
	if not ownedAuras then
		ownedAuras = Instance.new("Folder")
		ownedAuras.Name = "OwnedAuras"
		ownedAuras.Parent = stats
	end

	local ownedSkins = stats:FindFirstChild("OwnedSkins")
	if not ownedSkins then
		ownedSkins = Instance.new("Folder")
		ownedSkins.Name = "OwnedSkins"
		ownedSkins.Parent = stats
	end

	return leaderstats, stats, ownedAuras, ownedSkins
end

local function serializeBoolFolder(folder)
	local data = {}
	if not folder then return data end
	for _, child in ipairs(folder:GetChildren()) do
		if child:IsA("BoolValue") then
			data[child.Name] = child.Value
		end
	end
	return data
end

local function applyBoolFolder(folder, map)
	if typeof(map) ~= "table" then return end
	for name, value in pairs(map) do
		local obj = folder:FindFirstChild(name)
		if not obj then
			obj = Instance.new("BoolValue")
			obj.Name = name
			obj.Parent = folder
		end
		obj.Value = value == true
	end
end

