local Players = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local UserInputService = game:GetService("UserInputService")
local TweenService = game:GetService("TweenService")

local player = Players.LocalPlayer
local playerGui = player:WaitForChild("PlayerGui")

local REBIRTH_DATA = {
	[1] = { level = 10, multiplier = 2 },
	[2] = { level = 20, multiplier = 3 },
	[3] = { level = 30, multiplier = 4 },
	[4] = { level = 40, multiplier = 5 },
	[5] = { level = 50, multiplier = 6 },
	[6] = { level = 60, multiplier = 7 },
	[7] = { level = 70, multiplier = 8 },
	[8] = { level = 80, multiplier = 9 },
	[9] = { level = 90, multiplier = 10 },
	[10] = { level = 100, multiplier = 11 },
}

local rebirthGUI = playerGui:WaitForChild("RebirthGUI")
local MainMenuButtonsGUI = playerGui:WaitForChild("MainMenuButtons")
local toggleButton = MainMenuButtonsGUI:WaitForChild("Frame"):WaitForChild("RebirthToggleButton")
local mainFrame = rebirthGUI:WaitForChild("MainFrame")
local currentRebirthFrame = mainFrame:WaitForChild("CurrentRebirthFrame")
local nextRebirthLabel = currentRebirthFrame:WaitForChild("NextRebirthLabel")
local requirementLabel = currentRebirthFrame:WaitForChild("RequirementLabel")
local progressBar = currentRebirthFrame:WaitForChild("ProgressBarFrame"):WaitForChild("ProgressBar")
local rebirthButton = mainFrame:WaitForChild("RebirthButton")
local rewardsFrame = mainFrame:WaitForChild("RewardsFrame")
local closeButton = mainFrame:WaitForChild("CloseButton")

local template = rewardsFrame:WaitForChild("RebirthInfoFrame")
template.Visible = false

local rebirthRemote = ReplicatedStorage:WaitForChild("RebirthRequest")

local animating = false
local openPos = mainFrame.Position
local closedPos = UDim2.new(openPos.X.Scale, openPos.X.Offset, openPos.Y.Scale - 0.18, openPos.Y.Offset)

local function formatNumber(num)
	if num >= 1e9 then
		return string.format("%.1fB", num / 1e9)
	elseif num >= 1e6 then
		return string.format("%.1fM", num / 1e6)
	elseif num >= 1e3 then
		return string.format("%.1fK", num / 1e3)
	end
	return tostring(math.floor(num))
end

local function getNextRebirth()
	local leaderstats = player:FindFirstChild("leaderstats")
	if not leaderstats then return 1 end

	local rebirths = leaderstats:FindFirstChild("Rebirths")
	if not rebirths then return 1 end

	local nextLevel = rebirths.Value + 1
	return REBIRTH_DATA[nextLevel] and nextLevel or nil
end

local function canRebirth()
	local nextRebirth = getNextRebirth()
	if not nextRebirth then return false end

	local leaderstats = player:FindFirstChild("leaderstats")
	if not leaderstats then return false end

	local level = leaderstats:FindFirstChild("Level")
	if not level then return false end

	return level.Value >= REBIRTH_DATA[nextRebirth].level
end

local function updateRebirthDisplay()
	local nextRebirth = getNextRebirth()
	local leaderstats = player:FindFirstChild("leaderstats")
	if not nextRebirth or not leaderstats then
		nextRebirthLabel.Text = "MAX REBIRTH REACHED!"
		requirementLabel.Text = "You reached max rebirth level"
		rebirthButton.Text = "MAXED OUT"
		rebirthButton.BackgroundColor3 = Color3.fromRGB(100, 100, 100)
		progressBar.Size = UDim2.new(1, 0, 1, 0)
		return
	end

	local level = leaderstats:FindFirstChild("Level")
	if not level then return end

	local req = REBIRTH_DATA[nextRebirth]
	local progress = math.min(level.Value / req.level, 1)

	nextRebirthLabel.Text = "Next Rebirth: " .. nextRebirth
	requirementLabel.Text = "Need: Level " .. tostring(req.level) .. " (" .. tostring(level.Value) .. "/" .. tostring(req.level) .. ")"
	progressBar.Size = UDim2.new(progress, 0, 1, 0)

	if canRebirth() then
		rebirthButton.BackgroundColor3 = Color3.fromRGB(0, 255, 0)
		rebirthButton.Text = "REBIRTH " .. nextRebirth
	else
		rebirthButton.BackgroundColor3 = Color3.fromRGB(255, 100, 100)
		rebirthButton.Text = "LOCKED"
	end
end

local function updateRewardsDisplay()
	template.Visible = false

	local listLayout = rewardsFrame:FindFirstChildOfClass("UIListLayout")
	if not listLayout then
		listLayout = Instance.new("UIListLayout")
		listLayout.Padding = UDim.new(0, 2)
		listLayout.SortOrder = Enum.SortOrder.LayoutOrder
		listLayout.Parent = rewardsFrame
	end

	for _, child in ipairs(rewardsFrame:GetChildren()) do
		if child:IsA("Frame") and child ~= template and child.Name:match("^RebirthInfoRow_") then
			child:Destroy()
		end
	end

	local leaderstats = player:FindFirstChild("leaderstats")
	if not leaderstats then return end
	local currentRebirths = leaderstats:FindFirstChild("Rebirths")
	if not currentRebirths then return end

	for rebirthIndex = 1, currentRebirths.Value do
		local data = REBIRTH_DATA[rebirthIndex]
		if not data then continue end

		local row = template:Clone()
		row.Name = "RebirthInfoRow_" .. rebirthIndex
		row.Visible = true
		row.AutomaticSize = Enum.AutomaticSize.None
		row.Size = UDim2.new(1, 0, 0, 34)
		row.LayoutOrder = rebirthIndex
		row.Parent = rewardsFrame

		local rebirthTitle = row:WaitForChild("RebirthTitle")
		local multiplierLabel = row:WaitForChild("MultiplierLabel")

		rebirthTitle.Text = "Rebirth " .. rebirthIndex
		multiplierLabel.Text = tostring(data.multiplier) .. "x"
	end

	if rewardsFrame:IsA("ScrollingFrame") then
		task.defer(function()
			rewardsFrame.CanvasSize = UDim2.new(0, 0, 0, listLayout.AbsoluteContentSize.Y + 8)
		end)
	end
end

local function openFrame()
	if animating or mainFrame.Visible then return end
	animating = true
	mainFrame.Visible = true
	mainFrame.Position = closedPos

	local t = TweenService:Create(mainFrame, TweenInfo.new(0.2, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
		Position = openPos
	})
	t:Play()
	t.Completed:Wait()
	animating = false
end

local function closeFrame()
	if animating or not mainFrame.Visible then return end
	animating = true

	local t = TweenService:Create(mainFrame, TweenInfo.new(0.18, Enum.EasingStyle.Quad, Enum.EasingDirection.In), {
		Position = closedPos
	})
	t:Play()
	t.Completed:Wait()
	mainFrame.Visible = false
	mainFrame.Position = openPos
	animating = false
end

rebirthButton.MouseButton1Click:Connect(function()
	local nextRebirth = getNextRebirth()
	if nextRebirth and canRebirth() then
		rebirthRemote:FireServer(nextRebirth)
		closeFrame()
	end
end)

toggleButton.MouseButton1Click:Connect(function()
	if mainFrame.Visible then
		closeFrame()
	else
		updateRebirthDisplay()
		updateRewardsDisplay()
		openFrame()
	end
end)

closeButton.MouseButton1Click:Connect(closeFrame)

UserInputService.InputBegan:Connect(function(input, processed)
	if processed then return end
	if input.KeyCode == Enum.KeyCode.B then
		if mainFrame.Visible then
			closeFrame()
		else
			updateRebirthDisplay()
			updateRewardsDisplay()
			openFrame()
		end
	end
end)

task.spawn(function()
	while task.wait(1) do
		if mainFrame.Visible then
			updateRebirthDisplay()
		end
	end
end)

task.spawn(function()
	local leaderstats = player:WaitForChild("leaderstats")
	leaderstats:WaitForChild("Level").Changed:Connect(function()
		if mainFrame.Visible then updateRebirthDisplay() end
	end)
	leaderstats:WaitForChild("Rebirths").Changed:Connect(function()
		if mainFrame.Visible then
			updateRebirthDisplay()
			updateRewardsDisplay()
		end
	end)
end)
