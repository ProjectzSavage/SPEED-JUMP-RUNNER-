local Players = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local TweenService = game:GetService("TweenService")
local RunService = game:GetService("RunService")
local SoundService = game:GetService("SoundService")

local player = Players.LocalPlayer
local playerGui = player:WaitForChild("PlayerGui")
local showNotificationRemote = ReplicatedStorage:WaitForChild("ShowNotification")

local iconConfigModule = ReplicatedStorage:FindFirstChild("NotificationIconIds")
local ICONS = {}
if iconConfigModule and iconConfigModule:IsA("ModuleScript") then
	local ok, result = pcall(require, iconConfigModule)
	if ok and type(result) == "table" then
		ICONS = result
	end
end

local notificationGui = playerGui:WaitForChild("NotificationGUI")
local holder = notificationGui:WaitForChild("Holder")
local template = holder:WaitForChild("NotificationTemplate")

template.Visible = false
holder.ClipsDescendants = false

local confettiLayer = notificationGui:FindFirstChild("ConfettiLayer")
if not confettiLayer then
	confettiLayer = Instance.new("Frame")
	confettiLayer.Name = "ConfettiLayer"
	confettiLayer.Size = UDim2.fromScale(1, 1)
	confettiLayer.BackgroundTransparency = 1
	confettiLayer.BorderSizePixel = 0
	confettiLayer.ClipsDescendants = true
	confettiLayer.ZIndex = 100
	confettiLayer.Parent = notificationGui
end

local COLORS = {
	Success = Color3.fromRGB(50, 255, 120),
	Info = Color3.fromRGB(80, 170, 255),
	Warning = Color3.fromRGB(255, 210, 70),
	Error = Color3.fromRGB(255, 90, 90),
}

local CONFETTI_COLORS = {
	Color3.fromRGB(255, 70, 92),
	Color3.fromRGB(251, 191, 36),
	Color3.fromRGB(34, 197, 94),
	Color3.fromRGB(56, 189, 248),
	Color3.fromRGB(168, 85, 247),
	Color3.fromRGB(244, 114, 182),
}

local layoutCounter = 0

local function resolveIcon(data)
	if data.icon and data.icon ~= "" then
		return data.icon
	end
	if data.iconKey and ICONS[data.iconKey] then
		return ICONS[data.iconKey]
	end
	if data.userIconUserId then
		local ok, content = pcall(function()
			return Players:GetUserThumbnailAsync(tonumber(data.userIconUserId), Enum.ThumbnailType.HeadShot, Enum.ThumbnailSize.Size100x100)
		end)
		if ok and content then
			return content
		end
	end
	return nil
end

local function getTemplateScale(clone)
	return clone:FindFirstChildOfClass("UIScale") or clone:FindFirstChildWhichIsA("UIScale", true)
end

local function playUiSound(soundId, volume)
	if not soundId or soundId == "" then return end
	local sound = Instance.new("Sound")
	sound.SoundId = soundId
	sound.Volume = volume or 1
	sound.Parent = SoundService
	sound:Play()
	sound.Ended:Connect(function()
		sound:Destroy()
	end)
	task.delay(4, function()
		if sound and sound.Parent then
			sound:Destroy()
		end
	end)
end

local function spawnConfettiPiece()
	local piece = Instance.new("Frame")
	piece.Size = UDim2.fromOffset(math.random(6, 10), math.random(10, 18))
	piece.Position = UDim2.new(math.random(), 0, -0.06, math.random(-80, 10))
	piece.BackgroundColor3 = CONFETTI_COLORS[math.random(1, #CONFETTI_COLORS)]
	piece.BorderSizePixel = 0
	piece.Rotation = math.random(-180, 180)
	piece.ZIndex = 100
	piece.Parent = confettiLayer

	local xDrift = math.random(-140, 140)
	local endPos = UDim2.new(piece.Position.X.Scale, xDrift, 1.12, math.random(0, 120))
	local tweenTime = math.random(120, 220) / 100

	TweenService:Create(piece, TweenInfo.new(tweenTime, Enum.EasingStyle.Quad, Enum.EasingDirection.In), {
		Position = endPos,
		Rotation = piece.Rotation + math.random(260, 620),
		BackgroundTransparency = 0.2,
	}):Play()

	task.delay(tweenTime + 0.1, function()
		if piece and piece.Parent then
			piece:Destroy()
		end
	end)
end

local function playConfetti(count)
	count = math.max(1, math.floor(tonumber(count) or 80))
	for i = 1, count do
		task.delay(i * 0.012, spawnConfettiPiece)
	end
end

local function startRainbowTitle(label)
	local alive = true
	task.spawn(function()
		while alive and label and label.Parent do
			local hue = (tick() * 0.35) % 1
			label.TextColor3 = Color3.fromHSV(hue, 1, 1)
			RunService.RenderStepped:Wait()
		end
	end)
	return function()
		alive = false
	end
end

local function showNotification(data)
	data = data or {}
	layoutCounter += 1

	local clone = template:Clone()
	clone.Name = "Notification_" .. tostring(layoutCounter)
	clone.Visible = true
	clone.LayoutOrder = layoutCounter
	clone.Parent = holder

	local scale = getTemplateScale(clone)
	local icon = clone:FindFirstChild("Icon", true)
	local titleLabel = clone:FindFirstChild("TitleLabel", true)
	local messageLabel = clone:FindFirstChild("MessageLabel", true)

	if titleLabel then
		titleLabel.RichText = data.richText == true
		titleLabel.Text = data.title or "Notification"
		if not data.rainbowTitle then
			titleLabel.TextColor3 = COLORS[data.kind] or COLORS.Info
		end
	end
	if messageLabel then
		messageLabel.RichText = data.richText == true
		messageLabel.Text = data.message or ""
		messageLabel.TextColor3 = messageLabel.TextColor3
	end

	local resolvedIcon = resolveIcon(data)
	if icon then
		if resolvedIcon then
			icon.Image = resolvedIcon
			icon.Visible = true
			icon.ImageTransparency = 0
		else
			icon.Visible = false
		end
	end

	local stopRainbow
	if data.rainbowTitle and titleLabel then
		stopRainbow = startRainbowTitle(titleLabel)
	end
	if data.confetti then
		playConfetti(data.confettiCount)
	end
	if data.soundId then
		playUiSound(data.soundId, data.soundVolume or 0.9)
	end

	if scale then
		local targetScale = math.max(1, tonumber(data.scaleMultiplier) or 1)
		scale.Scale = 0
		TweenService:Create(scale, TweenInfo.new(0.22, Enum.EasingStyle.Back, Enum.EasingDirection.Out), {
			Scale = targetScale,
		}):Play()
	end

	local duration = tonumber(data.duration) or 3.5
	task.delay(duration, function()
		if not clone or not clone.Parent then return end
		if stopRainbow then stopRainbow() end

		if scale then
			local closeTween = TweenService:Create(scale, TweenInfo.new(0.18, Enum.EasingStyle.Quad, Enum.EasingDirection.In), {
				Scale = 0,
			})
			closeTween:Play()
			closeTween.Completed:Wait()
		else
			task.wait(0.18)
		end

		if clone then
			clone:Destroy()
		end
	end)
end

showNotificationRemote.OnClientEvent:Connect(showNotification)
