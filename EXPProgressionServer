							if hum and root and jumps and hum.Health > 0 then
								jumps.Value += 1
								hum:ChangeState(Enum.HumanoidStateType.Jumping)
								local v = root.AssemblyLinearVelocity
								root.AssemblyLinearVelocity = Vector3.new(v.X, math.max(v.Y, bouncePower), v.Z)

								local rebirthMult, gamepassExpMult, titleMult, stepMult = getPlayerMultipliers(plr)
								local expPotionMult = getExpPotionMultiplier(plr)
								local gain = BASE_EXP_PER_JUMP * rebirthMult * gamepassExpMult * titleMult * stepMult * expPotionMult * expMult

								addExp(plr, gain)
								expPopupRemote:FireClient(plr, math.floor(gain))
