local function updateComboForJump(player)
	local now = tick()
	local state = comboState[player]
	if not state then
		state = { combo = 0, lastJump = 0, notified = {} }
		comboState[player] = state
	end

	if now - state.lastJump <= COMBO_RESET_TIME then
		state.combo += 1
	else
		state.combo = 1
		state.notified = {}
	end
	state.lastJump = now

	local comboMult, comboCount = ensureComboStats(player)
	local multiplier = getComboMultiplierFromCount(state.combo)
	if comboMult then comboMult.Value = multiplier end
	if comboCount then comboCount.Value = state.combo end

	for _, info in ipairs(COMBO_THRESHOLDS) do
		if state.combo >= info.combo and not state.notified[info.combo] then
			state.notified[info.combo] = true
			notifyPlayer(player, "Jump Combo", info.notify, "Info", 3.2, nil, {
				iconKey = "Combo",
			})
		end
	end

	return state.combo, multiplier
end

