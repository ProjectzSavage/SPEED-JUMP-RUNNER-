local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local TweenService = game:GetService("TweenService")

local player = Players.LocalPlayer
local camera = workspace.CurrentCamera

local baseFOV = 70
local maxFOV = 110
local isRunning = false
local currentFOVTween = nil
local currentShakeTween = nil

local function applySpeedEffects(speed)
	if speed >= 20 and isRunning then
		local fovMultiplier = math.min((speed - 20) / 100, 1)
		local targetFOV = baseFOV + (maxFOV - baseFOV) * fovMultiplier

		if currentFOVTween then currentFOVTween:Cancel() end
		currentFOVTween = TweenService:Create(camera,
			TweenInfo.new(0.3, Enum.EasingStyle.Quad),
			{FieldOfView = targetFOV}
		)
		currentFOVTween:Play()

		local shakeIntensity = math.min(speed / 200, 0.5)
		local function shakeCamera()
			local randomX = (math.random() - 0.5) * shakeIntensity
			local randomY = (math.random() - 0.5) * shakeIntensity
			camera.CFrame = camera.CFrame * CFrame.new(randomX, randomY, 0)
		end

		if not currentShakeTween then
			currentShakeTween = RunService.Heartbeat:Connect(shakeCamera)
		end
	else
		if currentFOVTween then currentFOVTween:Cancel() end
		currentFOVTween = TweenService:Create(camera,
			TweenInfo.new(0.5, Enum.EasingStyle.Quad),
			{FieldOfView = baseFOV}
		)
		currentFOVTween:Play()

		if currentShakeTween then
			currentShakeTween:Disconnect()
			currentShakeTween = nil
		end
	end
end

local function checkMovement()
	if player.Character and player.Character:FindFirstChild("Humanoid") then
		local humanoid = player.Character.Humanoid
		isRunning = humanoid.MoveDirection.Magnitude > 0

		local leaderstats = player:FindFirstChild("leaderstats")
		if leaderstats and leaderstats:FindFirstChild("Speed") then
			applySpeedEffects(leaderstats.Speed.Value)
		end
	end
end

RunService.Heartbeat:Connect(checkMovement)
