				-- More reliable than GetPartsInPart for unions / angled pads
				pad.CanQuery = true
				local parts = workspace:GetPartBoundsInBox(
					pad.CFrame,
					pad.Size + Vector3.new(0, 3, 0),
					overlapParams
				)

