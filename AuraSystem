local function notifyPlayer(player, title, message, kind, duration, extra)
	local payload = {
		title = title,
		message = message,
		kind = kind or "Info",
		duration = duration or 3.5,
	}
	if type(extra) == "table" then
		for k, v in pairs(extra) do
			payload[k] = v
		end
	end
	showNotificationRemote:FireClient(player, payload)
end

local function ensureValue(parent, className, name, defaultValue)
	local obj = parent:FindFirstChild(name)
	if not obj then
		obj = Instance.new(className)
		obj.Name = name
		obj.Value = defaultValue
		obj.Parent = parent
	end
	return obj
end

local function ensureAuraStats(player)
	local leaderstats = player:FindFirstChild("leaderstats")
	if not leaderstats then
		leaderstats = Instance.new("Folder")
		leaderstats.Name = "leaderstats"
		leaderstats.Parent = player
	end

	local stats = player:FindFirstChild("Stats")
	if not stats then
		stats = Instance.new("Folder")
		stats.Name = "Stats"
		stats.Parent = player
	end

	local currentAura = ensureValue(stats, "StringValue", "CurrentAura", "None")
	local auraMultiplier = ensureValue(stats, "NumberValue", "AuraMultiplier", 1)

	local ownedAuras = stats:FindFirstChild("OwnedAuras")
	if not ownedAuras then
		ownedAuras = Instance.new("Folder")
		ownedAuras.Name = "OwnedAuras"
		ownedAuras.Parent = stats
	end

	for auraKey in pairs(AURAS) do
		ensureValue(ownedAuras, "BoolValue", auraKey, false)
	end

	return leaderstats, stats, currentAura, auraMultiplier, ownedAuras
end

local function refreshOwnedAuraGamepasses(player)
	local _, _, _, _, ownedAuras = ensureAuraStats(player)

	for auraKey, aura in pairs(AURAS) do
		local owned = ownedAuras:FindFirstChild(auraKey)
		if owned and aura.gamePassId and aura.gamePassId > 0 then
			local ok, hasPass = pcall(function()
				return MarketplaceService:UserOwnsGamePassAsync(player.UserId, aura.gamePassId)
			end)
			if ok and hasPass then
				owned.Value = true
			end
		end
	end
end

local function clearAura(character)
	for _, obj in ipairs(character:GetDescendants()) do
		if obj:GetAttribute("EquippedAuraObject") == true then
			if obj:IsA("ParticleEmitter") or obj:IsA("Attachment") or obj:IsA("Trail") or obj:IsA("Beam") then
				obj:Destroy()
			end
		end
	end
end

local function cloneAuraChildrenOntoPart(templatePart, targetPart)
	for _, child in ipairs(templatePart:GetChildren()) do
		if not child:IsA("BasePart") then
			local clone = child:Clone()
			clone:SetAttribute("EquippedAuraObject", true)
			clone.Parent = targetPart
		end
	end
end

local function applyAuraToCharacter(player, auraKey)
	local auraData = AURAS[auraKey]
	local character = player.Character
	if not auraData or not character then return false end

	local template = auraFolder:FindFirstChild(auraData.templateName)
	if not template or not template:IsA("Model") then
		warn("[AuraSystem] Missing aura template model:", auraData.templateName)
		return false
	end

	clearAura(character)

	for _, auraPart in ipairs(template:GetDescendants()) do
		if auraPart:IsA("BasePart") then
			local targetPart = character:FindFirstChild(auraPart.Name, true)
			if targetPart and targetPart:IsA("BasePart") then
				cloneAuraChildrenOntoPart(auraPart, targetPart)
			end
		end
	end

	return true
end

local function ownsAura(player, auraKey)
	local aura = AURAS[auraKey]
	if not aura then return false end

	local leaderstats, stats, currentAura, auraMultiplier, ownedAuras = ensureAuraStats(player)
	local ownedValue = ownedAuras:FindFirstChild(auraKey)
	return ownedValue and ownedValue.Value == true
end

local function tryUnlockAuraWithWins(player, auraKey)
	local aura = AURAS[auraKey]
	if not aura then return false end
	if aura.winsCost == math.huge then
		return false
	end

	local leaderstats = player:FindFirstChild("leaderstats")
	local wins = leaderstats and leaderstats:FindFirstChild("Wins")
	if not wins then return false end

	local _, _, _, _, ownedAuras = ensureAuraStats(player)
	local ownedValue = ownedAuras:FindFirstChild(auraKey)
	if ownedValue and ownedValue.Value == true then
		return true
	end

	if wins.Value < aura.winsCost then
		notifyPlayer(player, "Not Enough Wins", "You need " .. tostring(aura.winsCost) .. " Wins.", "Warning", 3.2, {
			iconKey = "Aura",
		})
		return false
	end

	wins.Value -= aura.winsCost
	if ownedValue then
		ownedValue.Value = true
	end

	notifyPlayer(player, "Aura Unlocked", aura.name .. " unlocked for " .. tostring(aura.winsCost) .. " Wins!", "Success", 3.5, {
		iconKey = "Aura",
	})
	return true
end

local function equipAura(player, auraKey)
	local _, _, currentAura, auraMultiplier, ownedAuras = ensureAuraStats(player)

	if auraKey == "None" or auraKey == "" then
		currentAura.Value = "None"
		auraMultiplier.Value = 1
		if player.Character then
			clearAura(player.Character)
		end
		notifyPlayer(player, "Aura Removed", "Aura unequipped.", "Info", 3, {
			iconKey = "Aura",
		})
		return true
	end

	local aura = AURAS[auraKey]
	if not aura then return false end

	local ownedValue = ownedAuras:FindFirstChild(auraKey)
	local alreadyOwned = ownedValue and ownedValue.Value == true

	if not alreadyOwned then
		local unlockedByWins = tryUnlockAuraWithWins(player, auraKey)
		if not unlockedByWins then
			return false
		end
	end

	currentAura.Value = auraKey
	auraMultiplier.Value = aura.boost
	applyAuraToCharacter(player, auraKey)

	notifyPlayer(player, "Aura Equipped", aura.name .. " equipped.", "Success", 3.2, {
		iconKey = "Aura",
	})
	return true
end

local function grantAuraPurchase(player, auraKey)
	local aura = AURAS[auraKey]
	if not aura then return false end

	local _, _, _, _, ownedAuras = ensureAuraStats(player)
	local owned = ownedAuras:FindFirstChild(auraKey)
	if owned then
		owned.Value = true
	end

	notifyPlayer(player, "THANK YOU!", aura.name .. " unlocked!", "Info", 4.5, {
		rainbowTitle = true,
		confetti = true,
		confettiCount = 120,
		soundId = "rbxassetid://1843520822",
		iconKey = "Purchase",
		scaleMultiplier = 1.8,
	})
	return true
end

promptAuraPurchaseRemote.OnServerEvent:Connect(function(player, auraKey)
	if typeof(auraKey) ~= "string" then return end
	local aura = AURAS[auraKey]
	if not aura or not aura.gamePassId or aura.gamePassId <= 0 then
		warn("[AuraSystem] Missing gamePassId for aura", auraKey)
		return
	end

	-- If already owned, silently refresh
	local ok, hasPass = pcall(function()
		return MarketplaceService:UserOwnsGamePassAsync(player.UserId, aura.gamePassId)
	end)
	if ok and hasPass then
		refreshOwnedAuraGamepasses(player)
		return
	end

	MarketplaceService:PromptGamePassPurchase(player, aura.gamePassId)
end)

equipAuraRemote.OnServerEvent:Connect(function(player, auraKey)
	if typeof(auraKey) ~= "string" then return end

	if auraKey == "None" or auraKey == "" then
		equipAura(player, "None")
		return
	end

	equipAura(player, auraKey)
end)

MarketplaceService.PromptGamePassPurchaseFinished:Connect(function(player, gamePassId, wasPurchased)
	if not player then return end

	local aura = AURA_BY_GAMEPASS_ID[gamePassId]
	if aura then
		refreshOwnedAuraGamepasses(player)
		if wasPurchased then
			grantAuraPurchase(player, aura.key)
		end
	end
end)

Players.PlayerAdded:Connect(function(player)
	ensureAuraStats(player)
	refreshOwnedAuraGamepasses(player)

	player.CharacterAdded:Connect(function()
		task.wait(0.35)
		local _, _, currentAura = ensureAuraStats(player)
		if currentAura.Value ~= "None" and currentAura.Value ~= "" and ownsAura(player, currentAura.Value) then
			applyAuraToCharacter(player, currentAura.Value)
		end
	end)
end)

for _, player in ipairs(Players:GetPlayers()) do
	task.spawn(function()
		ensureAuraStats(player)
		refreshOwnedAuraGamepasses(player)
		if player.Character then
			local _, _, currentAura = ensureAuraStats(player)
			if currentAura.Value ~= "None" and currentAura.Value ~= "" and ownsAura(player, currentAura.Value) then
				applyAuraToCharacter(player, currentAura.Value)
			end
		end
	end)
end
