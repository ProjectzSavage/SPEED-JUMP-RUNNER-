local function showExactGainLabel(totalGain)
	gainAnimId += 1
	local myId = gainAnimId

	if gainInTween then gainInTween:Cancel() end
	if gainOutTween then gainOutTween:Cancel() end

	gainTotalLabel.Text = "+" .. formatNumber(totalGain) .. " EXP"
	gainTotalLabel.TextTransparency = 1
	gainTotalLabel.TextStrokeTransparency = 1
	gainTotalLabel.Position = UDim2.new(0.9, 0, 0.683, 0) -- keep your exact position
	gainTotalLabel.Size = UDim2.new(0.097, 0, 0.373, 0)     -- keep your exact size

	gainInTween = TweenService:Create(
		gainTotalLabel,
		TweenInfo.new(0.12, Enum.EasingStyle.Quad, Enum.EasingDirection.Out),
		{
			TextTransparency = 0,
			TextStrokeTransparency = 0
		}
	)
	gainInTween:Play()

	task.delay(0.20, function()
		if myId ~= gainAnimId then return end

		gainOutTween = TweenService:Create(
			gainTotalLabel,
			TweenInfo.new(0.28, Enum.EasingStyle.Quad, Enum.EasingDirection.In),
			{
				TextTransparency = 1,
				TextStrokeTransparency = 1
			}
		)
		gainOutTween:Play()
	end)
end
local function animateSpeedLabel(targetSpeed)
	targetSpeed = math.max(0, math.floor(targetSpeed or 0))

	if speedTween then
		speedTween:Cancel()
	end

	local startValue = currentShownSpeed
	speedNumberValue.Value = startValue

	speedTween = TweenService:Create(
		speedNumberValue,
		TweenInfo.new(0.25, Enum.EasingStyle.Quad, Enum.EasingDirection.Out),
		{ Value = targetSpeed }
	)

	local conn
	conn = speedNumberValue.Changed:Connect(function(v)
		if speedValueLabel then
			speedValueLabel.Text = formatNumber(v) .. " Speed"
		end
	end)

	speedTween:Play()
	speedTween.Completed:Connect(function()
		if conn then conn:Disconnect() end
		currentShownSpeed = targetSpeed
		if speedValueLabel then
			speedValueLabel.Text = formatNumber(targetSpeed) .. " Speed"
		end
	end)
end

local function getNextBoost(current)
	if current < 1 then current = 1 end
	if current >= 128 then return nil end
	if current == 1 then return 2 end
	return math.min(current * 2, 128)
end

local function tweenFill(percent)
	percent = math.clamp(percent, 0, 1)
	TweenService:Create(
		fill,
		TweenInfo.new(0.2, Enum.EasingStyle.Quad, Enum.EasingDirection.Out),
		{ Size = UDim2.new(percent, 0, 1, 0) }
	):Play()
end

local function updateGui()
	local leaderstats = player:FindFirstChild("leaderstats")
	local statsFolder = player:FindFirstChild("Stats")
	local expBoostValue = player:FindFirstChild("ExpBoost")
	if not leaderstats or not statsFolder or not expBoostValue then return end

	local gamepassMultLabel = main:FindFirstChild("GamepassMultLabel")
	local rebirthMultLabel = main:FindFirstChild("RebirthMultLabel")
	local skinBoostLabel = main:FindFirstChild("SkinBoostLabel")
	
	local level = leaderstats:FindFirstChild("Level")
	local speed = leaderstats:FindFirstChild("Speed")
	local rebirths = leaderstats:FindFirstChild("Rebirths")
	local exp = statsFolder:FindFirstChild("EXP")
	local expRequired = statsFolder:FindFirstChild("EXPRequired")
	local rebirthMultiplier = statsFolder:FindFirstChild("Multiplier")
	local gamepassBoost = expBoostValue.Value
	local rebirthBoost = rebirthMultiplier.Value
	local speedBoostStat = leaderstats:FindFirstChild("SpeedBoost")
	local skinBoostPercent = math.floor(((speedBoostStat and speedBoostStat.Value) or 0) * 100 + 0.5)
	local totalBoost = gamepassBoost * rebirthBoost
	boostTopLabel.Text = tostring(totalBoost) .. "x TOTAL EXP BOOST"

	if gamepassMultLabel then
		gamepassMultLabel.Text = "Multiplier x" .. tostring(gamepassBoost) .. " (Gamepass)"
	end
	if rebirthMultLabel then
		rebirthMultLabel.Text = "Multiplier x" .. tostring(rebirthBoost) .. " (Rebirth)"
	end
	if skinBoostLabel then
		skinBoostLabel.Text = "+" .. tostring(skinBoostPercent) .. "% Speed (Skin)"
	end
	if not level or not speed or not rebirths or not exp or not expRequired or not rebirthMultiplier then return end

	levelLabel.Text = "Level: " .. tostring(level.Value)
	expLabel.Text = "EXP: " .. formatNumber(exp.Value) .. " / " .. formatNumber(expRequired.Value)

	local percent = (expRequired.Value > 0) and (exp.Value / expRequired.Value) or 0
	tweenFill(percent)

	local gamepassBoost = expBoostValue.Value
	local rebirthBoost = rebirthMultiplier.Value
	local totalBoost = gamepassBoost * rebirthBoost

	boostTopLabel.Text = tostring(totalBoost) .. "x TOTAL EXP BOOST"

	local nextBoost = getNextBoost(gamepassBoost)
	if nextBoost then
		buyBoostButton.Active = true
		buyBoostButton.AutoButtonColor = true
		boostText.Text = tostring(nextBoost) .. "x EXP"
		priceText.Text = "ONLY " .. tostring(nextBoost)
	else
		buyBoostButton.Active = false
		buyBoostButton.AutoButtonColor = false
		boostText.Text = "MAX BOOST"
		priceText.Text = "128x"
	end

	if speedValueLabel then
		animateSpeedLabel(speed.Value)
	end
	if leftInfoLabel then
		leftInfoLabel.Text = "Multiplier x" .. tostring(gamepassBoost) .. " (Gamepass)"
	end
	if rightInfoLabel then
		rightInfoLabel.Text = "Multiplier x" .. tostring(rebirthBoost) .. " (Rebirth)"
	end
end

local function randRange(a, b)
	return a + (b - a) * math.random()
end

local function showWorldPopup(gainAmount)
	local char = player.Character
	if not char then return end
	local root = char:FindFirstChild("HumanoidRootPart")
	if not root then return end

	local popup = worldPopupTemplate:Clone()
	popup.Enabled = true
	popup.Adornee = root
	popup.Parent = playerGui

	local mainFrame = popup:WaitForChild("Main")
	local amountLabel = mainFrame:WaitForChild("Amount")

	amountLabel.Text = "+" .. formatNumber(gainAmount)
	amountLabel.TextTransparency = 0
	amountLabel.TextStrokeTransparency = 0
	mainFrame.Position = UDim2.fromScale(0.5, 0.5)
	mainFrame.Size = UDim2.fromScale(1, 1)

	local function clamp(v, mn, mx)
		return math.max(mn, math.min(mx, v))
	end

	local dx = randRange(-0.42, 0.42)
	local dy = randRange(-0.38, 0.30)

	local sx = clamp(0.5 + dx, 0.22, 0.78)
	local sy = clamp(0.5 + dy, 0.22, 0.78)
	local spreadPos = UDim2.fromScale(sx, sy)

	local driftPos = UDim2.fromScale(
		clamp(sx + randRange(-0.08, 0.08), 0.24, 0.76),
		clamp(sy + randRange(-0.08, 0.08), 0.24, 0.76)
	)

	local t1 = TweenService:Create(
		mainFrame,
		TweenInfo.new(0.12, Enum.EasingStyle.Back, Enum.EasingDirection.Out),
		{ Position = spreadPos, Size = UDim2.fromScale(1.08, 1.08) }
	)
	local t2 = TweenService:Create(
		mainFrame,
		TweenInfo.new(0.14, Enum.EasingStyle.Quad, Enum.EasingDirection.Out),
		{ Position = driftPos, Size = UDim2.fromScale(1.00, 1.00) }
	)
	local t3 = TweenService:Create(
		mainFrame,
		TweenInfo.new(0.34, Enum.EasingStyle.Quad, Enum.EasingDirection.In),
		{ Position = UDim2.fromScale(0.5, 0.5), Size = UDim2.fromScale(0.16, 0.16) }
	)
	local fadeText = TweenService:Create(
		amountLabel,
		TweenInfo.new(0.34, Enum.EasingStyle.Quad, Enum.EasingDirection.In),
		{ TextTransparency = 1, TextStrokeTransparency = 1 }
	)

	t1:Play()
	t1.Completed:Connect(function()
		t2:Play()
	end)
	t2.Completed:Connect(function()
		t3:Play()
		fadeText:Play()
	end)
	t3.Completed:Connect(function()
		popup:Destroy()
	end)
end

local function fadeLevelUpEmitters(attachment, fadeDuration)
	local emitters = {}
	local maxLifetime = 0

	for _, obj in ipairs(attachment:GetDescendants()) do
		if obj:IsA("ParticleEmitter") then
			table.insert(emitters, obj)
			maxLifetime = math.max(maxLifetime, obj.Lifetime.Max)

			local emitCount = obj:GetAttribute("EmitCount") or 24
			obj:Emit(emitCount)
		end
	end

	if #emitters == 0 then
		Debris:AddItem(attachment, 1)
		return
	end

	task.delay(0.10, function()
		local stepCount = 8
		for i = 1, stepCount do
			local alpha = i / stepCount
			for _, em in ipairs(emitters) do
				em.Transparency = NumberSequence.new({
					NumberSequenceKeypoint.new(0, math.clamp(alpha * 0.75, 0, 1)),
					NumberSequenceKeypoint.new(1, 1)
				})
			end
			task.wait(fadeDuration / stepCount)
		end
	end)

	Debris:AddItem(attachment, maxLifetime + fadeDuration + 0.8)
end

local function playLevelUpFx(levelUps)
	local char = player.Character
	if not char then return end
	local root = char:FindFirstChild("HumanoidRootPart")
	if not root then return end

	local fx = levelUpTemplate:Clone()
	fx.Parent = root
	fx.Position = Vector3.new(0, 0, 0)

	local multiplier = math.clamp(levelUps, 1, 5)
	for _, obj in ipairs(fx:GetDescendants()) do
		if obj:IsA("ParticleEmitter") then
			local base = obj:GetAttribute("EmitCount") or 24
			obj:SetAttribute("EmitCount", base * multiplier)
		end
	end

	fadeLevelUpEmitters(fx, 0.40)
end

