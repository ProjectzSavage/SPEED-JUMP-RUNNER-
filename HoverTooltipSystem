local Players = game:GetService("Players")
local UserInputService = game:GetService("UserInputService")
local RunService = game:GetService("RunService")

local player = Players.LocalPlayer
local playerGui = player:WaitForChild("PlayerGui")
local mouse = player:GetMouse()

local tooltipGui = Instance.new("ScreenGui")
tooltipGui.Name = "TooltipGui"
tooltipGui.DisplayOrder = 999999
tooltipGui.Parent = playerGui

local tooltipFrame = Instance.new("Frame")
tooltipFrame.Size = UDim2.new(0, 150, 0, 30)
tooltipFrame.BackgroundColor3 = Color3.fromRGB(0, 0, 0)
tooltipFrame.BackgroundTransparency = 0.2
tooltipFrame.BorderSizePixel = 0
tooltipFrame.Visible = false
tooltipFrame.Parent = tooltipGui

local corner = Instance.new("UICorner")
corner.CornerRadius = UDim.new(0, 5)
corner.Parent = tooltipFrame

local tooltipLabel = Instance.new("TextLabel")
tooltipLabel.Size = UDim2.new(1, 0, 1, 0)
tooltipLabel.BackgroundTransparency = 1
tooltipLabel.Text = ""
tooltipLabel.TextColor3 = Color3.fromRGB(255, 255, 255)
tooltipLabel.TextScaled = true
tooltipLabel.Font = Enum.Font.GothamBold
tooltipLabel.Parent = tooltipFrame

local connection = nil

local function showTooltip(text)
	tooltipLabel.Text = text
	tooltipFrame.Visible = true

	connection = RunService.Heartbeat:Connect(function()
		tooltipFrame.Position = UDim2.new(0, mouse.X + 10, 0, mouse.Y - 40)
	end)
end

local function hideTooltip()
	tooltipFrame.Visible = false
	if connection then
		connection:Disconnect()
		connection = nil
	end
end

local function addTooltip(guiElement, text)
	guiElement.MouseEnter:Connect(function()
		showTooltip(text)
	end)

	guiElement.MouseLeave:Connect(function()
		hideTooltip()
	end)
end

wait(2)

local rebirthGUI = playerGui:FindFirstChild("RebirthGUI")
if rebirthGUI then
	local toggleButton = rebirthGUI:FindFirstChild("ToggleButton")
	if toggleButton then
		addTooltip(toggleButton, "Rebirth")
	end
end

local leaderboardGUI = playerGui:FindFirstChild("LeaderboardGUI")
if leaderboardGUI then
	local toggleButton = leaderboardGUI:FindFirstChild("TextButton")
	if toggleButton then
		addTooltip(toggleButton, "Leaderboard")
	end
end

local titleGUI = playerGui:FindFirstChild("TitleGUI")
if titleGUI then
	local toggleButton = titleGUI:FindFirstChild("ToggleButton")
	if toggleButton then
		addTooltip(toggleButton, "Titles")
	end
end

local skinGUI = playerGui:FindFirstChild("SkinGUI")
if skinGUI then
	local toggleButton = skinGUI:FindFirstChild("ToggleButton")
	if toggleButton then
		addTooltip(toggleButton, "Skins")
	end
end

_G.AddTooltip = addTooltip
