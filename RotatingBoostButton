local Players = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")

local player = Players.LocalPlayer
local playerGui = player:WaitForChild("PlayerGui")

local openShopEvent = ReplicatedStorage:FindFirstChild("OpenUnifiedShopPanel")
if not openShopEvent then
	openShopEvent = Instance.new("BindableEvent")
	openShopEvent.Name = "OpenUnifiedShopPanel"
	openShopEvent.Parent = ReplicatedStorage
end

local container = playerGui:WaitForChild("MainMenuButtons"):WaitForChild("Frame")
local button = container:WaitForChild("RotatingBoostButton")
local offerLabel = button:FindFirstChild("OfferLabel") or button:FindFirstChildWhichIsA("TextLabel")
local priceLabel = button:FindFirstChild("PriceLabel")

if offerLabel then
	offerLabel.Text = "SHOP"
end
if priceLabel then
	priceLabel.Text = "SHOP"
end

button.MouseButton1Click:Connect(function()
	openShopEvent:Fire()
end)
