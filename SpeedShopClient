local Players = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local TweenService = game:GetService("TweenService")

local player = Players.LocalPlayer
local playerGui = player:WaitForChild("PlayerGui")
local promptShopRemote = ReplicatedStorage:WaitForChild("PromptSpeedShopPurchase")

local gui = playerGui:WaitForChild("SpeedShopGUI")
local topOffersFrame = gui:WaitForChild("TopOffersFrame")
local openShopButton = topOffersFrame:WaitForChild("OpenShopButton")
local shopFrame = gui:WaitForChild("ShopFrame")
local headerFrame = shopFrame:WaitForChild("HeaderFrame")
local closeButton = headerFrame:WaitForChild("CloseButton")
local contentFrame = shopFrame:WaitForChild("ContentFrame")
local productsFrame = contentFrame:WaitForChild("ProductsFrame")

local uiScale = shopFrame:FindFirstChildOfClass("UIScale")
if not uiScale then
	uiScale = Instance.new("UIScale")
	uiScale.Scale = 1
	uiScale.Parent = shopFrame
end

local PRODUCTS = {
	Speed5 = {
		percent = 0.05,
		button = topOffersFrame:WaitForChild("Offer5Button"),
	},
	Speed10 = {
		percent = 0.10,
		button = topOffersFrame:WaitForChild("Offer10Button"),
	},
	Speed20 = {
		percent = 0.20,
		button = topOffersFrame:WaitForChild("Offer20Button"),
	},
	Speed50 = {
		percent = 0.50,
		button = productsFrame:WaitForChild("Product50Button"),
	},
	Speed100 = {
		percent = 1.00,
		button = productsFrame:WaitForChild("Product100Button"),
	},
	Speed210 = {
		percent = 2.10,
		button = productsFrame:WaitForChild("Product210Button"),
	},
}

local animating = false
local openPosition = shopFrame.Position
local closedPosition = UDim2.new(openPosition.X.Scale, openPosition.X.Offset, openPosition.Y.Scale + 0.06, openPosition.Y.Offset)

local function formatNumber(n)
	n = tonumber(n) or 0
	if n >= 1e12 then return string.format("%.2fT", n / 1e12) end
	if n >= 1e9 then return string.format("%.2fB", n / 1e9) end
	if n >= 1e6 then return string.format("%.2fM", n / 1e6) end
	if n >= 1e3 then return string.format("%.1fK", n / 1e3) end
	return tostring(math.floor(n))
end

local function getCurrentSpeed()
	local leaderstats = player:FindFirstChild("leaderstats")
	local speed = leaderstats and leaderstats:FindFirstChild("Speed")
	return math.max(0, math.floor((speed and speed.Value) or 0))
end

local function getLabelForButton(button)
	return button:FindFirstChild("AmountLabel")
		or button:FindFirstChild("TextLabel")
		or button:FindFirstChildWhichIsA("TextLabel")
end

local function setButtonText(button, text)
	local label = getLabelForButton(button)
	if label then
		label.Text = text
	elseif button:IsA("TextButton") then
		button.Text = text
	end
end

local function updateShopTexts()
	local currentSpeed = getCurrentSpeed()

	for key, info in pairs(PRODUCTS) do
		local gain = math.max(1, math.floor(currentSpeed * info.percent + 0.5))
		setButtonText(info.button, "+" .. formatNumber(gain) .. " Speed")
		info.button:SetAttribute("GainAmount", gain)
		info.button:SetAttribute("Percent", info.percent)
		info.button:SetAttribute("ProductKey", key)
		info.button:SetAttribute("CurrentSpeedSeen", currentSpeed)
	end
end

local function openShop()
	if animating or shopFrame.Visible then return end
	animating = true
	updateShopTexts()
	shopFrame.Visible = true
	shopFrame.Position = closedPosition
	uiScale.Scale = 0.94

	local t1 = TweenService:Create(shopFrame, TweenInfo.new(0.22, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
		Position = openPosition,
	})
	local t2 = TweenService:Create(uiScale, TweenInfo.new(0.22, Enum.EasingStyle.Back, Enum.EasingDirection.Out), {
		Scale = 1,
	})

	t1:Play()
	t2:Play()
	t1.Completed:Wait()
	animating = false
end

local function closeShop()
	if animating or not shopFrame.Visible then return end
	animating = true

	local t1 = TweenService:Create(shopFrame, TweenInfo.new(0.18, Enum.EasingStyle.Quad, Enum.EasingDirection.In), {
		Position = closedPosition,
	})
	local t2 = TweenService:Create(uiScale, TweenInfo.new(0.18, Enum.EasingStyle.Quad, Enum.EasingDirection.In), {
		Scale = 0.94,
	})

	t1:Play()
	t2:Play()
	t1.Completed:Wait()

	shopFrame.Visible = false
	shopFrame.Position = openPosition
	uiScale.Scale = 1
	animating = false
end

for productKey, info in pairs(PRODUCTS) do
	info.button.MouseButton1Click:Connect(function()
		promptShopRemote:FireServer(productKey)
	end)
end

openShopButton.MouseButton1Click:Connect(function()
	if shopFrame.Visible then
		closeShop()
	else
		openShop()
	end
end)

closeButton.MouseButton1Click:Connect(closeShop)

local leaderstats = player:WaitForChild("leaderstats")
leaderstats:WaitForChild("Speed").Changed:Connect(updateShopTexts)

shopFrame.Visible = false
shopFrame.Position = openPosition
updateShopTexts()
