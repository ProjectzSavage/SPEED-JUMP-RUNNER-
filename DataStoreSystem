local function applyData(player, data)
	if typeof(data) ~= "table" then return end
	local leaderstats, stats, ownedAuras, ownedSkins = ensureFolders(player)

	local ls = data.Leaderstats or {}
	local level = ensureValue(leaderstats, "IntValue", "Level", 0)
	level.Value = ls.Level or 0
	ensureValue(leaderstats, "IntValue", "Rebirths", 0).Value = ls.Rebirths or 0
	ensureValue(leaderstats, "IntValue", "Wins", 0).Value = ls.Wins or 0
	ensureValue(leaderstats, "StringValue", "CurrentSkin", "None").Value = ls.CurrentSkin or "None"
	ensureValue(leaderstats, "StringValue", "Title", "Newbie").Value = ls.Title or "Newbie"

	local st = data.Stats or {}
	ensureValue(stats, "NumberValue", "EXP", 0).Value = st.EXP or 0
	ensureValue(stats, "NumberValue", "EXPRequired", expRequiredForLevel(level.Value)).Value = expRequiredForLevel(level.Value)
	ensureValue(stats, "IntValue", "Jumps", 0).Value = st.Jumps or 0
	ensureValue(stats, "IntValue", "Multiplier", 1).Value = st.Multiplier or 1
