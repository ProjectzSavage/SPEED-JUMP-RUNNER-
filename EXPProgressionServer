		if not char then return end
		local player = Players:GetPlayerFromCharacter(char)
		if not player then return end

		local hum = char:FindFirstChildOfClass("Humanoid")
		if not hum or hum.Health <= 0 then return end

		local counts = winTouchCounts[part]
		local current = counts[player] or 0
		counts[player] = current + 1
		if current > 0 then return end

		local winsAmount = math.max(1, math.floor(part:GetAttribute("WinsAmount") or 1))
		local winsPotionMult = getWinsPotionMultiplier(player)
		winsAmount = math.max(1, math.floor(winsAmount * winsPotionMult + 0.5))
		local cooldownSec = part:GetAttribute("WinsCooldown") or 0.5

		winCooldown[player] = winCooldown[player] or {}
		local last = winCooldown[player][part] or 0
		local now = tick()
		if now - last < cooldownSec then return end
		winCooldown[player][part] = now

		local leaderstats = player:FindFirstChild("leaderstats")
		local wins = leaderstats and leaderstats:FindFirstChild("Wins")
		if wins then
			wins.Value += winsAmount
			autoEquipHighestStepMultiplier(player)
			notifyPlayer(player, "+" .. tostring(winsAmount) .. " Wins", "You earned " .. tostring(winsAmount) .. " win" .. (winsAmount == 1 and "" or "s") .. "!", "Warning", 3.2, nil, {
				scaleMultiplier = 1.8,
				confetti = true,
				confettiCount = math.clamp(20 + winsAmount * 10, 30, 90),
				soundId = "rbxassetid://1843520822",
				iconKey = "Wins",
			})
		end

		local shouldTeleport = part:GetAttribute("TeleportToSpawn")
		if shouldTeleport == nil or shouldTeleport == true then
			task.defer(teleportPlayerToSpawn, player)
		end
	end)

	part.TouchEnded:Connect(function(hit)
		local char = hit:FindFirstAncestorOfClass("Model")
		if not char then return end
		local player = Players:GetPlayerFromCharacter(char)
		if not player then return end

		local counts = winTouchCounts[part]
		if not counts then return end

		local current = counts[player] or 0
		current -= 1
		if current <= 0 then
			counts[player] = nil
		else
			counts[player] = current
		end
	end)
end

