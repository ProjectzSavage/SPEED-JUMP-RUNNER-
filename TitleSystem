local Players = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")

local equipTitleRemote = ReplicatedStorage:FindFirstChild("EquipTitle")
if not equipTitleRemote then
	equipTitleRemote = Instance.new("RemoteEvent")
	equipTitleRemote.Name = "EquipTitle"
	equipTitleRemote.Parent = ReplicatedStorage
end

local showNotificationRemote = ReplicatedStorage:FindFirstChild("ShowNotification")
if not showNotificationRemote then
	showNotificationRemote = Instance.new("RemoteEvent")
	showNotificationRemote.Name = "ShowNotification"
	showNotificationRemote.Parent = ReplicatedStorage
end

local equippedTitles = {}
local highestUnlockedIndexByPlayer = {}

local TITLES = {
	{ name = "Newbie", speedReq = 0, jumpReq = 0, rebirthReq = 0, color = Color3.fromRGB(255, 255, 255) },
	{ name = "Walker", speedReq = 1000, jumpReq = 50, rebirthReq = 0, color = Color3.fromRGB(0, 255, 0) },
	{ name = "Runner", speedReq = 5000, jumpReq = 100, rebirthReq = 1, color = Color3.fromRGB(0, 150, 255) },
	{ name = "Speedster", speedReq = 10000, jumpReq = 300, rebirthReq = 1, color = Color3.fromRGB(255, 165, 0) },
	{ name = "Lightning", speedReq = 35000, jumpReq = 750, rebirthReq = 2, color = Color3.fromRGB(255, 215, 0) },
	{ name = "Sonic", speedReq = 75000, jumpReq = 3000, rebirthReq = 3, color = Color3.fromRGB(255, 0, 255) },
	{ name = "Flash", speedReq = 100000, jumpReq = 10000, rebirthReq = 4, color = Color3.fromRGB(255, 0, 0) },
}

local TITLE_MULTIPLIERS = {
	Newbie = 1.00,
	Walker = 1.05,
	Runner = 1.10,
	Speedster = 1.15,
	Lightning = 1.25,
	Sonic = 1.35,
	Flash = 1.50,
}

local function notifyPlayer(player, title, message, kind, duration, icon, extra)
	local payload = {
		title = title,
		message = message,
		kind = kind or "Info",
		duration = duration or 3.5,
		icon = icon,
	}
	if type(extra) == "table" then
		for key, value in pairs(extra) do
			payload[key] = value
		end
	end
	showNotificationRemote:FireClient(player, payload)
end

local function getHighestUnlockedTitle(player)
	local leaderstats = player:FindFirstChild("leaderstats")
	local stats = player:FindFirstChild("Stats")
	if not leaderstats or not stats then return TITLES[1], 1 end

	local speed = leaderstats:FindFirstChild("Speed")
	local rebirths = leaderstats:FindFirstChild("Rebirths")
	local jumps = stats:FindFirstChild("Jumps")
	if not speed or not rebirths or not jumps then return TITLES[1], 1 end

	local highest = TITLES[1]
	local highestIndex = 1
	for index, t in ipairs(TITLES) do
		if speed.Value >= t.speedReq and jumps.Value >= t.jumpReq and rebirths.Value >= t.rebirthReq then
			highest = t
			highestIndex = index
		end
	end
	return highest, highestIndex
end

local function ensureTitleMultiplier(player, titleName)
	local stats = player:FindFirstChild("Stats")
	if not stats then return end
	local titleMult = stats:FindFirstChild("TitleMultiplier")
	if not titleMult then
		titleMult = Instance.new("NumberValue")
		titleMult.Name = "TitleMultiplier"
		titleMult.Value = 1
		titleMult.Parent = stats
	end
	titleMult.Value = TITLE_MULTIPLIERS[titleName] or 1
end

local function maybeNotifyTitleUnlock(player, unlocked, unlockedIndex)
	local previousIndex = highestUnlockedIndexByPlayer[player]
	if previousIndex == nil then
		highestUnlockedIndexByPlayer[player] = unlockedIndex
		return
	end

	if unlockedIndex > previousIndex then
		highestUnlockedIndexByPlayer[player] = unlockedIndex
		notifyPlayer(player, "New Title Unlocked", unlocked.name .. " is now unlocked!", "Success", 3.5, nil, {
			iconKey = "Title",
		})
	elseif unlockedIndex < previousIndex then
		highestUnlockedIndexByPlayer[player] = unlockedIndex
	end
end

local function updatePlayerTitle(player)
	local char = player.Character
	if not char then return end
	local head = char:FindFirstChild("Head")
	if not head then return end

	local old = head:FindFirstChild("TitleGui")
	if old then old:Destroy() end

	local chosen = equippedTitles[player]
	local unlocked, unlockedIndex = getHighestUnlockedTitle(player)
	maybeNotifyTitleUnlock(player, unlocked, unlockedIndex)

	local toShow = chosen or unlocked
	if typeof(toShow) ~= "table" or not toShow.name or not toShow.color then
		toShow = unlocked
	end

	local leaderstats = player:FindFirstChild("leaderstats")
	if leaderstats then
		local titleStat = leaderstats:FindFirstChild("Title")
		if not titleStat then
			titleStat = Instance.new("StringValue")
			titleStat.Name = "Title"
			titleStat.Parent = leaderstats
		end
		titleStat.Value = toShow.name
	end

	ensureTitleMultiplier(player, toShow.name)

	local billboard = Instance.new("BillboardGui")
	billboard.Name = "TitleGui"
	billboard.Size = UDim2.new(4, 0, 1, 0)
	billboard.StudsOffset = Vector3.new(0, 2, 0)
	billboard.Adornee = head
	billboard.AlwaysOnTop = true
	billboard.Parent = head
	billboard.MaxDistance = 100

	local titleLabel = Instance.new("TextLabel")
	titleLabel.Size = UDim2.new(1, 0, 1, 0)
	titleLabel.BackgroundTransparency = 1
	titleLabel.Text = toShow.name
	titleLabel.TextColor3 = toShow.color
	titleLabel.TextScaled = true
	titleLabel.Font = Enum.Font.GothamBold
	titleLabel.TextStrokeTransparency = 0
	titleLabel.TextStrokeColor3 = Color3.fromRGB(0, 0, 0)
	titleLabel.Parent = billboard

	local stats = player:FindFirstChild("Stats")
	local jumpsValue = stats and stats:FindFirstChild("Jumps")
	local jumpsText = jumpsValue and jumpsValue.Value or 0

	local jumpsLabel = Instance.new("TextLabel")
	jumpsLabel.Name = "JumpsLabel"
	jumpsLabel.Size = UDim2.new(1, 0, 0.55, 0)
	jumpsLabel.Position = UDim2.new(0, 0, 0.75, 0)
	jumpsLabel.BackgroundTransparency = 1
	jumpsLabel.Text = "Jumps: " .. tostring(jumpsText)
	jumpsLabel.TextColor3 = Color3.fromRGB(255, 255, 255)
	jumpsLabel.TextScaled = true
	jumpsLabel.Font = Enum.Font.GothamBold
	jumpsLabel.TextStrokeTransparency = 0
	jumpsLabel.TextStrokeColor3 = Color3.fromRGB(0, 0, 0)
	jumpsLabel.Parent = billboard
end

equipTitleRemote.OnServerEvent:Connect(function(player, titleData)
	equippedTitles[player] = titleData
	updatePlayerTitle(player)
end)

Players.PlayerAdded:Connect(function(player)
	player.CharacterAdded:Connect(function()
		task.wait(0.5)
		local _, unlockedIndex = getHighestUnlockedTitle(player)
		highestUnlockedIndexByPlayer[player] = unlockedIndex
		updatePlayerTitle(player)
	end)

	task.defer(function()
		local leaderstats = player:WaitForChild("leaderstats")
		local stats = player:WaitForChild("Stats")

		leaderstats:WaitForChild("Speed").Changed:Connect(function() updatePlayerTitle(player) end)
		leaderstats:WaitForChild("Rebirths").Changed:Connect(function() updatePlayerTitle(player) end)
		stats:WaitForChild("Jumps").Changed:Connect(function() updatePlayerTitle(player) end)
	end)
end)

Players.PlayerRemoving:Connect(function(player)
	equippedTitles[player] = nil
	highestUnlockedIndexByPlayer[player] = nil
end)
