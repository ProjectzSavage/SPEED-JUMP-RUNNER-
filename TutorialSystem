-- LocalScript in StarterPlayerScripts
local Players = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local RunService = game:GetService("RunService")
local CollectionService = game:GetService("CollectionService")
local TweenService = game:GetService("TweenService")

local player = Players.LocalPlayer
local playerGui = player:WaitForChild("PlayerGui")
local stats = player:WaitForChild("Stats")
local leaderstats = player:WaitForChild("leaderstats")

local completeTutorialRewardRemote = ReplicatedStorage:WaitForChild("CompleteTutorialReward")
local onboardingRemote = ReplicatedStorage:FindFirstChild("AnalyticsOnboardingStep")

local gui = playerGui:WaitForChild("TutorialGUI")
local mainFrame = gui:WaitForChild("MainFrame")
local instructionLabel = mainFrame:WaitForChild("InstructionLabel")
local skipButton = mainFrame:WaitForChild("SkipButton")

local mainMenuButtons = playerGui:WaitForChild("MainMenuButtons")
local levelExpGui = playerGui:WaitForChild("LevelExpGUI")
local rebirthGui = playerGui:WaitForChild("RebirthGUI")
local rebirthGuiMain = rebirthGui:WaitForChild("MainFrame")
local rebirthActionButton = rebirthGuiMain:WaitForChild("RebirthButton")
local rebirthToggleButton = mainMenuButtons:FindFirstChild("RebirthToggleButton", true)
if not rebirthToggleButton then
	error("RebirthToggleButton not found inside MainMenuButtons descendants")
end

local tutorialCompleted = stats:WaitForChild("TutorialCompleted")
local stepMultiplier = stats:WaitForChild("StepMultiplier")
local level = leaderstats:WaitForChild("Level")
local wins = leaderstats:WaitForChild("Wins")
local rebirths = leaderstats:WaitForChild("Rebirths")

local guidePart = gui:FindFirstChild("GuidePart") or Instance.new("Part")
guidePart.Name = "GuidePart"
guidePart.Anchored = true
guidePart.CanCollide = false
guidePart.CanTouch = false
guidePart.CanQuery = false
guidePart.Transparency = 1
guidePart.Size = Vector3.new(1, 1, 1)
guidePart.Parent = workspace

local attachment0 = guidePart:FindFirstChild("A0") or Instance.new("Attachment")
attachment0.Name = "A0"
attachment0.Parent = guidePart
local attachment1 = guidePart:FindFirstChild("A1") or Instance.new("Attachment")
attachment1.Name = "A1"
attachment1.Parent = guidePart

local beam = guidePart:FindFirstChildOfClass("Beam") or Instance.new("Beam")
beam.Parent = guidePart
beam.Attachment0 = attachment1
beam.Attachment1 = attachment0
beam.Width0 = 2
beam.Width1 = 2
beam.FaceCamera = true
beam.Color = ColorSequence.new(Color3.fromRGB(255, 220, 70))
beam.LightEmission = 0.5
beam.Brightness = 1
beam.Transparency = NumberSequence.new(0.05)
beam.Texture = "rbxassetid://3371283711"
beam.TextureMode = Enum.TextureMode.Wrap
beam.TextureLength = 5
beam.TextureSpeed = -2.5
beam.Segments = 20
beam.Enabled = false

local overlay = gui:FindFirstChild("DarkOverlay") or Instance.new("Frame")
overlay.Name = "DarkOverlay"
overlay.Size = UDim2.fromScale(1, 1)
overlay.Position = UDim2.fromScale(0, 0)
overlay.BackgroundColor3 = Color3.new(0, 0, 0)
overlay.BackgroundTransparency = 1
overlay.BorderSizePixel = 0
overlay.Visible = false
overlay.ZIndex = 50
overlay.Parent = gui

local sideArrow = gui:FindFirstChild("SideArrow") or Instance.new("ImageLabel")
sideArrow.Name = "SideArrow"
sideArrow.BackgroundTransparency = 1
sideArrow.Image = "rbxassetid://3371283711"
sideArrow.Size = UDim2.fromScale(0.05, 0.09)
sideArrow.AnchorPoint = Vector2.new(0.5, 0.5)
sideArrow.Visible = false
sideArrow.ZIndex = 80
sideArrow.Parent = gui

local topArrow = gui:FindFirstChild("TopArrow") or Instance.new("ImageLabel")
topArrow.Name = "TopArrow"
topArrow.BackgroundTransparency = 1
topArrow.Image = "rbxassetid://3371283711"
topArrow.Size = UDim2.fromScale(0.06, 0.10)
topArrow.AnchorPoint = Vector2.new(0.5, 0.5)
topArrow.Visible = false
topArrow.ZIndex = 1000
topArrow.Parent = gui

local currentTarget = nil
local tutorialStep = 1
local rewardGranted = false
local restoredMainButtons = false
local originalPositions = {}
local highlighted = {}
local rebirthHighlightMode = nil
local padTouchCompleted = false
local tutorialDisplayOrder = gui.DisplayOrder
local originalRebirthDisplayOrder = rebirthGui.DisplayOrder
local firedFunnelSteps = {}

local function logTutorialStep(step, stepName)
	if not onboardingRemote then return end
	if firedFunnelSteps[step] then return end
	firedFunnelSteps[step] = true
	onboardingRemote:FireServer({
		step = step,
		stepName = stepName,
	})
end

local function cacheOriginalPositions()
	for _, obj in ipairs(mainMenuButtons:GetDescendants()) do
		if obj:IsA("GuiObject") then
			originalPositions[obj] = obj.Position
		end
	end
end
cacheOriginalPositions()

local function getStepPad2Target()
	for _, part in ipairs(CollectionService:GetTagged("StepMultiplierPad")) do
		if tonumber(part:GetAttribute("StepOrder")) == 2 then
			return part
		end
	end
	return workspace:FindFirstChild("2", true)
end

local function getTrampolineTarget()
	return workspace:FindFirstChild("1x", true)
end

local stepPad2Target = getStepPad2Target()
local trampolineTarget = getTrampolineTarget()
local stepPad2RequiredWins = 2
if stepPad2Target and stepPad2Target:IsA("BasePart") then
	stepPad2RequiredWins = math.max(2, tonumber(stepPad2Target:GetAttribute("WinsRequired")) or 2)
	stepPad2Target.Touched:Connect(function(hit)
		if tutorialStep ~= 2 then return end
		local character = hit:FindFirstAncestorOfClass("Model")
		if character == player.Character then
			padTouchCompleted = true
			refreshStep()
		end
	end)
end

local function setMainMenuVisible(visible)
	if mainMenuButtons:IsA("ScreenGui") then
		mainMenuButtons.Enabled = visible
	else
		mainMenuButtons.Visible = visible
	end
end

local function showOnlyRebirthToggle()
	for _, obj in ipairs(mainMenuButtons:GetDescendants()) do
		if obj:IsA("GuiObject") and (obj:IsA("TextButton") or obj:IsA("ImageButton")) then
			obj.Visible = (obj == rebirthToggleButton)
		end
	end
end

local function restoreMainButtonsAnimated()
	if restoredMainButtons then return end
	restoredMainButtons = true

	local buttons = {}
	for _, obj in ipairs(mainMenuButtons:GetDescendants()) do
		if obj:IsA("GuiObject") and (obj:IsA("TextButton") or obj:IsA("ImageButton")) then
			obj.Visible = true
			table.insert(buttons, obj)
		end
	end

	table.sort(buttons, function(a, b)
		return a.AbsolutePosition.X < b.AbsolutePosition.X
	end)

	for index, button in ipairs(buttons) do
		local original = originalPositions[button] or button.Position
		button.Position = UDim2.new(original.X.Scale, original.X.Offset - 120, original.Y.Scale, original.Y.Offset)
		for _, child in ipairs(button:GetDescendants()) do
			if child:IsA("TextLabel") or child:IsA("TextButton") then
				child.TextTransparency = 1
				child.TextStrokeTransparency = 1
			elseif child:IsA("ImageLabel") or child:IsA("ImageButton") then
				child.ImageTransparency = 1
			end
		end

		task.delay((index - 1) * 0.08, function()
			TweenService:Create(button, TweenInfo.new(0.22, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
				Position = original,
			}):Play()
			for _, child in ipairs(button:GetDescendants()) do
				if child:IsA("TextLabel") or child:IsA("TextButton") then
					TweenService:Create(child, TweenInfo.new(0.22, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
						TextTransparency = 0,
						TextStrokeTransparency = 0,
					}):Play()
				elseif child:IsA("ImageLabel") or child:IsA("ImageButton") then
					TweenService:Create(child, TweenInfo.new(0.22, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
						ImageTransparency = 0,
					}):Play()
				end
			end
		end)
	end
end

local function getTargetPartForModel(model)
	if not model then return nil end
	if model:IsA("BasePart") then return model end
	if model:IsA("Model") then
		return model.PrimaryPart or model:FindFirstChildWhichIsA("BasePart", true)
	end
	return nil
end

local function findFirstWinTarget()
	return workspace:FindFirstChild("firstwin", true)
end

local function setInstruction(text)
	instructionLabel.Text = text
end

local function setTarget(target)
	currentTarget = target
	beam.Enabled = target ~= nil
end

local function clearHighlights()
	for obj, oldZ in pairs(highlighted) do
		if obj and obj.Parent then obj.ZIndex = oldZ end
	end
	table.clear(highlighted)
	overlay.Visible = false
	overlay.BackgroundTransparency = 1
	sideArrow.Visible = false
	topArrow.Visible = false
	rebirthHighlightMode = nil
	rebirthGui.DisplayOrder = originalRebirthDisplayOrder

	local rebirthStroke = rebirthActionButton:FindFirstChildOfClass("UIStroke")
	if rebirthStroke then
		rebirthStroke.Thickness = 1
		rebirthStroke.Transparency = 0
		rebirthStroke.Color = Color3.fromRGB(255, 255, 255)
	end
end

local function raiseZ(obj, minZ)
	if obj:IsA("GuiObject") then
		if highlighted[obj] == nil then highlighted[obj] = obj.ZIndex end
		obj.ZIndex = math.max(obj.ZIndex, minZ)
	end
	for _, desc in ipairs(obj:GetDescendants()) do
		if desc:IsA("GuiObject") then
			if highlighted[desc] == nil then highlighted[desc] = desc.ZIndex end
			desc.ZIndex = math.max(desc.ZIndex, minZ)
		end
	end
end

local function setOverlayVisible()
	overlay.Visible = true
	TweenService:Create(overlay, TweenInfo.new(0.2, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
		BackgroundTransparency = 0.35,
	}):Play()
end

local function applyRebirthToggleHighlight()
	if rebirthHighlightMode == "Toggle" then return end
	clearHighlights()
	rebirthHighlightMode = "Toggle"
	rebirthGui.DisplayOrder = tutorialDisplayOrder + 100
	raiseZ(rebirthToggleButton, 70)
	sideArrow.Visible = true
	sideArrow.Rotation = 270
end

local function applyRebirthFrameHighlight()
	if rebirthHighlightMode == "Frame" then return end
	clearHighlights()
	rebirthHighlightMode = "Frame"
	rebirthGui.DisplayOrder = tutorialDisplayOrder + 100
	setOverlayVisible()
	raiseZ(rebirthGuiMain, 70)
	raiseZ(rebirthActionButton, 100)
	local stroke = rebirthActionButton:FindFirstChildOfClass("UIStroke")
	if not stroke then
		stroke = Instance.new("UIStroke")
		stroke.Parent = rebirthActionButton
	end
	stroke.Enabled = true
	stroke.Thickness = 4
	stroke.Color = Color3.fromRGB(255, 230, 90)
	stroke.Transparency = 0
	topArrow.Visible = true
	topArrow.Rotation = 180
end

function refreshStep()
	if tutorialCompleted.Value then
		beam.Enabled = false
		clearHighlights()
		mainFrame.Visible = false
		setMainMenuVisible(true)
		restoreMainButtonsAnimated()
		return
	end

	if tutorialStep == 1 then
		clearHighlights()
		setMainMenuVisible(false)
		mainFrame.Visible = true
		setInstruction("Get " .. tostring(stepPad2RequiredWins) .. " Wins")
		setTarget(findFirstWinTarget())
		logTutorialStep(1, "Got First Wins Goal")
		if wins.Value >= stepPad2RequiredWins then
			tutorialStep = 2
			refreshStep()
		end
	elseif tutorialStep == 2 then
		clearHighlights()
		setInstruction("Touch the 2x step pad")
		setTarget(stepPad2Target)
		if padTouchCompleted then
			logTutorialStep(2, "Touched 2x Step Pad")
			tutorialStep = 3
			refreshStep()
		end
	elseif tutorialStep == 3 then
		clearHighlights()
		setInstruction("Use Auto Jump or Use the 1x Trampoline and Reach Level 10")
		setTarget(trampolineTarget)
		if level.Value >= 10 then
			logTutorialStep(3, "Reached Level 10")
			tutorialStep = 4
			refreshStep()
		end
	elseif tutorialStep == 4 then
		setMainMenuVisible(true)
		showOnlyRebirthToggle()
		setInstruction("Rebirth now")
		setTarget(nil)
		if rebirthGuiMain.Visible then
			applyRebirthFrameHighlight()
		else
			applyRebirthToggleHighlight()
		end
		if rebirths.Value >= 1 and not rewardGranted then
			logTutorialStep(4, "Completed First Rebirth")
			rewardGranted = true
			completeTutorialRewardRemote:FireServer()
			tutorialStep = 5
			refreshStep()
		end
	elseif tutorialStep == 5 then
		beam.Enabled = false
		clearHighlights()
		setInstruction("Tutorial complete! Reward granted.")
		setMainMenuVisible(true)
		restoreMainButtonsAnimated()
		task.delay(2, function()
			mainFrame.Visible = false
		end)
	end
end

skipButton.MouseButton1Click:Connect(function()
	rewardGranted = true
	tutorialCompleted.Value = true
	beam.Enabled = false
	clearHighlights()
	setMainMenuVisible(true)
	restoreMainButtonsAnimated()
	mainFrame.Visible = false
end)

wins.Changed:Connect(refreshStep)
level.Changed:Connect(refreshStep)
stepMultiplier.Changed:Connect(refreshStep)
rebirths.Changed:Connect(refreshStep)
tutorialCompleted.Changed:Connect(refreshStep)
rebirthGuiMain:GetPropertyChangedSignal("Visible"):Connect(function()
	if tutorialStep == 4 then
		refreshStep()
	end
end)

RunService.RenderStepped:Connect(function()
	local character = player.Character
	local root = character and character:FindFirstChild("HumanoidRootPart")

	if beam.Enabled and currentTarget and root then
		local startPos = root.Position + Vector3.new(0, 0.8, 0)
		if typeof(currentTarget) == "Instance" then
			local targetPart = getTargetPartForModel(currentTarget)
			if targetPart then
				attachment0.WorldPosition = startPos
				attachment1.WorldPosition = targetPart.Position + Vector3.new(0, 3, 0)
			end
		end
	end

	local t = tick()
	if sideArrow.Visible and rebirthToggleButton.Visible then
		local pos = rebirthToggleButton.AbsolutePosition
		local size = rebirthToggleButton.AbsoluteSize
		local xOffset = math.sin(t * 4) * 12
		sideArrow.Position = UDim2.fromOffset(pos.X + size.X + 70 + xOffset, pos.Y + size.Y * 0.5)
	end

	if topArrow.Visible and rebirthGuiMain.Visible then
		local pos = rebirthActionButton.AbsolutePosition
		local size = rebirthActionButton.AbsoluteSize
		local yOffset = math.sin(t * 4) * 10
		topArrow.Position = UDim2.fromOffset(pos.X + size.X * 0.5, pos.Y - 55 + yOffset)
	end
end)

mainFrame.Visible = not tutorialCompleted.Value
refreshStep()
