local function ensureValue(parent, className, name, defaultValue)
	local v = parent:FindFirstChild(name)
	if not v then
		v = Instance.new(className)
		v.Name = name
		v.Value = defaultValue
		v.Parent = parent
	end
	return v
end

local function getPotionPromptConfig(prompt)
	if not prompt or not prompt:IsA("ProximityPrompt") then
		return nil
	end

	local productId = tonumber(prompt:GetAttribute("PotionProductId")) or tonumber(prompt:GetAttribute("ProductId"))
	if not productId or productId <= 0 then
		return nil
	end

	local potionType = tostring(prompt:GetAttribute("PotionType") or "")
	if potionType ~= "Exp" and potionType ~= "Wins" then
		return nil
	end

	local multiplier = tonumber(prompt:GetAttribute("PotionMultiplier")) or 2
	local durationMinutes = tonumber(prompt:GetAttribute("PotionDurationMinutes")) or 30
	local potionName = tostring(prompt:GetAttribute("PotionName") or ((multiplier .. "x " .. potionType .. " Potion")))
	local potionIcon = tostring(prompt:GetAttribute("PotionIcon") or "")

	return {
		productId = productId,
		potionType = potionType,
		multiplier = math.max(1, multiplier),
		durationSeconds = math.max(60, math.floor(durationMinutes * 60)),
		name = potionName,
		icon = potionIcon,
	}
end

local function registerPotionPrompt(prompt)
	if not prompt or CONNECTED_POTION_PROMPTS[prompt] then return end
	if not prompt:IsA("ProximityPrompt") then return end

	local config = getPotionPromptConfig(prompt)
	if not config then return end
	POTION_PRODUCT_BY_ID[config.productId] = config
	CONNECTED_POTION_PROMPTS[prompt] = true

	prompt.Triggered:Connect(function(player)
		local latestConfig = getPotionPromptConfig(prompt)
		if not latestConfig then return end
		POTION_PRODUCT_BY_ID[latestConfig.productId] = latestConfig
		MarketplaceService:PromptProductPurchase(player, latestConfig.productId)
	end)
end

local function formatNumber(n)
	n = tonumber(n) or 0
	if n >= 1e12 then return string.format("%.2fT", n / 1e12) end
	if n >= 1e9 then return string.format("%.2fB", n / 1e9) end
	if n >= 1e6 then return string.format("%.2fM", n / 1e6) end
	if n >= 1e3 then return string.format("%.1fK", n / 1e3) end
	return tostring(math.floor(n))
end

local function notifyPlayer(player, title, message, kind, duration, icon, extra)
	local payload = {
		title = title,
		message = message,
		kind = kind or "Info",
		duration = duration or 3.5,
		icon = icon,
	}
	if type(extra) == "table" then
		for key, value in pairs(extra) do
			payload[key] = value
		end
	end
	showNotificationRemote:FireClient(player, payload)
end

local function formatExpRequired(level)
	return math.floor(100 + (level ^ 1.45) * 35)
end

local function getRealSpeedFromLevel(level)
	return BASE_REAL_SPEED + level
end

local function getDisplaySpeedFromProgress(level, exp, expRequired)
	local progress = level
	if expRequired > 0 then
		progress = progress + (exp / expRequired)
	end

	local base = 18.75 * progress * progress
	local visualMultiplier = 10 -- 1 million times bigger visually
	return math.floor(base * visualMultiplier)
end

local function getProgressValue(level, exp, expRequired)
	if expRequired > 0 then
		return level + (exp / expRequired)
	end
	return level
end

local function getNextBoost(currentBoost)
	if currentBoost < 1 then currentBoost = 1 end
	if currentBoost >= 128 then return nil end
	if currentBoost == 1 then return 2 end
	return math.min(currentBoost * 2, 128)
end

local function getStepMultiplierDefinitions()
	local fromPads = {}
	for _, part in ipairs(CollectionService:GetTagged("StepMultiplierPad")) do
		if part:IsA("BasePart") then
			local winsRequired = tonumber(part:GetAttribute("WinsRequired")) or 0
			local multiplier = tonumber(part:GetAttribute("StepMultiplier")) or 1
			local order = tonumber(part:GetAttribute("StepOrder")) or (#fromPads + 1)
			table.insert(fromPads, {
				winsRequired = winsRequired,
				multiplier = math.max(1, multiplier),
				order = math.max(1, math.floor(order)),
			})
		end
	end

	if #fromPads == 0 then
		return DEFAULT_STEP_MULTIPLIERS
	end

	table.sort(fromPads, function(a, b)
		if a.winsRequired == b.winsRequired then
			if a.multiplier == b.multiplier then
				return a.order < b.order
			end
			return a.multiplier < b.multiplier
		end
		return a.winsRequired < b.winsRequired
	end)

	return fromPads
end

local function getHighestUnlockedStepMultiplier(wins)
	local definitions = getStepMultiplierDefinitions()
	local best = definitions[1] or { winsRequired = 0, multiplier = 1, order = 1 }
	for _, info in ipairs(definitions) do
		if wins >= info.winsRequired and info.multiplier >= best.multiplier then
			best = info
		end
	end
	return best
end

