local function isPointInsidePart(worldPoint, part)
	local localPoint = part.CFrame:PointToObjectSpace(worldPoint)
	local half = part.Size * 0.5
	return math.abs(localPoint.X) <= half.X
		and math.abs(localPoint.Y) <= half.Y
		and math.abs(localPoint.Z) <= half.Z
end

local function getZonePart()
	local zone = workspace:FindFirstChild(SHOP_ZONE_PART_NAME, true)
	if zone and not zone:IsA("BasePart") then
		warn("[UnifiedShop] ShopZone found but it is not a BasePart:", zone:GetFullName())
		return nil
	end
	return zone
end

openShopEvent.Event:Connect(function()
	manualClosedInsideZone = false
	openShop("button")
end)

local warnedNoZone = false
RunService.RenderStepped:Connect(function()
	local zone = getZonePart()
	local character = player.Character
	local root = character and character:FindFirstChild("HumanoidRootPart")
	if not zone then
		if not warnedNoZone then
			warnedNoZone = true
			warn("[UnifiedShop] No part named ShopZone found in Workspace descendants")
		end
		return
	end
	warnedNoZone = false
	if not root then
		return
	end

	local nowInside = isPointInsidePart(root.Position, zone)
	if nowInside and not insideZone then
		insideZone = true
		print("[UnifiedShop] Entered zone")
		if not manualClosedInsideZone then
			openShop("zone")
		end
	elseif not nowInside and insideZone then
		insideZone = false
		manualClosedInsideZone = false
		print("[UnifiedShop] Left zone")
		if shopOpen then
			closeShop(false)
		end
	end
end)

