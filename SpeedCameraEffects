local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local TweenService = game:GetService("TweenService")

local player = Players.LocalPlayer
local camera = workspace.CurrentCamera

local BASE_FOV = 70
local MAX_FOV = 110
local SPEED_START = 18
local SPEED_FULL = 120

local currentFOVTween
local shakeConn

local function setFOV(target, t)
	if currentFOVTween then currentFOVTween:Cancel() end
	currentFOVTween = TweenService:Create(
		camera,
		TweenInfo.new(t, Enum.EasingStyle.Quad, Enum.EasingDirection.Out),
		{ FieldOfView = target }
	)
	currentFOVTween:Play()
end

local function stopShake()
	if shakeConn then
		shakeConn:Disconnect()
		shakeConn = nil
	end
end

local function startShake(intensity)
	stopShake()
	shakeConn = RunService.RenderStepped:Connect(function()
		local x = (math.random() - 0.5) * intensity
		local y = (math.random() - 0.5) * intensity
		camera.CFrame = camera.CFrame * CFrame.new(x, y, 0)
	end)
end

RunService.RenderStepped:Connect(function()
	local char = player.Character
	if not char then return end

	local hum = char:FindFirstChildOfClass("Humanoid")
	if not hum then return end

	local isMoving = hum.MoveDirection.Magnitude > 0.05
	local realSpeed = hum.WalkSpeed -- real speed, not displayed stat

	if isMoving and realSpeed > SPEED_START then
		local alpha = math.clamp((realSpeed - SPEED_START) / (SPEED_FULL - SPEED_START), 0, 1)
		local targetFov = BASE_FOV + (MAX_FOV - BASE_FOV) * alpha
		setFOV(targetFov, 0.18)

		local shake = 0.02 + (0.22 * alpha)
		startShake(shake)
	else
		setFOV(BASE_FOV, 0.25)
		stopShake()
	end
end)
