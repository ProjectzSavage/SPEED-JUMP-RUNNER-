local Players = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local MarketplaceService = game:GetService("MarketplaceService")

local promptReviveRemote = ReplicatedStorage:FindFirstChild("PromptReviveOffer")
if not promptReviveRemote then
	promptReviveRemote = Instance.new("RemoteEvent")
	promptReviveRemote.Name = "PromptReviveOffer"
	promptReviveRemote.Parent = ReplicatedStorage
end

local requestRevivePurchaseRemote = ReplicatedStorage:FindFirstChild("RequestRevivePurchase")
if not requestRevivePurchaseRemote then
	requestRevivePurchaseRemote = Instance.new("RemoteEvent")
	requestRevivePurchaseRemote.Name = "RequestRevivePurchase"
	requestRevivePurchaseRemote.Parent = ReplicatedStorage
end

local REVIVE_PRODUCTS = {
	Early = { productId = 3607231878, price = 19 },
	Mid = { productId = 3607231878, price = 39 },
	Late = { productId = 3607231878, price = 69 },
}

local pendingRevives = {}

local function getCurrentStage(player)
	local stats = player:FindFirstChild("Stats")
	local currentStage = stats and stats:FindFirstChild("CurrentStage")
	return currentStage and currentStage.Value or 1
end

local function getReviveProductForStage(stage)
	if stage >= 1 and stage <= 3 then
		return REVIVE_PRODUCTS.Early
	elseif stage >= 4 and stage <= 7 then
		return REVIVE_PRODUCTS.Mid
	else
		return REVIVE_PRODUCTS.Late
	end
end

local function promptRevive(player)
	local stage = getCurrentStage(player)
	local info = getReviveProductForStage(stage)
	if not info or info.productId <= 0 then return end

	pendingRevives[player.UserId] = {
		productId = info.productId,
		stage = stage,
	}

	promptReviveRemote:FireClient(player, {
		title = "Revive?",
		info = "Continue from Stage " .. tostring(stage) .. " before time runs out.",
		price = info.price,
		productId = info.productId,
		duration = 8,
	})
end

requestRevivePurchaseRemote.OnServerEvent:Connect(function(player, productId)
	local pending = pendingRevives[player.UserId]
	if not pending then return end
	if pending.productId ~= productId then return end
	MarketplaceService:PromptProductPurchase(player, productId)
end)

Players.PlayerAdded:Connect(function(player)
	player.CharacterAdded:Connect(function(character)
		local humanoid = character:WaitForChild("Humanoid")
		humanoid.Died:Connect(function()
			task.delay(0.1, function()
				if player.Parent then
					promptRevive(player)
				end
			end)
		end)
	end)
end)

for _, player in ipairs(Players:GetPlayers()) do
	if player.Character then
		local humanoid = player.Character:FindFirstChildOfClass("Humanoid")
		if humanoid then
			humanoid.Died:Connect(function()
				task.delay(0.1, function()
					if player.Parent then
						promptRevive(player)
					end
				end)
			end)
		end
	end
end

return {
	REVIVE_PRODUCTS = REVIVE_PRODUCTS,
	PendingRevives = pendingRevives,
}
