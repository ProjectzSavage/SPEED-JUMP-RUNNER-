local function getTrampolineAccess(player, part)
	local keyName = part.Name

	local parentModel = part:FindFirstAncestorOfClass("Model")
	if not TRAMPOLINE_REQUIREMENTS[keyName] and parentModel and TRAMPOLINE_REQUIREMENTS[parentModel.Name] then
		keyName = parentModel.Name
	end

	local data = TRAMPOLINE_REQUIREMENTS[keyName]
	if not data then
		return true, 1, part:GetAttribute("BouncePower") or TRAMPOLINE_BOUNCE_DEFAULT
	end

	local stats = player:FindFirstChild("Stats")
	local leaderstats = player:FindFirstChild("leaderstats")
	local rebirths = leaderstats and leaderstats:FindFirstChild("Rebirths")
	local playtime = stats and stats:FindFirstChild("PlayTimeSeconds")

	if data.free then
		return true, data.expMult, data.bouncePower
	end

	if data.playtimeSeconds and (not playtime or playtime.Value < data.playtimeSeconds) then
		local remaining = math.max(0, data.playtimeSeconds - (playtime and playtime.Value or 0))
		return false, data.expMult, data.bouncePower, string.format("Need %dm playtime (%dm left)", math.floor(data.playtimeSeconds / 60), math.ceil(remaining / 60))
	end

	if data.rebirths and (not rebirths or rebirths.Value < data.rebirths) then
		return false, data.expMult, data.bouncePower, string.format("Need %d rebirths", data.rebirths)
	end

	if data.gamePassId and data.gamePassId > 0 then
		trampolinePassOwnership[player] = trampolinePassOwnership[player] or {}
		local owns = trampolinePassOwnership[player][keyName]
		if owns == nil then
			refreshTrampolinePassOwnership(player)
			owns = trampolinePassOwnership[player][part.Name]
		end
		if not owns then
			return false, data.expMult, data.bouncePower, "Requires gamepass", data.gamePassId, data.displayName or keyName
		end
	end

	return true, data.expMult, data.bouncePower
end

local function notifyLockedTrampoline(player, part, reason, gamePassId, displayName)
	trampolinePromptCooldown[player] = trampolinePromptCooldown[player] or {}
	local now = tick()
	local last = trampolinePromptCooldown[player][part] or 0
	if now - last < 4 then return end
	trampolinePromptCooldown[player][part] = now

	if gamePassId and gamePassId > 0 then
		notifyPlayer(player, "Locked Trampoline", (displayName or part.Name) .. " requires a gamepass.", "Warning", 3.2)
		MarketplaceService:PromptGamePassPurchase(player, gamePassId)
	else
		notifyPlayer(player, "Locked Trampoline", reason or "You can't use this yet.", "Warning", 3.2)
	end
end

