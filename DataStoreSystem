	applyBoolFolder(ownedAuras, data.OwnedAuras)
	applyBoolFolder(ownedSkins, data.OwnedSkins)
end

local function savePlayer(player)
	local userId = tostring(player.UserId)
	local data = serializePlayer(player)
	local ok, err = pcall(function()
		PROFILE_STORE:UpdateAsync(userId, function()
			return data
		end)
	end)
	if not ok then
		warn("[DataStore] Failed to save", player.Name, err)
	end
end

local function loadPlayer(player)
	local userId = tostring(player.UserId)
	local ok, data = pcall(function()
		return PROFILE_STORE:GetAsync(userId)
	end)
	if ok and data then
		applyData(player, data)
	elseif not ok then
		warn("[DataStore] Failed to load", player.Name, data)
	end
end

Players.PlayerAdded:Connect(function(player)
	ensureFolders(player)
	task.defer(function()
		loadPlayer(player)
	end)
end)

Players.PlayerRemoving:Connect(savePlayer)

game:BindToClose(function()
	for _, player in ipairs(Players:GetPlayers()) do
		savePlayer(player)
	end
	task.wait(2)
end)

task.spawn(function()
	while true do
		task.wait(AUTOSAVE_INTERVAL)
		for _, player in ipairs(Players:GetPlayers()) do
			savePlayer(player)
		end
	end
end)
