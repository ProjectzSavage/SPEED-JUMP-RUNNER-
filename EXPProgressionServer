local function onPlayerAdded(player)
	createPlayerStats(player)
	refreshOwnedExpBoost(player)
	refreshOwnedWinsBoost(player)
	refreshOwnedRebirthBoost(player)
	refreshOwnedAuraGamepasses(player)
	refreshTrampolinePassOwnership(player)
	migrateLegacyShopBonus(player)
	potionFiveMinuteWarnings[player] = {}

	-- Re-check gamepass ownership shortly after join in case initial cache/state is late.
	task.delay(3, function()
		if player.Parent then
			refreshOwnedExpBoost(player)
			refreshOwnedWinsBoost(player)
			refreshOwnedRebirthBoost(player)
			refreshOwnedAuraGamepasses(player)
			refreshTrampolinePassOwnership(player)
		end
	end)

	local leaderstats = player:WaitForChild("leaderstats")
	local stats = player:WaitForChild("Stats")

	autoEquipHighestStepMultiplier(player, true)
	refreshVisiblePotionState(player, "Speed")
	refreshVisiblePotionState(player, "Exp")
	refreshVisiblePotionState(player, "Wins")

	leaderstats:WaitForChild("Level").Changed:Connect(function() applyWalkSpeed(player) end)
	leaderstats:WaitForChild("Wins").Changed:Connect(function()
		autoEquipHighestStepMultiplier(player)
	end)
	stats:WaitForChild("EXP").Changed:Connect(function() applyWalkSpeed(player) end)
	stats:WaitForChild("EXPRequired").Changed:Connect(function() applyWalkSpeed(player) end)
	stats:WaitForChild("SpeedBoost").Changed:Connect(function() applyWalkSpeed(player) end)
	stats:WaitForChild("SelectedRealSpeed").Changed:Connect(function() applyWalkSpeed(player) end)
	stats:WaitForChild("TitleMultiplier").Changed:Connect(function() applyWalkSpeed(player) end)
	stats:WaitForChild("StepMultiplier").Changed:Connect(function() applyWalkSpeed(player) end)
	stats:WaitForChild("SpeedPotionMultiplier").Changed:Connect(function() applyWalkSpeed(player) end)
	stats:WaitForChild("SpeedPotionEndTime").Changed:Connect(function() applyWalkSpeed(player) end)
	stats:WaitForChild("LevelUpSpeedBoostEndTime").Changed:Connect(function() applyWalkSpeed(player) end)
	stats:WaitForChild("AuraMultiplier").Changed:Connect(function() applyWalkSpeed(player) end)
	stats:WaitForChild("GroupRewardDisplaySpeedBonus").Changed:Connect(function() applyWalkSpeed(player) end)

	player.CharacterAdded:Connect(function(character)
		local humanoid = character:WaitForChild("Humanoid")
		humanoid.Died:Connect(function()
			task.delay(0.1, function()
				if player.Parent then
					promptRevive(player)
				end
			end)
		end)
		task.wait(0.2)
		applyWalkSpeed(player)
		local _, currentAura = ensureAuraStats(player)
		if currentAura.Value ~= "None" and currentAura.Value ~= "" then
			applyAuraToCharacter(player, currentAura.Value)
		end
	end)

	applyWalkSpeed(player)
end

Players.PlayerAdded:Connect(onPlayerAdded)
Players.PlayerRemoving:Connect(function(player)
	playerJumpDebounce[player] = nil
	surfaceCooldown[player] = nil
	trampolineCooldown[player] = nil
	winCooldown[player] = nil
	potionFiveMinuteWarnings[player] = nil
	comboState[player] = nil
end)

task.spawn(function()
	while true do
		local tickNow = tick()
		for _, player in ipairs(Players:GetPlayers()) do
			local state = comboState[player]
			if state and tickNow - state.lastJump > COMBO_RESET_TIME then
				resetComboState(player)
			end
		end

		local now = os.time()
		for _, player in ipairs(Players:GetPlayers()) do
			local stats = player:FindFirstChild("Stats")
			if stats then
				local warningState = potionFiveMinuteWarnings[player]
				if warningState then
					local potionChecks = {
						{ key = "Speed", endTime = stats:FindFirstChild("SpeedPotionEndTime"), name = stats:FindFirstChild("SpeedPotionName"), icon = stats:FindFirstChild("SpeedPotionIcon") },
						{ key = "Exp", endTime = stats:FindFirstChild("ExpPotionEndTime"), name = stats:FindFirstChild("ExpPotionName"), icon = stats:FindFirstChild("ExpPotionIcon") },
						{ key = "Wins", endTime = stats:FindFirstChild("WinsPotionEndTime"), name = stats:FindFirstChild("WinsPotionName"), icon = stats:FindFirstChild("WinsPotionIcon") },
					}

					for _, potion in ipairs(potionChecks) do
						local endValue = potion.endTime and potion.endTime.Value or 0
						if endValue <= now then
							warningState[potion.key] = nil
						elseif endValue - now <= 300 and warningState[potion.key] ~= endValue then
							warningState[potion.key] = endValue
							local potionName = (potion.name and potion.name.Value ~= "" and potion.name.Value) or (potion.key .. " Potion")
							notifyPlayer(player, "Potion Ending Soon", potionName .. " expires in 5 minutes.", "Warning", 4, nil, {
								icon = potion.icon and potion.icon.Value or nil,
							})
						end
					end
				end
			end
		end
		task.wait(5)
	end
end)

for _, player in ipairs(Players:GetPlayers()) do
	task.spawn(onPlayerAdded, player)
end
