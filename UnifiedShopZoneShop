local function clearGeneratedFrames(container, keepSet)
	for _, child in ipairs(container:GetChildren()) do
		if child:IsA("Frame") and not keepSet[child] then
			child:Destroy()
		end
	end
end

local function applyCompactListLayout()
	if itemListLayout then
		itemListLayout.Padding = UDim.new(0, 4)
	end
	if itemListPadding then
		itemListPadding.PaddingTop = UDim.new(0, 4)
		itemListPadding.PaddingBottom = UDim.new(0, 4)
		itemListPadding.PaddingLeft = UDim.new(0, 4)
		itemListPadding.PaddingRight = UDim.new(0, 4)
	end
end

local function refreshCanvas(scrollingFrame)
	local layout = scrollingFrame:FindFirstChildWhichIsA("UIListLayout")
	if layout then
		RunService.Heartbeat:Wait()
		scrollingFrame.CanvasSize = UDim2.new(0, 0, 0, layout.AbsoluteContentSize.Y + 8)
	end
end

local function recalculateSectionOffsets()
	sectionOffsets = {}
	RunService.Heartbeat:Wait()
	for sectionName, header in pairs(sectionHeaders) do
		if header and header.Parent then
			sectionOffsets[sectionName] = math.max(0, header.AbsolutePosition.Y - itemList.AbsolutePosition.Y + itemList.CanvasPosition.Y)
		end
	end
end

local function scrollToSection(sectionName)
	local targetY = sectionOffsets[sectionName] or 0
	TweenService:Create(itemList, TweenInfo.new(0.22, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
		CanvasPosition = Vector2.new(0, targetY),
	}):Play()
end

local function openGiftMenu(item)
	giftingItem = item
	giftHeaderLabel.Text = "Gift To - " .. tostring(item.title)
	giftInfoLabel.Text = "Gifting UI only for now"
	giftFrame.Visible = true

	clearGeneratedFrames(playersList, { [playerRowTemplate] = true })
	for _, otherPlayer in ipairs(Players:GetPlayers()) do
		if otherPlayer ~= player then
			local row = playerRowTemplate:Clone()
			row.Name = "Player_" .. otherPlayer.Name
			row.Visible = true
			row.Parent = playersList

			local nameLabel = row:WaitForChild("NameLabel")
			local selectButton = row:WaitForChild("SelectButton")
			nameLabel.Text = otherPlayer.Name

			selectButton.MouseButton1Click:Connect(function()
				giftInfoLabel.Text = "Coming soon: gifting to " .. otherPlayer.Name
			end)
		end
	end

	refreshCanvas(playersList)
end

local function buyItem(item)
	if item.kind == "gamepass" then
		if item.gamePassId and item.gamePassId > 0 then
			MarketplaceService:PromptGamePassPurchase(player, item.gamePassId)
		end
	elseif item.kind == "product" then
		if item.productId and item.productId > 0 then
			MarketplaceService:PromptProductPurchase(player, item.productId)
		else
			warn("[UnifiedShop] Potion product id missing for", item.title, item.subtitle)
		end
	elseif item.kind == "winsAura" then
		if item.auraKey then
			equipAuraRemote:FireServer(item.auraKey)
		end
	elseif item.kind == "paidAura" then
		if item.auraKey then
			promptAuraPurchaseRemote:FireServer(item.auraKey)
		end
	end
end

local function createCategoryHeader(sectionName, layoutOrder)
	local header = categoryHeaderTemplate:Clone()
	header.Name = sectionName .. "Header"
	header.Visible = true
	header.LayoutOrder = layoutOrder
	header.Parent = itemList
	if header:IsA("Frame") then
		header.Size = UDim2.new(1, 0, 0, 24)
	end
	local titleLabel = header:WaitForChild("TitleLabel")
	titleLabel.Text = sectionName
	sectionHeaders[sectionName] = header
	return header
end

local function createItemCard(item, layoutOrder)
	local template = TEMPLATE_BY_TYPE[item.templateType] or greyTemplate
	local card = template:Clone()
	card.Name = (item.title:gsub("%s+", "")) .. "_Card_" .. tostring(layoutOrder)
	card.Visible = true
	card.LayoutOrder = layoutOrder
	card.Parent = itemList

	local titleLabel = card:WaitForChild("TitleLabel")
	local subtitleLabel = card:WaitForChild("SubtitleLabel")
	local buyButton = card:WaitForChild("BuyButton")
	local giftButton = card:WaitForChild("GiftButton")
	local displayImage = card:FindFirstChild("Display")

	titleLabel.Text = item.title
	subtitleLabel.Text = item.subtitle
	buyButton.Text = "Buy"
	giftButton.Text = "Gift"

	if displayImage and displayImage:IsA("ImageLabel") then
		displayImage.Image = item.displayImage or ""
	end

	buyButton.MouseButton1Click:Connect(function()
		buyItem(item)
	end)

	giftButton.MouseButton1Click:Connect(function()
		openGiftMenu(item)
	end)
end

local function renderAllSections()
	sectionHeaders = {}
	clearGeneratedFrames(itemList, {
		[categoryHeaderTemplate] = true,
		[rainbowTemplate] = true,
		[greyTemplate] = true,
	})
	applyCompactListLayout()

	local layoutOrder = 1
	for _, sectionName in ipairs(SECTION_ORDER) do
		createCategoryHeader(sectionName, layoutOrder)
		layoutOrder += 1

		for _, item in ipairs(ITEMS[sectionName] or {}) do
			createItemCard(item, layoutOrder)
			layoutOrder += 1
		end
	end

	refreshCanvas(itemList)
	recalculateSectionOffsets()
end

local function openShop(source)
	print("[UnifiedShop] openShop called from", tostring(source))
	if animating or shopOpen then return end
	animating = true
	shopOpen = true
	giftFrame.Visible = false
	renderAllSections()
	mainFrame.Visible = true
	mainFrame.Position = closedPos
	uiScale.Scale = 0.94

	local t1 = TweenService:Create(mainFrame, TweenInfo.new(0.22, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), { Position = openPos })
	local t2 = TweenService:Create(uiScale, TweenInfo.new(0.22, Enum.EasingStyle.Back, Enum.EasingDirection.Out), { Scale = 1 })
	t1:Play()
	t2:Play()
	t1.Completed:Wait()
	animating = false
end

local function closeShop(manualClose)
	if animating or not shopOpen then return end
	animating = true
	giftFrame.Visible = false
	local t1 = TweenService:Create(mainFrame, TweenInfo.new(0.18, Enum.EasingStyle.Quad, Enum.EasingDirection.In), { Position = closedPos })
	local t2 = TweenService:Create(uiScale, TweenInfo.new(0.18, Enum.EasingStyle.Quad, Enum.EasingDirection.In), { Scale = 0.94 })
	t1:Play()
	t2:Play()
	t1.Completed:Wait()
	mainFrame.Visible = false
	mainFrame.Position = openPos
	uiScale.Scale = 1
	shopOpen = false
	animating = false
	if manualClose and insideZone then
		manualClosedInsideZone = true
		print("[UnifiedShop] manually closed inside zone; waiting for re-entry")
	end
end

