local function normalizeAssetId(value)
	if value == nil then return "" end
	local raw = tostring(value):gsub("%s+", "")
	if raw == "" then return "" end
	if raw:find("rbxassetid://", 1, true) then
		return raw
	end
	local number = tonumber(raw:match("%d+"))
	if number and number > 0 then
		return "rbxassetid://" .. tostring(math.floor(number))
	end
	return raw
end

local function refreshVisiblePotionState(player, potionType)
	local stats = player:FindFirstChild("Stats")
	if not stats then return end
	local now = os.time()

	if potionType == "Exp" then
		local localMult = stats:FindFirstChild("LocalExpPotionMultiplier")
		local localEnd = stats:FindFirstChild("LocalExpPotionEndTime")
		local localName = stats:FindFirstChild("LocalExpPotionName")
		local localIcon = stats:FindFirstChild("LocalExpPotionIcon")
		local globalMult = stats:FindFirstChild("GlobalExpPotionMultiplier")
		local globalEnd = stats:FindFirstChild("GlobalExpPotionEndTime")
		local globalName = stats:FindFirstChild("GlobalExpPotionName")
		local globalIcon = stats:FindFirstChild("GlobalExpPotionIcon")
		local visibleMult = stats:FindFirstChild("ExpPotionMultiplier")
		local visibleEnd = stats:FindFirstChild("ExpPotionEndTime")
		local visibleName = stats:FindFirstChild("ExpPotionName")
		local visibleIcon = stats:FindFirstChild("ExpPotionIcon")
		if not (localMult and localEnd and localName and localIcon and globalMult and globalEnd and globalName and globalIcon and visibleMult and visibleEnd and visibleName and visibleIcon) then return end

		local useGlobal = globalEnd.Value > now and globalMult.Value >= localMult.Value and globalMult.Value > 1
		local useLocal = localEnd.Value > now and localMult.Value > 1
		if useGlobal then
			visibleMult.Value = globalMult.Value
			visibleEnd.Value = globalEnd.Value
			visibleName.Value = globalName.Value
			visibleIcon.Value = globalIcon.Value
		elseif useLocal then
			visibleMult.Value = localMult.Value
			visibleEnd.Value = localEnd.Value
			visibleName.Value = localName.Value
			visibleIcon.Value = localIcon.Value
		else
			visibleMult.Value = 1
			visibleEnd.Value = 0
			visibleName.Value = ""
			visibleIcon.Value = ""
		end
	elseif potionType == "Wins" then
		local localMult = stats:FindFirstChild("LocalWinsPotionMultiplier")
		local localEnd = stats:FindFirstChild("LocalWinsPotionEndTime")
		local localName = stats:FindFirstChild("LocalWinsPotionName")
		local localIcon = stats:FindFirstChild("LocalWinsPotionIcon")
		local globalMult = stats:FindFirstChild("GlobalWinsPotionMultiplier")
		local globalEnd = stats:FindFirstChild("GlobalWinsPotionEndTime")
		local globalName = stats:FindFirstChild("GlobalWinsPotionName")
		local globalIcon = stats:FindFirstChild("GlobalWinsPotionIcon")
		local visibleMult = stats:FindFirstChild("WinsPotionMultiplier")
		local visibleEnd = stats:FindFirstChild("WinsPotionEndTime")
		local visibleName = stats:FindFirstChild("WinsPotionName")
		local visibleIcon = stats:FindFirstChild("WinsPotionIcon")
		if not (localMult and localEnd and localName and localIcon and globalMult and globalEnd and globalName and globalIcon and visibleMult and visibleEnd and visibleName and visibleIcon) then return end

		local useGlobal = globalEnd.Value > now and globalMult.Value >= localMult.Value and globalMult.Value > 1
		local useLocal = localEnd.Value > now and localMult.Value > 1
		if useGlobal then
			visibleMult.Value = globalMult.Value
			visibleEnd.Value = globalEnd.Value
			visibleName.Value = globalName.Value
			visibleIcon.Value = globalIcon.Value
		elseif useLocal then
			visibleMult.Value = localMult.Value
			visibleEnd.Value = localEnd.Value
			visibleName.Value = localName.Value
			visibleIcon.Value = localIcon.Value
		else
			visibleMult.Value = 1
			visibleEnd.Value = 0
			visibleName.Value = ""
			visibleIcon.Value = ""
		end
	elseif potionType == "Speed" then
		local globalMult = stats:FindFirstChild("GlobalSpeedPotionMultiplier")
		local globalEnd = stats:FindFirstChild("GlobalSpeedPotionEndTime")
		local globalName = stats:FindFirstChild("GlobalSpeedPotionName")
		local globalIcon = stats:FindFirstChild("GlobalSpeedPotionIcon")
		local visibleMult = stats:FindFirstChild("SpeedPotionMultiplier")
		local visibleEnd = stats:FindFirstChild("SpeedPotionEndTime")
		local visibleName = stats:FindFirstChild("SpeedPotionName")
		local visibleIcon = stats:FindFirstChild("SpeedPotionIcon")
		if not (globalMult and globalEnd and globalName and globalIcon and visibleMult and visibleEnd and visibleName and visibleIcon) then return end

		if globalEnd.Value > now and globalMult.Value > 1 then
			visibleMult.Value = globalMult.Value
			visibleEnd.Value = globalEnd.Value
			visibleName.Value = globalName.Value
			visibleIcon.Value = globalIcon.Value
		else
			visibleMult.Value = 1
			visibleEnd.Value = 0
			visibleName.Value = ""
			visibleIcon.Value = ""
		end
	end
end

local function grantPurchasablePotion(player, config)
	if typeof(config) ~= "table" then return false end
	local stats = player:FindFirstChild("Stats")
	if not stats then return false end

	local now = os.time()
	local addSeconds = math.max(60, tonumber(config.durationSeconds) or 1800)
	local multiplier = math.max(1, tonumber(config.multiplier) or 1)
	local potionName = tostring(config.name or (tostring(multiplier) .. "x Potion"))
	local potionIcon = normalizeAssetId(config.icon)

	if config.potionType == "Exp" then
		local mult = stats:FindFirstChild("LocalExpPotionMultiplier")
		local expires = stats:FindFirstChild("LocalExpPotionEndTime")
		local name = stats:FindFirstChild("LocalExpPotionName")
		local icon = stats:FindFirstChild("LocalExpPotionIcon")
		if not mult or not expires or not name or not icon then return false end
		mult.Value = multiplier
		expires.Value = math.max(now, expires.Value) + addSeconds
		name.Value = potionName
		icon.Value = potionIcon
		refreshVisiblePotionState(player, "Exp")
		notifyPlayer(player, "Potion Activated", potionName .. " activated!", "Success", 3.5, nil, {
			icon = potionIcon,
		})
		return true
	elseif config.potionType == "Wins" then
		local mult = stats:FindFirstChild("LocalWinsPotionMultiplier")
		local expires = stats:FindFirstChild("LocalWinsPotionEndTime")
		local name = stats:FindFirstChild("LocalWinsPotionName")
		local icon = stats:FindFirstChild("LocalWinsPotionIcon")
		if not mult or not expires or not name or not icon then return false end
		mult.Value = multiplier
		expires.Value = math.max(now, expires.Value) + addSeconds
		name.Value = potionName
		icon.Value = potionIcon
		refreshVisiblePotionState(player, "Wins")
		notifyPlayer(player, "Potion Activated", potionName .. " activated!", "Success", 3.5, nil, {
			icon = potionIcon,
		})
		return true
	end

	return false
end

local function getMaxRealSpeed(player)
	local leaderstats = player:FindFirstChild("leaderstats")
	if not leaderstats then return BASE_REAL_SPEED end

	local level = leaderstats:FindFirstChild("Level")
	local lvl = (level and level.Value) or 0
	local skinBoost = getSkinSpeedBoost(player)
	local rawMax = getRealSpeedFromLevel(lvl) * (1 + skinBoost)

	return math.clamp(rawMax, BASE_REAL_SPEED, MAX_REAL_SPEED_CAP)
end

local function applyWalkSpeed(player)
	local leaderstats = player:FindFirstChild("leaderstats")
	local stats = player:FindFirstChild("Stats")
	if not leaderstats or not stats then return end

	local level = leaderstats:FindFirstChild("Level")
	local speedStat = leaderstats:FindFirstChild("Speed")
	local exp = stats:FindFirstChild("EXP")
	local expRequired = stats:FindFirstChild("EXPRequired")
	local selectedReal = stats:FindFirstChild("SelectedRealSpeed")
	local useCustomSpeed = stats:FindFirstChild("UseCustomSpeed")
	local maxRealStat = stats:FindFirstChild("MaxRealSpeed")
	if not level or not speedStat or not exp or not expRequired or not selectedReal or not useCustomSpeed or not maxRealStat then return end

	local skinBoost = getSkinSpeedBoost(player)
	local maxReal = getMaxRealSpeed(player)
	maxRealStat.Value = maxReal
	local potionMultiplier = (stats:FindFirstChild("SpeedPotionMultiplier") and stats.SpeedPotionMultiplier.Value) or 1
	potionMultiplier = math.max(1, potionMultiplier)
	local levelUpBoostEndTime = (stats:FindFirstChild("LevelUpSpeedBoostEndTime") and stats.LevelUpSpeedBoostEndTime.Value) or 0
	local levelUpMultiplier = (levelUpBoostEndTime > tick()) and LEVEL_UP_SPEED_BOOST_MULTIPLIER or 1

	local chosen
	if useCustomSpeed.Value then
		chosen = math.clamp(selectedReal.Value, BASE_REAL_SPEED, maxReal)
		selectedReal.Value = chosen
	else
		chosen = maxReal
		selectedReal.Value = chosen
	end

	local char = player.Character
	if char then
		local hum = char:FindFirstChildOfClass("Humanoid")
		if hum then
			hum.WalkSpeed = chosen * potionMultiplier * levelUpMultiplier
		end
	end

	local displayBase = getDisplaySpeedFromProgress(level.Value, exp.Value, expRequired.Value)
	speedStat.Value = math.floor(displayBase * (1 + skinBoost))
end

local function refreshOwnedExpBoost(player)
	local expBoost = player:FindFirstChild("ExpBoost")
	if not expBoost then return end

	local highestOwned = 1
	for multiplier, gamePassId in pairs(GAMEPASS_ID_BY_MULTIPLIER) do
		if gamePassId > 0 then
			local ok, ownsPass = pcall(function()
				return MarketplaceService:UserOwnsGamePassAsync(player.UserId, gamePassId)
			end)
			if ok and ownsPass and multiplier > highestOwned then
				highestOwned = multiplier
			end
		end
	end

	expBoost.Value = highestOwned
end

local function createPlayerStats(player)
