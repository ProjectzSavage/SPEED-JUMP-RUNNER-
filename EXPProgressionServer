local function getSpawnPart()
	local directSpawnLocation = workspace:FindFirstChild("SpawnLocation")
	if directSpawnLocation and directSpawnLocation:IsA("BasePart") then
		return directSpawnLocation
	end

	local directSpawnPart = workspace:FindFirstChild("SpawnPoint")
	if directSpawnPart and directSpawnPart:IsA("BasePart") then
		return directSpawnPart
	end

	local alternateSpawnPart = workspace:FindFirstChild("Spawn") or workspace:FindFirstChild("SpawnPart") or workspace:FindFirstChild("LobbySpawn")
	if alternateSpawnPart and alternateSpawnPart:IsA("BasePart") then
		return alternateSpawnPart
	end

	local spawnModel = workspace:FindFirstChild("SpawnPoint") or workspace:FindFirstChild("Spawn") or workspace:FindFirstChild("LobbySpawn")
	if spawnModel and spawnModel:IsA("Model") then
		local p = spawnModel:FindFirstChild("SpawnLocation") or spawnModel:FindFirstChildWhichIsA("BasePart")
		if p and p:IsA("BasePart") then
			return p
		end
	end

	for _, obj in ipairs(workspace:GetDescendants()) do
		if obj:IsA("SpawnLocation") then
			return obj
		end
	end

	return nil
end

