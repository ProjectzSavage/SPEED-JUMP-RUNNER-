-- StageLocationTracker (Server Script, put in ServerScriptService)
local Players = game:GetService("Players")
local CollectionService = game:GetService("CollectionService")

local function parseStageNumber(name)
	if typeof(name) ~= "string" then return nil end
	local lower = string.lower(name)
	local n = tonumber(lower:match("stage(%d+)"))
	if n then return n end
	return tonumber(name)
end

local function setupStageZone(part)
	if not part:IsA("BasePart") then return end
	if part:GetAttribute("StageZoneConnected") then return end
	part:SetAttribute("StageZoneConnected", true)

	-- Look for a stage number on the part itself, or its parent Model/Folder.
	local stageNum = parseStageNumber(part.Name)
	if not stageNum and part.Parent then
		stageNum = parseStageNumber(part.Parent.Name)
	end
	if not stageNum then
		warn("[StageZone] Could not parse a stage number from:", part:GetFullName())
		return
	end

	part.Touched:Connect(function(hit)
		local character = hit:FindFirstAncestorOfClass("Model")
		if not character then return end
		local player = Players:GetPlayerFromCharacter(character)
		if not player then return end

		local stats = player:FindFirstChild("Stats")
		local currentStage = stats and stats:FindFirstChild("CurrentStage")
		if currentStage and currentStage.Value ~= stageNum then
			currentStage.Value = stageNum
		end
	end)
end

for _, part in ipairs(CollectionService:GetTagged("StageZone")) do
	setupStageZone(part)
end
CollectionService:GetInstanceAddedSignal("StageZone"):Connect(setupStageZone)
