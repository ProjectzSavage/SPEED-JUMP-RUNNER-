local function ensureValue(parent, className, name, defaultValue)
	local v = parent:FindFirstChild(name)
	if not v then
		v = Instance.new(className)
		v.Name = name
		v.Value = defaultValue
		v.Parent = parent
	end
	return v
end

local function formatNumber(n)
	n = tonumber(n) or 0
	if n >= 1e12 then return string.format("%.2fT", n / 1e12) end
	if n >= 1e9 then return string.format("%.2fB", n / 1e9) end
	if n >= 1e6 then return string.format("%.2fM", n / 1e6) end
	if n >= 1e3 then return string.format("%.1fK", n / 1e3) end
	return tostring(math.floor(n))
end

local function notifyPlayer(player, title, message, kind, duration, icon, extra)
	local payload = {
		title = title,
		message = message,
		kind = kind or "Info",
		duration = duration or 3.5,
		icon = icon,
	}
	if type(extra) == "table" then
		for key, value in pairs(extra) do
			payload[key] = value
		end
	end
	showNotificationRemote:FireClient(player, payload)
end

local function formatExpRequired(level)
	return math.floor(100 + (level ^ 1.45) * 35)
end

local function getRealSpeedFromLevel(level)
	return BASE_REAL_SPEED + level
end

local function getDisplaySpeedFromProgress(level, exp, expRequired)
	local progress = level
	if expRequired > 0 then
		progress = progress + (exp / expRequired)
	end
	return math.floor(18.75 * progress * progress)
end

local function getProgressValue(level, exp, expRequired)
	if expRequired > 0 then
		return level + (exp / expRequired)
	end
	return level
end

local function getNextBoost(currentBoost)
	if currentBoost < 1 then currentBoost = 1 end
	if currentBoost >= 128 then return nil end
	if currentBoost == 1 then return 2 end
	return math.min(currentBoost * 2, 128)
end

local function getHighestUnlockedStepMultiplier(wins)
	local best = STEP_MULTIPLIERS[1]
	for _, info in ipairs(STEP_MULTIPLIERS) do
		if wins >= info.winsRequired and info.multiplier >= best.multiplier then
			best = info
		end
	end
	return best
end

local function getStepMultiplierValue(player)
	local stats = player:FindFirstChild("Stats")
	local value = stats and stats:FindFirstChild("StepMultiplier")
	return (value and value.Value) or 1
end

local function getEquippedStepOrder(player)
	local stats = player:FindFirstChild("Stats")
	local value = stats and stats:FindFirstChild("EquippedStepOrder")
	return (value and value.Value) or 1
end

local function setEquippedStepMultiplier(player, multiplier, order, suppressNotification)
	local stats = player:FindFirstChild("Stats")
	if not stats then return end

	multiplier = math.max(1, tonumber(multiplier) or 1)
	order = math.max(1, math.floor(tonumber(order) or 1))

	local stepValue = stats:FindFirstChild("StepMultiplier")
	local orderValue = stats:FindFirstChild("EquippedStepOrder")
	local previousMultiplier = stepValue and stepValue.Value or 1
	local previousOrder = orderValue and orderValue.Value or 1

	if stepValue then stepValue.Value = multiplier end
	if orderValue then orderValue.Value = order end

	if not suppressNotification and (previousMultiplier ~= multiplier or previousOrder ~= order) then
		notifyPlayer(player, "Step Multiplier Equipped", "x" .. tostring(multiplier) .. " /step is now equipped.", "Success", 3.2, nil, {
			iconKey = "StepMultiplier",
		})
	end
end

local function autoEquipHighestStepMultiplier(player, suppressNotification)
	local leaderstats = player:FindFirstChild("leaderstats")
	local wins = leaderstats and leaderstats:FindFirstChild("Wins")
	if not wins then return nil end

	local best = getHighestUnlockedStepMultiplier(wins.Value)
	if not best then
		setEquippedStepMultiplier(player, 1, 1, suppressNotification)
		return STEP_MULTIPLIERS[1]
	end

	setEquippedStepMultiplier(player, best.multiplier, best.order, suppressNotification)
	return best
end

local function getPlayerMultipliers(player)
	local stats = player:FindFirstChild("Stats")
	if not stats then return 1, 1, 1, 1 end

	local rebirthMult = (stats:FindFirstChild("Multiplier") and stats.Multiplier.Value) or 1
	local gamepassExpMult = (player:FindFirstChild("ExpBoost") and player.ExpBoost.Value) or 1
	local titleMult = (stats:FindFirstChild("TitleMultiplier") and stats.TitleMultiplier.Value) or 1
	local stepMult = (stats:FindFirstChild("StepMultiplier") and stats.StepMultiplier.Value) or 1
	if stepMult < 1 then stepMult = 1 end

	return rebirthMult, gamepassExpMult, titleMult, stepMult
end

local function getSkinSpeedBoost(player)
	local stats = player:FindFirstChild("Stats")
	if stats and stats:FindFirstChild("SpeedBoost") then
		return stats.SpeedBoost.Value
	end

	local leaderstats = player:FindFirstChild("leaderstats")
	if leaderstats and leaderstats:FindFirstChild("SpeedBoost") then
		return leaderstats.SpeedBoost.Value
	end

	return 0
end

local function getMaxRealSpeed(player)
	local leaderstats = player:FindFirstChild("leaderstats")
	if not leaderstats then return BASE_REAL_SPEED end

	local level = leaderstats:FindFirstChild("Level")
	local lvl = (level and level.Value) or 0
	local skinBoost = getSkinSpeedBoost(player)
	local rawMax = getRealSpeedFromLevel(lvl) * (1 + skinBoost)

	return math.clamp(rawMax, BASE_REAL_SPEED, MAX_REAL_SPEED_CAP)
end

local function applyWalkSpeed(player)
	local leaderstats = player:FindFirstChild("leaderstats")
	local stats = player:FindFirstChild("Stats")
	if not leaderstats or not stats then return end

	local level = leaderstats:FindFirstChild("Level")
	local speedStat = leaderstats:FindFirstChild("Speed")
	local exp = stats:FindFirstChild("EXP")
	local expRequired = stats:FindFirstChild("EXPRequired")
	local selectedReal = stats:FindFirstChild("SelectedRealSpeed")
	local useCustomSpeed = stats:FindFirstChild("UseCustomSpeed")
	local maxRealStat = stats:FindFirstChild("MaxRealSpeed")
	if not level or not speedStat or not exp or not expRequired or not selectedReal or not useCustomSpeed or not maxRealStat then return end

	local skinBoost = getSkinSpeedBoost(player)
	local maxReal = getMaxRealSpeed(player)
	maxRealStat.Value = maxReal

	local chosen
	if useCustomSpeed.Value then
		chosen = math.clamp(selectedReal.Value, BASE_REAL_SPEED, maxReal)
		selectedReal.Value = chosen
	else
		chosen = maxReal
		selectedReal.Value = chosen
	end

	local char = player.Character
	if char then
		local hum = char:FindFirstChildOfClass("Humanoid")
		if hum then
			hum.WalkSpeed = chosen
		end
	end

	local displayBase = getDisplaySpeedFromProgress(level.Value, exp.Value, expRequired.Value)
	speedStat.Value = math.floor(displayBase * (1 + skinBoost))
end

local function refreshOwnedExpBoost(player)
	local expBoost = player:FindFirstChild("ExpBoost")
	if not expBoost then return end

	local highestOwned = 1
	for multiplier, gamePassId in pairs(GAMEPASS_ID_BY_MULTIPLIER) do
		if gamePassId > 0 then
			local ok, ownsPass = pcall(function()
				return MarketplaceService:UserOwnsGamePassAsync(player.UserId, gamePassId)
			end)
			if ok and ownsPass and multiplier > highestOwned then
				highestOwned = multiplier
			end
		end
	end

	expBoost.Value = highestOwned
end

local function createPlayerStats(player)
	local leaderstats = player:FindFirstChild("leaderstats")
	if not leaderstats then
		leaderstats = Instance.new("Folder")
		leaderstats.Name = "leaderstats"
		leaderstats.Parent = player
	end

	local allowed = {
		Level = true,
		Rebirths = true,
		Speed = true,
		Wins = true,
		Title = true,
		CurrentSkin = true,
	}

	for _, child in ipairs(leaderstats:GetChildren()) do
		if not allowed[child.Name] then
			child:Destroy()
		end
	end

	ensureValue(leaderstats, "IntValue", "Level", 0)
	ensureValue(leaderstats, "IntValue", "Rebirths", 0)
	ensureValue(leaderstats, "IntValue", "Speed", 0)
	ensureValue(leaderstats, "IntValue", "Wins", 0)
	ensureValue(leaderstats, "StringValue", "CurrentSkin", "None")
	ensureValue(leaderstats, "StringValue", "Title", "Newbie")

	local stats = player:FindFirstChild("Stats")
	if not stats then
		stats = Instance.new("Folder")
		stats.Name = "Stats"
		stats.Parent = player
	end

	local level = leaderstats:FindFirstChild("Level")
	ensureValue(stats, "NumberValue", "EXP", 0)
	ensureValue(stats, "NumberValue", "EXPRequired", formatExpRequired(level.Value))
	ensureValue(stats, "IntValue", "Jumps", 0)
	ensureValue(stats, "IntValue", "Multiplier", 1)
	ensureValue(stats, "NumberValue", "SpeedBoost", 0)
	ensureValue(stats, "NumberValue", "TitleMultiplier", 1)
	ensureValue(stats, "BoolValue", "UseCustomSpeed", false)
	ensureValue(stats, "NumberValue", "SelectedRealSpeed", 0)
	local maxRealValue = ensureValue(stats, "NumberValue", "MaxRealSpeed", BASE_REAL_SPEED)
	local stepMultiplierValue = ensureValue(stats, "NumberValue", "StepMultiplier", 1)
	local equippedStepOrderValue = ensureValue(stats, "IntValue", "EquippedStepOrder", 1)
	if maxRealValue.Value < BASE_REAL_SPEED then maxRealValue.Value = BASE_REAL_SPEED end
	if stepMultiplierValue.Value < 1 then stepMultiplierValue.Value = 1 end
	if equippedStepOrderValue.Value < 1 then equippedStepOrderValue.Value = 1 end

	-- legacy values kept only so old scripts don't error
	ensureValue(stats, "NumberValue", "ShopSpeedBonus", 0)
	ensureValue(stats, "NumberValue", "ShopRealSpeedBonus", 0)
	ensureValue(stats, "BoolValue", "MigratedLegacyShopBonus", false)

	ensureValue(player, "NumberValue", "ExpBoost", 1)

	if not leaderstats:GetAttribute("Guarded") then
		leaderstats:SetAttribute("Guarded", true)
		leaderstats.ChildAdded:Connect(function(child)
			if not allowed[child.Name] then
				child:Destroy()
			end
		end)
	end
end

local function getSpeedExpFactor(player)
	local leaderstats = player:FindFirstChild("leaderstats")
	local displayedSpeed = (leaderstats and leaderstats:FindFirstChild("Speed") and leaderstats.Speed.Value) or 0
	local factor = ((displayedSpeed + EXP_SPEED_SCALE) / EXP_SPEED_SCALE) ^ EXP_SPEED_EXPONENT
	return math.max(1, factor)
end

local function addExp(player, amount)
	local leaderstats = player:FindFirstChild("leaderstats")
	local stats = player:FindFirstChild("Stats")
	if not leaderstats or not stats then return end

	local level = leaderstats:FindFirstChild("Level")
	local exp = stats:FindFirstChild("EXP")
	local expRequired = stats:FindFirstChild("EXPRequired")
	if not level or not exp or not expRequired then return end

	exp.Value += amount
	local levelUps = 0

	while exp.Value >= expRequired.Value and level.Value < MAX_LEVEL do
		exp.Value -= expRequired.Value
		level.Value += 1
		expRequired.Value = formatExpRequired(level.Value)
		levelUps += 1
	end

	applyWalkSpeed(player)
	if levelUps > 0 then
		levelUpFxRemote:FireClient(player, levelUps)
	end
end

local function getExpNeededToReachTargetProgress(currentLevel, currentExp, currentExpRequired, targetProgress)
	local targetLevel = math.floor(targetProgress)
	local targetFraction = targetProgress - targetLevel

	local simLevel = currentLevel
	local simExp = currentExp
	local simExpRequired = currentExpRequired
	local needed = 0

	while simLevel < targetLevel do
		needed += math.max(0, simExpRequired - simExp)
		simLevel += 1
		simExp = 0
		simExpRequired = formatExpRequired(simLevel)
	end

	local targetExpAtLevel = targetFraction * formatExpRequired(targetLevel)
	needed += math.max(0, targetExpAtLevel - simExp)

	return needed
end

local function grantSyncedSpeedProduct(player, productKey)
	local info = SPEED_SHOP_PRODUCTS[productKey]
	if not info then
		return false
	end

	local leaderstats = player:FindFirstChild("leaderstats")
	local stats = player:FindFirstChild("Stats")
	if not leaderstats or not stats then
		return false
	end

	local level = leaderstats:FindFirstChild("Level")
	local speedStat = leaderstats:FindFirstChild("Speed")
	local exp = stats:FindFirstChild("EXP")
	local expRequired = stats:FindFirstChild("EXPRequired")
	local selectedRealSpeed = stats:FindFirstChild("SelectedRealSpeed")
	local useCustomSpeed = stats:FindFirstChild("UseCustomSpeed")
	if not level or not speedStat or not exp or not expRequired then
		return false
	end

	applyWalkSpeed(player)

	local skinMultiplier = 1 + getSkinSpeedBoost(player)
	local currentDisplayedSpeed = math.max(0, math.floor(speedStat.Value))
	local targetDisplayedSpeed = math.max(currentDisplayedSpeed + 1, math.floor(currentDisplayedSpeed * (1 + info.percent) + 0.5))
	local targetBaseDisplaySpeed = math.max(0, math.ceil(targetDisplayedSpeed / skinMultiplier))

	local currentProgress = getProgressValue(level.Value, exp.Value, expRequired.Value)
	local targetProgress = math.sqrt(targetBaseDisplaySpeed / 18.75)
	if targetProgress <= currentProgress then
		targetProgress = currentProgress + 0.001
	end

	local expToGrant = getExpNeededToReachTargetProgress(level.Value, exp.Value, expRequired.Value, targetProgress)
	if expToGrant <= 0 then
		expToGrant = 1
	end

	local oldMaxReal = getMaxRealSpeed(player)
	addExp(player, expToGrant)
	local newMaxReal = getMaxRealSpeed(player)

	if useCustomSpeed and useCustomSpeed.Value and selectedRealSpeed then
		selectedRealSpeed.Value = math.clamp(selectedRealSpeed.Value + math.max(0, newMaxReal - oldMaxReal), BASE_REAL_SPEED, newMaxReal)
		applyWalkSpeed(player)
	end

	return true
end

local function migrateLegacyShopBonus(player)
	local leaderstats = player:FindFirstChild("leaderstats")
	local stats = player:FindFirstChild("Stats")
	if not leaderstats or not stats then return end

	local migrated = stats:FindFirstChild("MigratedLegacyShopBonus")
	local shopSpeedBonus = stats:FindFirstChild("ShopSpeedBonus")
	local shopRealBonus = stats:FindFirstChild("ShopRealSpeedBonus")
	if not migrated or not migrated:IsA("BoolValue") then return end
	if not shopSpeedBonus or not shopSpeedBonus:IsA("NumberValue") then return end
	if not shopRealBonus or not shopRealBonus:IsA("NumberValue") then return end
	if migrated.Value then return end
	if shopSpeedBonus.Value <= 0 and shopRealBonus.Value <= 0 then
		migrated.Value = true
		return
	end

	applyWalkSpeed(player)
	local speedStat = leaderstats:FindFirstChild("Speed")
	if not speedStat or not speedStat:IsA("IntValue") then return end

	local currentDisplayedSpeed = math.max(0, tonumber(speedStat.Value) or 0)
	local targetDisplayedSpeed = currentDisplayedSpeed + math.max(0, tonumber(shopSpeedBonus.Value) or 0)
	local skinMultiplier = 1 + getSkinSpeedBoost(player)
	local targetBaseDisplaySpeed = math.max(0, math.ceil(targetDisplayedSpeed / skinMultiplier))

	local level = leaderstats:FindFirstChild("Level")
	local exp = stats:FindFirstChild("EXP")
	local expRequired = stats:FindFirstChild("EXPRequired")
	if not level or not level:IsA("IntValue") then return end
	if not exp or not exp:IsA("NumberValue") then return end
	if not expRequired or not expRequired:IsA("NumberValue") then return end

	local currentProgress = getProgressValue(level.Value, exp.Value, expRequired.Value)
	local targetProgress = math.sqrt(targetBaseDisplaySpeed / 18.75)
	if targetProgress > currentProgress then
		local expToGrant = getExpNeededToReachTargetProgress(level.Value, exp.Value, expRequired.Value, targetProgress)
		if expToGrant > 0 then
			addExp(player, expToGrant)
		end
	end

	shopSpeedBonus.Value = 0
	shopRealBonus.Value = 0
	migrated.Value = true
	applyWalkSpeed(player)
end

promptBoostRemote.OnServerEvent:Connect(function(player, requestedMultiplier)
	local expBoost = player:FindFirstChild("ExpBoost")
	if not expBoost then return end

	local nextBoost = getNextBoost(expBoost.Value)
	if not nextBoost or requestedMultiplier ~= nextBoost then return end

	local gamePassId = GAMEPASS_ID_BY_MULTIPLIER[nextBoost]
	if not gamePassId or gamePassId <= 0 then
		warn("Missing gamepass ID for multiplier:", nextBoost)
		return
	end

	MarketplaceService:PromptGamePassPurchase(player, gamePassId)
end)

promptSpeedShopRemote.OnServerEvent:Connect(function(player, productKey)
