local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local ReplicatedStorage = game:GetService("ReplicatedStorage")

local SPEED_INCREMENT = 1
local BASE_SPEED = 4
local MAX_SPEED = 100000

local playerData = {}

local jumpRemote = Instance.new("RemoteEvent")
jumpRemote.Name = "JumpDetected"
jumpRemote.Parent = ReplicatedStorage

local function formatNumber(num)
	if num >= 1000000000 then
		return string.format("%.1fB", num / 1000000000)
	elseif num >= 1000000 then
		return string.format("%.1fM", num / 1000000)
	elseif num >= 1000 then
		return string.format("%.1fK", num / 1000)
	else
		return tostring(num)
	end
end

local function createLeaderstats(player)
	local leaderstats = Instance.new("Folder")
	leaderstats.Name = "leaderstats"
	leaderstats.Parent = player

	local speed = Instance.new("IntValue")
	speed.Name = "Speed"
	speed.Value = BASE_SPEED
	speed.Parent = leaderstats

	local jumps = Instance.new("IntValue")
	jumps.Name = "Jumps"
	jumps.Value = 0
	jumps.Parent = leaderstats

	local rebirths = Instance.new("IntValue")
	rebirths.Name = "Rebirths"
	rebirths.Value = 0
	rebirths.Parent = leaderstats

	local multiplier = Instance.new("IntValue")
	multiplier.Name = "Multiplier"
	multiplier.Value = 1
	multiplier.Parent = player

	print("Leaderstats created - Rebirths:", rebirths.Value, "Multiplier:", multiplier.Value)
end

local function onPlayerAdded(player)
	print("Player joining:", player.Name)
	createLeaderstats(player)

	playerData[player] = {
		jumpCount = 0,
		currentSpeed = BASE_SPEED,
		lastJumpTime = 0
	}

	print("Player data created for", player.Name)

	player.CharacterAdded:Connect(function(character)
		print("Character spawned for", player.Name)

		for i = 1, 3 do
			wait(i)

			local humanoid = character:FindFirstChild("Humanoid")
			if not humanoid then
				print("Attempt", i, "- No humanoid found, retrying...")
				continue
			end

			humanoid.WalkSpeed = BASE_SPEED

			if not playerData[player] then
				playerData[player] = {
					jumpCount = 0,
					currentSpeed = BASE_SPEED,
					lastJumpTime = 0
				}
				print("Attempt", i, "- Player data recreated for", player.Name)
			else
				playerData[player].currentSpeed = BASE_SPEED
				playerData[player].jumpCount = 0
				playerData[player].lastJumpTime = 0
				print("Attempt", i, "- Player data reset for", player.Name)
			end

			if player.leaderstats then
				player.leaderstats.Speed.Value = BASE_SPEED
				player.leaderstats.Jumps.Value = 0
				if not player.leaderstats:FindFirstChild("Rebirths") then
					local rebirths = Instance.new("IntValue")
					rebirths.Name = "Rebirths"
					rebirths.Value = 0
					rebirths.Parent = player.leaderstats
				end
				if not player.leaderstats:FindFirstChild("Multiplier") then
					local multiplier = Instance.new("IntValue")
					multiplier.Name = "Multiplier"
					multiplier.Value = 1
					multiplier.Parent = player.leaderstats
				end
			end

			print("Attempt", i, "- Setup complete. Player data exists:", playerData[player] ~= nil)
			break
		end
	end)
end

local function calculateActualSpeed(statSpeed)
	if statSpeed <= 50 then
		return 16 + (statSpeed * 0.4)
	elseif statSpeed <= 200 then
		return 36 + ((statSpeed - 50) * 0.2)
	elseif statSpeed <= 1000 then
		return 66 + ((statSpeed - 200) * 0.05)
	elseif statSpeed <= 5000 then
		return 106 + ((statSpeed - 1000) * 0.02)
	else
		return 186 + ((statSpeed - 5000) * 0.01)
	end
end

jumpRemote.OnServerEvent:Connect(function(player)
	print("Jump detected for", player.Name)
	local data = playerData[player]
	if not data then 
		print("No player data found for", player.Name)
		return 
	end

	if not player.Character then 
		print("No character found for", player.Name)
		return 
	end

	local humanoid = player.Character:FindFirstChild("Humanoid")
	if not humanoid then 
		print("No humanoid found for", player.Name)
		return 
	end

	local currentTime = tick()
	if currentTime - data.lastJumpTime > 0.1 then
		data.lastJumpTime = currentTime

		local multiplier = player.leaderstats:FindFirstChild("Multiplier")
		local speedBoost = player.leaderstats:FindFirstChild("SpeedBoost")
		local baseSpeedGain = SPEED_INCREMENT * (multiplier and multiplier.Value or 1)
		local speedGain = baseSpeedGain * (1 + (speedBoost and speedBoost.Value or 0))

		print("Base gain:", baseSpeedGain, "Speed boost:", speedBoost and speedBoost.Value or 0, "Final gain:", speedGain)

		data.jumpCount = data.jumpCount + 1
		data.currentSpeed = math.min(data.currentSpeed + speedGain, MAX_SPEED)

		local actualSpeed = calculateActualSpeed(data.currentSpeed)
		humanoid.WalkSpeed = actualSpeed

		player.leaderstats.Speed.Value = data.currentSpeed
		player.leaderstats.Jumps.Value = data.jumpCount

		print("Speed updated for", player.Name, "- Stat Speed:", data.currentSpeed, "Actual Speed:", actualSpeed, "Jumps:", data.jumpCount)
	end
end)

local rebirthRemote = ReplicatedStorage:FindFirstChild("RebirthRequest")
if rebirthRemote then
	rebirthRemote.OnServerEvent:Connect(function(player, rebirthLevel)
		print("Rebirth request received for", player.Name, "level", rebirthLevel)
		if playerData[player] then
			playerData[player].currentSpeed = BASE_SPEED
			playerData[player].jumpCount = 0
			playerData[player].lastJumpTime = 0
			print("Player data reset for", player.Name)
		end
	end)
end

local function onPlayerRemoving(player)
	playerData[player] = nil
end

Players.PlayerAdded:Connect(onPlayerAdded)
Players.PlayerRemoving:Connect(onPlayerRemoving)

for _, player in pairs(Players:GetPlayers()) do
	onPlayerAdded(player)
end

local function resetPlayerSpeed(player)
	if playerData[player] and player.Character then
		local humanoid = player.Character:FindFirstChild("Humanoid")
		if humanoid then
			playerData[player].jumpCount = 0
			playerData[player].currentSpeed = BASE_SPEED
			humanoid.WalkSpeed = BASE_SPEED
			player.leaderstats.Speed.Value = BASE_SPEED
			player.leaderstats.Jumps.Value = 0
		end
	end
end
