local Players = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")

local REBIRTH_REQUIREMENTS = {
	[1] = { level = 10, multiplier = 2 },
	[2] = { level = 20, multiplier = 3 },
	[3] = { level = 30, multiplier = 4 },
	[4] = { level = 40, multiplier = 5 },
	[5] = { level = 50, multiplier = 6 },
	[6] = { level = 60, multiplier = 7 },
	[7] = { level = 70, multiplier = 8 },
	[8] = { level = 80, multiplier = 9 },
	[9] = { level = 90, multiplier = 10 },
	[10] = { level = 100, multiplier = 11 },
}

local rebirthRemote = ReplicatedStorage:WaitForChild("RebirthRequest")

local function expRequiredForLevel(level)
	return math.floor(100 + (level ^ 1.45) * 35)
end

local function ensureStats(player)
	local leaderstats = player:FindFirstChild("leaderstats")
	if not leaderstats then return nil, nil end

	local stats = player:FindFirstChild("Stats")
	if not stats then
		stats = Instance.new("Folder")
		stats.Name = "Stats"
		stats.Parent = player
	end

	local rebirths = leaderstats:FindFirstChild("Rebirths")
	if not rebirths then
		rebirths = Instance.new("IntValue")
		rebirths.Name = "Rebirths"
		rebirths.Value = 0
		rebirths.Parent = leaderstats
	end

	local level = leaderstats:FindFirstChild("Level")
	if not level then
		level = Instance.new("IntValue")
		level.Name = "Level"
		level.Value = 1
		level.Parent = leaderstats
	end

	local speed = leaderstats:FindFirstChild("Speed")
	if not speed then
		speed = Instance.new("IntValue")
		speed.Name = "Speed"
		speed.Value = 0
		speed.Parent = leaderstats
	end

	local jumps = stats:FindFirstChild("Jumps")
	if not jumps then
		jumps = Instance.new("IntValue")
		jumps.Name = "Jumps"
		jumps.Value = 0
		jumps.Parent = stats
	end

	local multiplier = stats:FindFirstChild("Multiplier")
	if not multiplier then
		multiplier = Instance.new("IntValue")
		multiplier.Name = "Multiplier"
		multiplier.Value = 1
		multiplier.Parent = stats
	end

	local exp = stats:FindFirstChild("EXP")
	if not exp then
		exp = Instance.new("NumberValue")
		exp.Name = "EXP"
		exp.Value = 0
		exp.Parent = stats
	end

	local expRequired = stats:FindFirstChild("EXPRequired")
	if not expRequired then
		expRequired = Instance.new("NumberValue")
		expRequired.Name = "EXPRequired"
		expRequired.Value = expRequiredForLevel(level.Value)
		expRequired.Parent = stats
	end

	return leaderstats, stats
end

local function canRebirth(player, rebirthLevel)
	local leaderstats = player:FindFirstChild("leaderstats")
	if not leaderstats then return false end

	local level = leaderstats:FindFirstChild("Level")
	local rebirths = leaderstats:FindFirstChild("Rebirths")
	if not level or not rebirths then return false end

	local req = REBIRTH_REQUIREMENTS[rebirthLevel]
	if not req then return false end

	return level.Value >= req.level and rebirths.Value == (rebirthLevel - 1)
end

local function doRebirth(player, rebirthLevel)
	if not canRebirth(player, rebirthLevel) then
		return false
	end

	local leaderstats, stats = ensureStats(player)
	if not leaderstats or not stats then return false end

	local level = leaderstats:FindFirstChild("Level")
	local rebirths = leaderstats:FindFirstChild("Rebirths")
	local jumps = stats:FindFirstChild("Jumps")
	local multiplier = stats:FindFirstChild("Multiplier")
	local exp = stats:FindFirstChild("EXP")
	local expRequired = stats:FindFirstChild("EXPRequired")

	if not level or not rebirths or not jumps or not multiplier or not exp or not expRequired then
		return false
	end

	level.Value = 1
	exp.Value = 0
	expRequired.Value = expRequiredForLevel(1)
	jumps.Value = 0

	rebirths.Value = rebirthLevel
	multiplier.Value = REBIRTH_REQUIREMENTS[rebirthLevel].multiplier

	return true
end

rebirthRemote.OnServerEvent:Connect(function(player, rebirthLevel)
	doRebirth(player, rebirthLevel)
end)

Players.PlayerAdded:Connect(function(player)
	ensureStats(player)
	player.CharacterAdded:Connect(function()
		task.wait(0.2)
		ensureStats(player)
	end)
end)
