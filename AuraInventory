local function formatNumber(n)

	n = tonumber(n) or 0

	if n >= 1e12 then return string.format("%.2fT", n / 1e12) end

	if n >= 1e9 then return string.format("%.2fB", n / 1e9) end

	if n >= 1e6 then return string.format("%.2fM", n / 1e6) end

	if n >= 1e3 then return string.format("%.1fK", n / 1e3) end

	return tostring(math.floor(n))

end

local function ownsAura(aura)

	local purchasedValue = ownedAuras:FindFirstChild(aura.key)

	local purchased = purchasedValue and purchasedValue.Value == true

	return purchased

end

local function setCategory(tab)

	aurasPage.Visible = tab == "Auras"

	if trailsPage then trailsPage.Visible = tab == "Trails" end

	if itemsPage then itemsPage.Visible = tab == "Items" end

end

local function styleActionButton(button, text, color, active)

	button.Text = text

	button.BackgroundColor3 = color

	button.AutoButtonColor = active ~= false

end

local function refreshCanvas()

	local layout = aurasPage:FindFirstChildOfClass("UIListLayout")

	if aurasPage:IsA("ScrollingFrame") and layout then

		RunService.Heartbeat:Wait()

		aurasPage.CanvasSize = UDim2.new(0, 0, 0, layout.AbsoluteContentSize.Y + 12)

	end

end

local function updateAuraPage()

	for _, child in ipairs(aurasPage:GetChildren()) do

		if child:IsA("Frame") and child ~= template then

			child:Destroy()

		end

	end

	for index, aura in ipairs(AURAS) do

		local card = template:Clone()

		card.Name = "AuraCard_" .. aura.key

		card.Visible = true

		card.LayoutOrder = index

		card.Parent = aurasPage

		local previewImage = card:WaitForChild("PreviewImage")

		local nameLabel = card:WaitForChild("NameLabel")

		local boostLabel = card:WaitForChild("BoostLabel")

		local requirementFrame = card:WaitForChild("RequirementFrame")

		local requirementLabel = requirementFrame:WaitForChild("RequirementLabel")

		local robuxLabel = requirementFrame:WaitForChild("RobuxLabel")

		nameLabel.Text = aura.name

		boostLabel.Text = "x" .. string.format("%.2f", aura.boost) .. " EXP Boost"

		previewImage.Image = aura.previewImage or ""

		local owned = ownsAura(aura)

		local equipped = currentAura.Value == aura.key

		local winsValue = leaderstats:FindFirstChild("Wins")

		local enoughWins = winsValue and winsValue.Value >= aura.winsCost

		if equipped then

			styleActionButton(requirementLabel, "Equipped", Color3.fromRGB(70, 190, 80), false)

			styleActionButton(robuxLabel, "Unequip", Color3.fromRGB(190, 70, 70), true)

		elseif owned then

			styleActionButton(requirementLabel, "Equip", Color3.fromRGB(70, 190, 80), true)

			styleActionButton(robuxLabel, "Owned", Color3.fromRGB(110, 110, 110), false)

		else

			if aura.winsCost < math.huge then

				styleActionButton(requirementLabel, formatNumber(aura.winsCost), enoughWins and Color3.fromRGB(70, 170, 220) or Color3.fromRGB(120, 120, 120), true)

			else

				styleActionButton(requirementLabel, "N/A", Color3.fromRGB(110, 110, 110), false)

			end

			if aura.gamePassId and aura.gamePassId > 0 then

				styleActionButton(robuxLabel, tostring(aura.robuxPrice), Color3.fromRGB(170, 80, 220), true)

			else

				styleActionButton(robuxLabel, "N/A", Color3.fromRGB(110, 110, 110), false)

			end

		end

		-- RequirementLabel = buy with wins / equip

		requirementLabel.MouseButton1Click:Connect(function()

			if equipped then

				return

			end

			-- Always let server decide:

			-- if owned => equip

			-- if wins-based and enough wins => spend wins + unlock + equip

			equipAuraRemote:FireServer(aura.key)

		end)

		-- RobuxLabel = buy / owned / unequip

		robuxLabel.MouseButton1Click:Connect(function()

			if equipped then

				equipAuraRemote:FireServer("None")

				return

			end

			if owned then

				return

			end

			if aura.gamePassId and aura.gamePassId > 0 then

				promptAuraPurchaseRemote:FireServer(aura.key)

			end

		end)

	end

	refreshCanvas()

end

local function openFrame()

	if animating or mainFrame.Visible then return end

	animating = true

	setCategory("Auras")

	updateAuraPage()

	mainFrame.Visible = true

	mainFrame.Position = closedPos

	uiScale.Scale = 0.94

	local tween1 = TweenService:Create(mainFrame, TweenInfo.new(0.22, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {

		Position = openPos,

	})

	local tween2 = TweenService:Create(uiScale, TweenInfo.new(0.22, Enum.EasingStyle.Back, Enum.EasingDirection.Out), {

		Scale = 1,

	})

	tween1:Play()

	tween2:Play()

	tween1.Completed:Connect(function()

		animating = false

	end)

end

local function closeFrame()

	if animating or not mainFrame.Visible then return end

	animating = true

	local tween1 = TweenService:Create(mainFrame, TweenInfo.new(0.18, Enum.EasingStyle.Quad, Enum.EasingDirection.In), {

		Position = closedPos,

	})

	local tween2 = TweenService:Create(uiScale, TweenInfo.new(0.18, Enum.EasingStyle.Quad, Enum.EasingDirection.In), {

		Scale = 0.94,

	})

	tween1:Play()

	tween2:Play()

	tween1.Completed:Connect(function()

		mainFrame.Visible = false

		mainFrame.Position = openPos

		uiScale.Scale = 1

		animating = false

	end)

end

